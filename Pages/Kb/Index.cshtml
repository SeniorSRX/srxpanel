@page
@model SRXPanel.Pages.Kb.IndexModel
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Knowledge Base";
    ViewData["MetaDescription"] = "Guides, tutorials and answers to common hosting questions.";
}

<section class="text-center" style="padding:64px 0 28px;background:radial-gradient(ellipse at top, #16233b 0%, #0d1117 60%);">
    <div class="container" style="max-width:700px;">
        <h1 class="text-light fw-bold">How can we help?</h1>
        <p class="text-secondary fs-5">Search our knowledge base or browse by category.</p>
        <form method="get" class="d-flex gap-2 mt-3">
            <input name="q" value="@Model.Q" class="form-control form-control-lg" placeholder="Search articles…" />
            <button class="btn btn-cta btn-lg px-4" type="submit"><i class="bi bi-search"></i></button>
        </form>
    </div>
</section>

<div class="container pb-5">
    @if (!string.IsNullOrWhiteSpace(Model.Q))
    {
        <h5 class="text-light mt-4 mb-3">@Model.SearchResults.Count result(s) for “@Model.Q”</h5>
        @if (!Model.SearchResults.Any())
        {
            <p class="text-secondary">No articles matched your search. Try different keywords or <a href="/contact" class="accent">contact support</a>.</p>
        }
        else
        {
            foreach (var a in Model.SearchResults)
            {
                <a href="/kb/@a.Category!.Slug/@a.Slug" class="d-block text-decoration-none mb-2">
                    <div style="background:#161b22;border:1px solid #30363d;border-radius:10px;padding:16px;">
                        <div class="text-light fw-semibold">@a.Title</div>
                        <div class="text-secondary small">@a.Category!.Name</div>
                    </div>
                </a>
            }
        }
        <div class="mt-3"><a href="/kb" class="text-secondary text-decoration-none"><i class="bi bi-arrow-left"></i> Back to all categories</a></div>
    }
    else
    {
        <div class="row g-4 mt-2">
            @foreach (var c in Model.Categories)
            {
                <div class="col-md-6 col-lg-4">
                    <a href="/kb/@c.Slug" class="text-decoration-none">
                        <div style="background:#161b22;border:1px solid #30363d;border-radius:14px;padding:26px;height:100%;">
                            <i class="bi @c.Icon accent" style="font-size:30px;"></i>
                            <h5 class="text-light mt-3 mb-1">@c.Name</h5>
                            <p class="text-secondary small mb-2">@c.Description</p>
                            <span class="text-secondary small">@(Model.Counts.GetValueOrDefault(c.Id)) article(s)</span>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>
