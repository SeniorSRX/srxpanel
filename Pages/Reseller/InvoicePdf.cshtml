@page
@model SRXPanel.Pages.Reseller.InvoicePdfModel
@{
    Layout = null;
    var primary = Model.Branding?.PrimaryColor ?? "#2563eb";
    var company = string.IsNullOrWhiteSpace(Model.Settings.CompanyName) ? (Model.Branding?.PanelTitle ?? "Your Company") : Model.Settings.CompanyName;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Invoice @Model.Invoice.Number</title>
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Segoe UI', Arial, sans-serif; color: #1a1a1a; margin: 0; padding: 2rem; background: #f4f5f7; }
        .sheet { max-width: 800px; margin: 0 auto; background: #fff; padding: 2.5rem; box-shadow: 0 4px 24px rgba(0,0,0,.1); border-radius: 8px; }
        .head { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 3px solid @primary; padding-bottom: 1rem; margin-bottom: 1.5rem; }
        .brand { font-size: 1.6rem; font-weight: 700; color: @primary; }
        .muted { color: #6b7280; font-size: .85rem; }
        table { width: 100%; border-collapse: collapse; margin: 1.25rem 0; }
        th { text-align: left; background: #f9fafb; padding: .6rem; font-size: .8rem; text-transform: uppercase; color: #6b7280; }
        td { padding: .6rem; border-bottom: 1px solid #eee; }
        .totals { width: 260px; margin-left: auto; }
        .totals td { border: none; padding: .3rem .6rem; }
        .grand { font-weight: 700; font-size: 1.15rem; color: @primary; border-top: 2px solid #eee; }
        .pill { display:inline-block; padding: .2rem .6rem; border-radius: 999px; font-size: .75rem; font-weight:600; }
        .paid { background:#dcfce7; color:#166534; } .unpaid { background:#fef9c3; color:#854d0e; }
        .actions { max-width: 800px; margin: 1rem auto 0; text-align: right; }
        .btn { display:inline-block; background:@primary; color:#fff; text-decoration:none; padding:.5rem 1rem; border-radius:6px; border:none; cursor:pointer; font-size:.9rem; }
        @@media print { body { background:#fff; padding:0; } .sheet { box-shadow:none; } .actions { display:none; } }
    </style>
</head>
<body>
    <div class="actions">
        <button class="btn" onclick="window.print()">Print / Save as PDF</button>
    </div>
    <div class="sheet">
        <div class="head">
            <div>
                @if (Model.Settings.LogoPath != null || Model.Branding?.LogoPath != null)
                {
                    <img src="@(Model.Settings.LogoPath ?? Model.Branding?.LogoPath)" alt="logo" style="max-height:50px" />
                }
                else
                {
                    <div class="brand">@company</div>
                }
                <div class="muted">@Model.Settings.CompanyAddress</div>
                @if (!string.IsNullOrWhiteSpace(Model.Settings.TaxNumber))
                {
                    <div class="muted">@Model.Payment.TaxLabel: @Model.Settings.TaxNumber</div>
                }
            </div>
            <div style="text-align:right;">
                <div style="font-size:1.4rem; font-weight:700;">INVOICE</div>
                <div class="muted">@Model.Invoice.Number</div>
                <div class="muted">Issued: @Model.Invoice.CreatedAt.ToString("yyyy-MM-dd")</div>
                <div class="muted">Due: @Model.Invoice.DueDate.ToString("yyyy-MM-dd")</div>
                <div style="margin-top:.4rem;">
                    <span class="pill @(Model.Invoice.Status == SRXPanel.Models.ResellerInvoiceStatus.Paid ? "paid" : "unpaid")">@Model.Invoice.Status</span>
                </div>
            </div>
        </div>

        <table>
            <thead><tr><th>Description</th><th>Period</th><th style="text-align:right;">Amount</th></tr></thead>
            <tbody>
                <tr>
                    <td>Hosting platform charges</td>
                    <td>@Model.Invoice.PeriodStart.ToString("yyyy-MM-dd") – @Model.Invoice.PeriodEnd.ToString("yyyy-MM-dd")</td>
                    <td style="text-align:right;">@Model.Invoice.Amount.ToString("0.00")</td>
                </tr>
            </tbody>
        </table>

        <table class="totals">
            <tr><td>Subtotal</td><td style="text-align:right;">@Model.Invoice.Amount.ToString("0.00")</td></tr>
            @if (Model.Payment.TaxRatePercent > 0)
            {
                <tr><td>@Model.Payment.TaxLabel (@Model.Payment.TaxRatePercent%)</td><td style="text-align:right;">@Model.TaxAmount.ToString("0.00")</td></tr>
            }
            <tr class="grand"><td>Total</td><td style="text-align:right;">@Model.Total.ToString("0.00")</td></tr>
        </table>

        <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-top:1.5rem;">
            <div class="muted" style="max-width:60%;">
                @if (!string.IsNullOrWhiteSpace(Model.Settings.PaymentTerms))
                {
                    <p><strong>Payment terms:</strong> @Model.Settings.PaymentTerms</p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Settings.BankDetails))
                {
                    <p><strong>Bank transfer:</strong><br />@Model.Settings.BankDetails</p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Settings.FooterNotes))
                {
                    <p>@Model.Settings.FooterNotes</p>
                }
            </div>
            <div style="text-align:center;">
                <div id="qr"></div>
                <div class="muted" style="margin-top:.3rem;">Scan to pay</div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script>
        new QRCode(document.getElementById("qr"), {
            text: window.location.origin + "/Billing?invoice=@Model.Invoice.Number",
            width: 90, height: 90
        });
    </script>
</body>
</html>
