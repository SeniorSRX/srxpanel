@page
@model SRXPanel.Pages.Reseller.BillingModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Reseller Billing";
    string Money(decimal v) => $"{Model.Config.Currency.ToUpper()} {v:0.00}";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Reseller/Dashboard">Reseller</a></li>
            <li class="breadcrumb-item active" aria-current="page">Billing</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">Billing &amp; Balance</h4>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="srx-stat-card">
            <div class="srx-stat-value">@Money(Model.Balance)</div>
            <div class="srx-stat-label"><i class="bi bi-wallet2"></i> @(Model.Config.Model == ResellerBillingModel.Prepaid ? "Current Balance" : "Outstanding")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="srx-stat-card">
            <div class="srx-stat-value">@Model.Config.Model</div>
            <div class="srx-stat-label"><i class="bi bi-diagram-3"></i> Billing Model</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="srx-stat-card">
            <div class="srx-stat-value">@Model.Config.PlatformFeePercent%</div>
            <div class="srx-stat-label"><i class="bi bi-percent"></i> Platform Fee</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card srx-card mb-4">
            <div class="card-body">
                <h6 class="text-light mb-3"><i class="bi bi-plus-circle"></i> Add Credits</h6>
                <form method="post" asp-page-handler="AddCredit" class="input-group">
                    <span class="input-group-text">@Model.Config.Currency.ToUpper()</span>
                    <input name="amount" type="number" step="0.01" min="1" class="form-control" placeholder="50.00" />
                    <button class="btn btn-primary">Pay with Card</button>
                </form>
                <p class="text-secondary small mt-2 mb-0">Charged via Stripe (simulation on dev).</p>
            </div>
        </div>

        @if (Model.Config.Model == ResellerBillingModel.Prepaid)
        {
            <div class="card srx-card">
                <div class="card-body">
                    <h6 class="text-light mb-3"><i class="bi bi-arrow-repeat"></i> Auto Top-Up</h6>
                    <form method="post" asp-page-handler="AutoTopUp">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" name="enabled" value="true" @(Model.Config.AutoTopUpEnabled ? "checked" : "") />
                            <label class="form-check-label">Enable auto top-up</label>
                        </div>
                        <div class="mb-2"><label class="form-label small">Top up when balance below</label><input name="threshold" type="number" step="0.01" value="@Model.Config.AutoTopUpThreshold" class="form-control" /></div>
                        <div class="mb-3"><label class="form-label small">Top-up amount</label><input name="topUpAmount" type="number" step="0.01" value="@Model.Config.AutoTopUpAmount" class="form-control" /></div>
                        <button class="btn btn-outline-primary btn-sm"><i class="bi bi-save"></i> Save</button>
                    </form>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-8">
        <div class="card srx-card mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-light mb-0"><i class="bi bi-list-columns"></i> Transactions</h6>
                    <div class="btn-group btn-group-sm">
                        <a asp-page="/Reseller/Billing" class="btn @(Model.Filter == null ? "btn-primary" : "btn-outline-secondary")">All</a>
                        @foreach (var t in Enum.GetValues<ResellerTransactionType>())
                        {
                            <a asp-page="/Reseller/Billing" asp-route-filter="@t" class="btn @(Model.Filter == t ? "btn-primary" : "btn-outline-secondary")">@t</a>
                        }
                    </div>
                </div>
                @if (Model.Transactions.Any())
                {
                    <table class="table table-sm align-middle mb-0">
                        <thead><tr><th>Date</th><th>Type</th><th class="text-end">Amount</th><th class="text-end">Balance</th><th>Note</th></tr></thead>
                        <tbody>
                            @foreach (var t in Model.Transactions)
                            {
                                <tr>
                                    <td class="text-secondary small">@t.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td><span class="badge text-bg-secondary">@t.Type</span></td>
                                    <td class="text-end @(t.Type == ResellerTransactionType.Credit ? "text-success" : "text-danger")">
                                        @(t.Type == ResellerTransactionType.Credit ? "+" : "-")@t.Amount.ToString("0.00")
                                    </td>
                                    <td class="text-end">@t.Balance.ToString("0.00")</td>
                                    <td class="small">@t.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-secondary mb-0">No transactions yet.</p>
                }
            </div>
        </div>

        <div class="card srx-card">
            <div class="card-body">
                <h6 class="text-light mb-3"><i class="bi bi-receipt"></i> Platform Invoices</h6>
                @if (Model.Invoices.Any())
                {
                    <table class="table table-sm align-middle mb-0">
                        <thead><tr><th>Number</th><th>Period</th><th class="text-end">Amount</th><th>Status</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var inv in Model.Invoices)
                            {
                                <tr>
                                    <td>@inv.Number</td>
                                    <td class="small text-secondary">@inv.PeriodStart.ToString("MM/dd") – @inv.PeriodEnd.ToString("MM/dd")</td>
                                    <td class="text-end">@inv.Amount.ToString("0.00")</td>
                                    <td><span class="badge @(inv.Status == ResellerInvoiceStatus.Paid ? "text-bg-success" : inv.Status == ResellerInvoiceStatus.Void ? "text-bg-secondary" : "text-bg-warning")">@inv.Status</span></td>
                                    <td class="text-end"><a asp-page="/Reseller/InvoicePdf" asp-route-id="@inv.Id" target="_blank" class="btn btn-sm btn-outline-secondary"><i class="bi bi-download"></i></a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-secondary mb-0">No invoices yet.</p>
                }
            </div>
        </div>
    </div>
</div>
