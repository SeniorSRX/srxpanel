@page
@using SRXPanel.Services
@model SRXPanel.Pages.AboutModel
@inject IFrontendService Frontend
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "About Us";
    var fs = await Frontend.GetSettingsAsync();
    ViewData["MetaDescription"] = fs.MissionStatement;
}

<section class="text-center" style="padding:64px 0 24px;background:radial-gradient(ellipse at top, #16233b 0%, #0d1117 60%);">
    <div class="container" style="max-width:760px;">
        <h1 class="text-light fw-bold">About @fs.SiteName</h1>
        <p class="text-secondary fs-5">@fs.Tagline</p>
    </div>
</section>

<div class="container pb-5" style="max-width:820px;">
    <div class="py-4">
        <p class="text-light fs-5" style="line-height:1.8;">@fs.AboutContent</p>
    </div>

    <div class="p-4 my-3 text-center" style="background:#161b22;border:1px solid #30363d;border-radius:14px;">
        <i class="bi bi-bullseye accent" style="font-size:32px;"></i>
        <h4 class="text-light mt-2">Our mission</h4>
        <p class="text-secondary mb-0" style="max-width:560px;margin:0 auto;">@fs.MissionStatement</p>
    </div>

    <div class="row g-4 text-center my-4">
        <div class="col-md-4"><i class="bi bi-people accent fs-2"></i><h5 class="text-light mt-2">Customer first</h5><p class="text-secondary small">Every decision starts with what's best for our customers.</p></div>
        <div class="col-md-4"><i class="bi bi-shield-check accent fs-2"></i><h5 class="text-light mt-2">Reliable</h5><p class="text-secondary small">99.9% uptime backed by resilient infrastructure.</p></div>
        <div class="col-md-4"><i class="bi bi-heart accent fs-2"></i><h5 class="text-light mt-2">Open</h5><p class="text-secondary small">Built in the open, with a thriving community.</p></div>
    </div>

    <h4 class="text-light text-center mt-5 mb-4">Meet the team</h4>
    <div class="row g-4 justify-content-center">
        @{
            var team = new (string Name, string Role)[]
            {
                ("Alex Rivera", "Founder & CEO"),
                ("Sam Chen", "Head of Engineering"),
                ("Maria Lopez", "Customer Success")
            };
        }
        @foreach (var m in team)
        {
            <div class="col-6 col-md-4 text-center">
                <div style="width:88px;height:88px;border-radius:50%;background:var(--srx-primary);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;color:#fff;font-size:30px;font-weight:800;">@m.Name.Substring(0,1)</div>
                <div class="text-light fw-semibold">@m.Name</div>
                <div class="text-secondary small">@m.Role</div>
            </div>
        }
    </div>
</div>
