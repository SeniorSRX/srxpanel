@page "{domainId:int}"
@model SRXPanel.Pages.Dns.RecordsModel
@using SRXPanel.Models
@{
    ViewData["Title"] = $"DNS Records — {Model.Domain.DomainName}";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-page="/Dns/Index">DNS</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Domain.DomainName</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">DNS Records — <span class="text-secondary">@Model.Domain.DomainName</span></h4>
    <div class="d-flex gap-2">
        <form method="post" asp-page-handler="Template" asp-route-domainId="@Model.DomainId" asp-route-template="www" class="d-inline">
            <button class="btn btn-sm btn-outline-secondary" title="Add www/root A + CNAME"><i class="bi bi-globe"></i> www preset</button>
        </form>
        <form method="post" asp-page-handler="Template" asp-route-domainId="@Model.DomainId" asp-route-template="mail" class="d-inline">
            <button class="btn btn-sm btn-outline-secondary" title="Add MX + mail A + SPF"><i class="bi bi-envelope"></i> mail preset</button>
        </form>
        <form method="post" asp-page-handler="Template" asp-route-domainId="@Model.DomainId" asp-route-template="ftp" class="d-inline">
            <button class="btn btn-sm btn-outline-secondary" title="Add ftp A record"><i class="bi bi-folder"></i> ftp preset</button>
        </form>
    </div>
</div>

<div class="card srx-card mb-3">
    <div class="card-body">
        <h6 class="text-light mb-3">Add Record</h6>
        <form method="post" asp-page-handler="Save" asp-route-domainId="@Model.DomainId" class="row g-2 align-items-end">
            <input type="hidden" asp-for="Input.Id" value="" />
            <div class="col-md-2">
                <label class="form-label small">Type</label>
                <select asp-for="Input.Type" class="form-select" id="recType">
                    @foreach (var t in Enum.GetValues<DnsRecordType>())
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Name</label>
                <input asp-for="Input.Name" class="form-control" placeholder="@@" />
            </div>
            <div class="col-md-4">
                <label class="form-label small">Value</label>
                <input asp-for="Input.Value" class="form-control" placeholder="203.0.113.10" />
            </div>
            <div class="col-md-1">
                <label class="form-label small">TTL</label>
                <input asp-for="Input.TTL" class="form-control" />
            </div>
            <div class="col-md-1">
                <label class="form-label small">Priority</label>
                <input asp-for="Input.Priority" class="form-control" placeholder="—" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-lg"></i> Add</button>
            </div>
        </form>
    </div>
</div>

<div class="card srx-card">
    <div class="card-body">
        @if (Model.Records.Any())
        {
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Name</th>
                        <th>Value</th>
                        <th>TTL</th>
                        <th>Priority</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Records)
                    {
                        <tr>
                            <td><span class="badge text-bg-secondary">@r.Type</span></td>
                            <td>@r.Name</td>
                            <td><code>@r.Value</code></td>
                            <td>@r.TTL</td>
                            <td>@(r.Priority?.ToString() ?? "—")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#edit-@r.Id" title="Edit"><i class="bi bi-pencil"></i></button>
                                    <form method="post" asp-page-handler="Delete" asp-route-domainId="@Model.DomainId" asp-route-recordId="@r.Id" class="d-inline srx-confirm-form" data-confirm-message="Delete this @r.Type record?">
                                        <button type="submit" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <tr class="collapse" id="edit-@r.Id">
                            <td colspan="6">
                                <form method="post" asp-page-handler="Save" asp-route-domainId="@Model.DomainId" class="row g-2 align-items-end">
                                    <input type="hidden" name="Input.Id" value="@r.Id" />
                                    <div class="col-md-2">
                                        <label class="form-label small">Type</label>
                                        <select name="Input.Type" class="form-select">
                                            @foreach (var t in Enum.GetValues<DnsRecordType>())
                                            {
                                                if (t == r.Type)
                                                {
                                                    <option value="@t" selected>@t</option>
                                                }
                                                else
                                                {
                                                    <option value="@t">@t</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">Name</label>
                                        <input name="Input.Name" value="@r.Name" class="form-control" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label small">Value</label>
                                        <input name="Input.Value" value="@r.Value" class="form-control" />
                                    </div>
                                    <div class="col-md-1">
                                        <label class="form-label small">TTL</label>
                                        <input name="Input.TTL" value="@r.TTL" class="form-control" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">Priority</label>
                                        <input name="Input.Priority" value="@r.Priority" class="form-control" />
                                    </div>
                                    <div class="col-md-2">
                                        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check-lg"></i> Save</button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No DNS records yet. Add one above or apply a preset.</p>
        }
    </div>
</div>
