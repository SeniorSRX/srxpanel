@page
@model SRXPanel.Pages.VpsModel
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "VPS Hosting";
    ViewData["MetaDescription"] = "High-performance KVM VPS with full root access, NVMe SSD and instant deployment.";
    string Money(decimal d) => $"${d:0.00}";
    var osIcons = new Dictionary<string, string> { ["ubuntu"] = "bi-ubuntu", ["debian"] = "bi-hdd", ["centos"] = "bi-server", ["fedora"] = "bi-hdd", ["rocky"] = "bi-server" };
}

<section class="text-center" style="padding:56px 0 24px;">
    <div class="container">
        <h1 class="text-light fw-bold">VPS Hosting</h1>
        <p class="text-secondary fs-5">KVM virtualization, full root access and instant deployment.</p>
    </div>
</section>

<div class="container pb-4">
    <div class="row g-4 justify-content-center">
        @foreach (var v in Model.Plans)
        {
            <div class="col-lg-4 col-md-6">
                <div style="background:#161b22;border:1px solid @(v.IsPopular ? "var(--srx-primary)" : "#30363d");border-radius:16px;padding:30px;height:100%;@(v.IsPopular ? "box-shadow:0 0 0 1px var(--srx-primary);" : "")">
                    @if (v.IsPopular) { <span class="badge text-bg-primary mb-2">Most Popular</span> }
                    <h3 class="text-light">@v.Name</h3>
                    <div class="text-secondary small mb-2"><i class="bi bi-geo-alt accent"></i> @v.Location</div>
                    <div class="my-3"><span style="font-size:42px;font-weight:800;color:#fff;">@Money(v.Price)</span><span class="text-secondary">/mo</span></div>
                    <a href="/register" class="btn @(v.IsPopular ? "btn-cta" : "btn-outline-cta") w-100 mb-3">Deploy Now</a>
                    <div class="text-secondary py-1"><i class="bi bi-cpu accent"></i> @v.CpuCores vCPU core(s)</div>
                    <div class="text-secondary py-1"><i class="bi bi-memory accent"></i> @(v.RamMB / 1024) GB RAM</div>
                    <div class="text-secondary py-1"><i class="bi bi-hdd accent"></i> @v.DiskGB GB NVMe SSD</div>
                    <div class="text-secondary py-1"><i class="bi bi-arrow-left-right accent"></i> @(v.BandwidthGB / 1000) TB bandwidth</div>
                    <div class="mt-3 d-flex gap-2 align-items-center">
                        <span class="text-secondary small">OS:</span>
                        @foreach (var os in v.OsList)
                        {
                            <span class="badge" style="background:#0d1117;border:1px solid #30363d;color:#c9d1d9;text-transform:capitalize;">
                                <i class="bi @(osIcons.GetValueOrDefault(os, "bi-disc"))"></i> @os
                            </span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<section class="py-5" style="background:#0b0f14;">
    <div class="container">
        <h2 class="text-center text-light fw-bold mb-5">Why our VPS?</h2>
        <div class="row g-4 text-center">
            @{
                var feats = new (string Icon, string Title, string Desc)[]
                {
                    ("bi-terminal", "Full Root Access", "Complete control of your server — install anything you need."),
                    ("bi-cpu", "KVM Virtualization", "Dedicated, guaranteed resources with true isolation."),
                    ("bi-lightning-charge", "Instant Deploy", "Your VPS is provisioned and online in under 60 seconds."),
                    ("bi-clock-history", "Hourly Billing", "Pay only for what you use with optional hourly billing.")
                };
            }
            @foreach (var f in feats)
            {
                <div class="col-md-6 col-lg-3">
                    <i class="bi @f.Icon accent" style="font-size:30px;"></i>
                    <h5 class="text-light mt-3">@f.Title</h5>
                    <p class="text-secondary small">@f.Desc</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="text-center text-light fw-bold mb-4">Compare VPS plans</h2>
        <div class="table-responsive" style="max-width:900px;margin:0 auto;">
            <table class="table table-dark align-middle text-center" style="background:#161b22;border-radius:12px;overflow:hidden;">
                <thead>
                    <tr>
                        <th class="text-start">Plan</th>
                        <th>vCPU</th><th>RAM</th><th>SSD</th><th>Bandwidth</th><th>Price</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Plans)
                    {
                        <tr>
                            <td class="text-start text-light fw-semibold">@v.Name</td>
                            <td>@v.CpuCores</td>
                            <td>@(v.RamMB / 1024) GB</td>
                            <td>@v.DiskGB GB</td>
                            <td>@(v.BandwidthGB / 1000) TB</td>
                            <td>@Money(v.Price)/mo</td>
                            <td><a href="/register" class="btn btn-sm btn-cta">Deploy</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
