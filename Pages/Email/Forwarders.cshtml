@page
@model SRXPanel.Pages.Email.ForwardersModel
@{
    ViewData["Title"] = "Email Forwarders";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-page="/Email/Index">Email</a></li>
            <li class="breadcrumb-item active" aria-current="page">Forwarders</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">Email Forwarders</h4>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card srx-card">
            <div class="card-body">
                <h6 class="text-light mb-3">Add Forwarder</h6>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <form method="post">
                    @if (Model.CanChooseOwner)
                    {
                        <div class="mb-3">
                            <label asp-for="Input.OwnerId" class="form-label"></label>
                            <select asp-for="Input.OwnerId" asp-items="Model.OwnerOptions" class="form-select">
                                <option value="">-- Select owner --</option>
                            </select>
                        </div>
                    }
                    <div class="mb-3">
                        <label asp-for="Input.Source" class="form-label">Source Address</label>
                        <input asp-for="Input.Source" class="form-control" placeholder="info@example.com" />
                        <span asp-validation-for="Input.Source" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Destination" class="form-label">Forward To</label>
                        <input asp-for="Input.Destination" class="form-control" placeholder="you@gmail.com" />
                        <span asp-validation-for="Input.Destination" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-lg"></i> Add Forwarder</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card srx-card">
            <div class="card-body">
                <h6 class="text-light mb-3">Existing Forwarders</h6>
                @if (Model.Forwarders.Any())
                {
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Source</th>
                                <th>Destination</th>
                                @if (Model.ShowOwner)
                                {
                                    <th>Owner</th>
                                }
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in Model.Forwarders)
                            {
                                <tr>
                                    <td>@f.Source</td>
                                    <td>@f.Destination</td>
                                    @if (Model.ShowOwner)
                                    {
                                        <td>@(f.User?.UserName ?? "-")</td>
                                    }
                                    <td class="text-end">
                                        <form method="post" asp-page="/Email/Index" asp-page-handler="DeleteForwarder" asp-route-id="@f.Id" class="d-inline srx-confirm-form" data-confirm-message="Delete this forwarder?">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-secondary mb-0">No forwarders yet.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
