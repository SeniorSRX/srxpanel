@page
@model SRXPanel.Pages.Packages.IndexModel
@{
    ViewData["Title"] = "Packages";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Packages</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">Hosting Packages</h4>
    <a asp-page="/Packages/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Package</a>
</div>

<div class="row g-3">
    @foreach (var p in Model.Packages)
    {
        <div class="col-md-4">
            <div class="card srx-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="text-light">@p.Name</h5>
                    <div class="text-secondary small mb-3">@p.Price.ToString("C")/mo</div>
                    <ul class="list-unstyled small text-secondary flex-grow-1">
                        <li><i class="bi bi-hdd"></i> Disk: @(p.DiskQuotaMB == 0 ? "Unlimited" : $"{p.DiskQuotaMB} MB")</li>
                        <li><i class="bi bi-activity"></i> Bandwidth: @(p.BandwidthQuotaMB == 0 ? "Unlimited" : $"{p.BandwidthQuotaMB} MB")</li>
                        <li><i class="bi bi-globe2"></i> Domains: @(p.MaxDomains == 0 ? "Unlimited" : p.MaxDomains)</li>
                        <li><i class="bi bi-envelope"></i> Emails: @(p.MaxEmails == 0 ? "Unlimited" : p.MaxEmails)</li>
                        <li><i class="bi bi-database"></i> Databases: @(p.MaxDatabases == 0 ? "Unlimited" : p.MaxDatabases)</li>
                        <li><i class="bi bi-folder"></i> FTP Accounts: @(p.MaxFtpAccounts == 0 ? "Unlimited" : p.MaxFtpAccounts)</li>
                    </ul>
                    <div class="d-flex gap-2 mt-3">
                        <a asp-page="/Packages/Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary flex-grow-1">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@p.Id" class="srx-confirm-form" data-confirm-message="Delete package '@p.Name'?">
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Packages.Any())
{
    <p class="text-secondary">No packages defined yet.</p>
}
