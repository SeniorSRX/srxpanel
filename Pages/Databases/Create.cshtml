@page
@model SRXPanel.Pages.Databases.CreateModel
@{
    ViewData["Title"] = "New Database";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-page="/Databases/Index">Databases</a></li>
            <li class="breadcrumb-item active" aria-current="page">New</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">Create Database</h4>

<div class="card srx-card" style="max-width: 640px;">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <form method="post">
            <div class="row g-3">
                @if (Model.CanChooseOwner)
                {
                    <div class="col-md-12">
                        <label asp-for="Input.OwnerId" class="form-label"></label>
                        <select asp-for="Input.OwnerId" asp-items="Model.OwnerOptions" class="form-select">
                            <option value="">-- Select owner --</option>
                        </select>
                        <div class="form-text">Reload the page after selecting an owner to load their domains.</div>
                    </div>
                }
                <div class="col-md-6">
                    <label asp-for="Input.DbNameSuffix" class="form-label"></label>
                    <div class="input-group">
                        @if (!string.IsNullOrEmpty(Model.Prefix))
                        {
                            <span class="input-group-text">@Model.Prefix</span>
                        }
                        <input asp-for="Input.DbNameSuffix" class="form-control" placeholder="mydb" />
                    </div>
                    <span asp-validation-for="Input.DbNameSuffix" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.DbUserSuffix" class="form-label"></label>
                    <div class="input-group">
                        @if (!string.IsNullOrEmpty(Model.Prefix))
                        {
                            <span class="input-group-text">@Model.Prefix</span>
                        }
                        <input asp-for="Input.DbUserSuffix" class="form-control" placeholder="dbuser" />
                    </div>
                    <span asp-validation-for="Input.DbUserSuffix" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Input.Password" class="form-label"></label>
                    <input asp-for="Input.Password" type="text" class="form-control" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    <div class="form-text">Auto-generated. Copy it now — it is stored hashed.</div>
                </div>
                @if (Model.DomainOptions.Any())
                {
                    <div class="col-md-4">
                        <label asp-for="Input.DomainId" class="form-label"></label>
                        <select asp-for="Input.DomainId" asp-items="Model.DomainOptions" class="form-select">
                            <option value="">-- None --</option>
                        </select>
                    </div>
                }
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create Database</button>
                <a asp-page="/Databases/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
