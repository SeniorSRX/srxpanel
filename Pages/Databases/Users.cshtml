@page
@model SRXPanel.Pages.Databases.UsersModel
@{
    ViewData["Title"] = "Database Users";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-page="/Databases/Index">Databases</a></li>
            <li class="breadcrumb-item active" aria-current="page">DB Users</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">Database Users &amp; Permissions</h4>

<div class="card srx-card">
    <div class="card-body">
        @if (Model.Databases.Any())
        {
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>DB User</th>
                        <th>Database</th>
                        @if (Model.ShowOwner)
                        {
                            <th>Owner</th>
                        }
                        <th>Permissions</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Databases)
                    {
                        <tr>
                            <td>@d.DbUser</td>
                            <td><code>@d.DbName</code></td>
                            @if (Model.ShowOwner)
                            {
                                <td>@(d.User?.UserName ?? "-")</td>
                            }
                            <td><span class="badge text-bg-secondary">ALL PRIVILEGES</span></td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#reset-@d.Id">
                                    <i class="bi bi-key"></i> Reset Password
                                </button>
                            </td>
                        </tr>
                        <tr class="collapse" id="reset-@d.Id">
                            <td colspan="@(Model.ShowOwner ? 5 : 4)">
                                <form method="post" asp-page-handler="ResetPassword" class="row g-2 align-items-end">
                                    <input type="hidden" name="Reset.DatabaseId" value="@d.Id" />
                                    <div class="col-md-6">
                                        <label class="form-label small">New password for @d.DbUser</label>
                                        <input name="Reset.NewPassword" type="text" class="form-control form-control-sm" value="@SRXPanel.Services.HostingHelpers.GeneratePassword()" />
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg"></i> Save</button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No database users found. Create a database first.</p>
        }
    </div>
</div>
