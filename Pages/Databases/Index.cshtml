@page
@model SRXPanel.Pages.Databases.IndexModel
@{
    ViewData["Title"] = "Databases";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Databases</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">Databases</h4>
    <div class="d-flex gap-2">
        <a asp-page="/Databases/Users" class="btn btn-outline-secondary"><i class="bi bi-person-gear"></i> DB Users</a>
        <a asp-page="/Databases/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Database</a>
    </div>
</div>

@if (Model.IsSuperAdmin)
{
    <form method="get" class="mb-3">
        <div class="input-group" style="max-width: 360px;">
            <span class="input-group-text"><i class="bi bi-funnel"></i></span>
            <select name="FilterUserId" asp-items="Model.UserFilterOptions" class="form-select" onchange="this.form.submit()">
                <option value="">All users</option>
            </select>
        </div>
    </form>
}

<div class="card srx-card">
    <div class="card-body">
        @if (Model.Databases.Any())
        {
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Database</th>
                        <th>DB User</th>
                        @if (Model.ShowOwner)
                        {
                            <th>Owner</th>
                        }
                        <th>Domain</th>
                        <th>Size</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Databases)
                    {
                        <tr>
                            <td><code>@d.DbName</code></td>
                            <td>@d.DbUser</td>
                            @if (Model.ShowOwner)
                            {
                                <td>@(d.User?.UserName ?? "-")</td>
                            }
                            <td>@(d.Domain?.DomainName ?? "-")</td>
                            <td>@d.DbSize.ToString("0.0") MB</td>
                            <td>
                                @if (d.IsActive)
                                {
                                    <span class="badge srx-badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge srx-badge-suspended">Inactive</span>
                                }
                            </td>
                            <td>@d.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="Delete" asp-route-id="@d.Id" class="d-inline srx-confirm-form" data-confirm-message="Delete database '@d.DbName'? All data will be lost.">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No databases found.</p>
        }
    </div>
</div>
