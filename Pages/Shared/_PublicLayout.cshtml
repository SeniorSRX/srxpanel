@using SRXPanel.Services
@using Microsoft.Extensions.Options
@inject IFrontendService Frontend
@inject IOptions<PublicSiteOptions> SiteOptions
@{
    var fs = await Frontend.GetSettingsAsync();
    var site = SiteOptions.Value;
    var companyName = string.IsNullOrWhiteSpace(fs.SiteName) ? "Professional Web Hosting" : fs.SiteName;
    var title = ViewData["Title"]?.ToString();
    var pageTitle = string.IsNullOrEmpty(title) ? companyName : $"{title} - {companyName}";
    var metaDesc = ViewData["MetaDescription"]?.ToString() ?? fs.MetaDescription;
    var ogImage = ViewData["OgImage"]?.ToString();
    var canonical = ViewData["Canonical"]?.ToString();
    var jsonLd = ViewData["JsonLd"]?.ToString();
    var lang = Context.Request.Cookies["srx_lang"] ?? "en";
    var dir = lang == "ar" ? "rtl" : "ltr";
    var isAdmin = User.IsInRole(Roles.SuperAdmin);
    var maintenance = fs.MaintenanceMode && !isAdmin;
    string Nav(string href) => Context.Request.Path.Value?.TrimEnd('/').Equals(href, StringComparison.OrdinalIgnoreCase) == true ? "active" : "";
    var year = DateTime.UtcNow.Year;
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    @if (!string.IsNullOrEmpty(metaDesc))
    {
        <meta name="description" content="@metaDesc" />
    }
    @if (!string.IsNullOrEmpty(canonical))
    {
        <link rel="canonical" href="@canonical" />
    }
    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@companyName" />
    <meta property="og:title" content="@pageTitle" />
    @if (!string.IsNullOrEmpty(metaDesc)) { <meta property="og:description" content="@metaDesc" /> }
    @if (!string.IsNullOrEmpty(ogImage)) { <meta property="og:image" content="@ogImage" /> }
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root { --srx-primary: @fs.PrimaryColor; --srx-secondary: @fs.SecondaryColor; }
        body { background:#0d1117; color:#c9d1d9; }
        .pubnav { position:fixed; top:0; left:0; right:0; z-index:1000; transition:background .25s, border-color .25s; border-bottom:1px solid transparent; }
        .pubnav.solid { background:rgba(13,17,23,.95); backdrop-filter:blur(10px); border-bottom-color:#21262d; }
        .pubnav .brand { font-size:22px; font-weight:800; color:#fff; text-decoration:none; }
        .pubnav .nav-link { color:#c9d1d9; font-weight:500; }
        .pubnav .nav-link:hover, .pubnav .nav-link.active { color:#fff; }
        .btn-cta { background:var(--srx-primary); border-color:var(--srx-primary); color:#fff; font-weight:600; }
        .btn-cta:hover { filter:brightness(1.1); color:#fff; }
        .btn-outline-cta { border:1px solid #30363d; color:#e6edf3; }
        .btn-outline-cta:hover { border-color:var(--srx-primary); color:#fff; }
        main.pubmain { padding-top:72px; min-height:70vh; }
        .pubfooter { border-top:1px solid #21262d; background:#0b0f14; padding:56px 0 28px; margin-top:64px; }
        .pubfooter a { color:#8b949e; text-decoration:none; display:block; padding:4px 0; }
        .pubfooter a:hover { color:#fff; }
        .pubfooter h6 { color:#fff; font-size:13px; text-transform:uppercase; letter-spacing:.5px; margin-bottom:12px; }
        .social-ico { display:inline-flex; width:36px; height:36px; align-items:center; justify-content:center; border:1px solid #30363d; border-radius:8px; color:#c9d1d9; font-size:16px; }
        .social-ico:hover { border-color:var(--srx-primary); color:#fff; }
        .cookie-bar { position:fixed; bottom:0; left:0; right:0; z-index:1100; background:#161b22; border-top:1px solid #30363d; padding:14px 20px; }
        a.footer-brand { font-size:20px; font-weight:800; color:#fff; text-decoration:none; }
        .accent { color:var(--srx-primary); }
    </style>
    @if (!string.IsNullOrWhiteSpace(fs.CustomCss))
    {
        @Html.Raw($"<style>{fs.CustomCss}</style>")
    }
    @if (!string.IsNullOrEmpty(fs.GoogleAnalyticsId))
    {
        <script async src="https://www.googletagmanager.com/gtag/js?id=@fs.GoogleAnalyticsId"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@fs.GoogleAnalyticsId');
        </script>
    }
    @if (!string.IsNullOrEmpty(fs.FacebookPixelId))
    {
        <script>
            !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
            fbq('init', '@fs.FacebookPixelId'); fbq('track', 'PageView');
        </script>
    }
    @if (!string.IsNullOrEmpty(jsonLd))
    {
        @Html.Raw($"<script type=\"application/ld+json\">{jsonLd}</script>")
    }
</head>
<body>
@if (maintenance)
{
    <div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height:100vh;padding:24px;">
        <i class="bi bi-cone-striped" style="font-size:64px;color:var(--srx-primary);"></i>
        @if (!string.IsNullOrEmpty(fs.LogoPath))
        {
            <img src="@fs.LogoPath" alt="@companyName" class="mt-3" style="max-height:48px;" />
        }
        else
        {
            <h1 class="text-light mt-3">@companyName</h1>
        }
        <p class="text-secondary fs-5" style="max-width:520px;">@fs.MaintenanceMessage</p>
        <a href="/Account/Login" class="btn btn-outline-cta mt-2">Staff Login</a>
    </div>
}
else
{
    <nav class="pubnav" id="pubnav">
        <div class="container d-flex align-items-center justify-content-between py-3">
            <a href="/" class="brand">
                @if (!string.IsNullOrEmpty(fs.LogoPath))
                {
                    <img src="@fs.LogoPath" alt="@companyName" style="max-height:34px;max-width:180px;" />
                }
                else
                {
                    @companyName
                }
            </a>
            <button class="btn btn-sm btn-outline-cta d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#pubmenu"><i class="bi bi-list"></i></button>
            <div class="collapse navbar-collapse d-lg-flex" id="pubmenu">
                <ul class="navbar-nav mx-lg-auto d-flex flex-lg-row gap-lg-1 mt-3 mt-lg-0">
                    <li class="nav-item"><a class="nav-link @Nav("")" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link @Nav("/pricing")" href="/pricing">Hosting</a></li>
                    <li class="nav-item"><a class="nav-link @Nav("/vps")" href="/vps">VPS</a></li>
                    <li class="nav-item"><a class="nav-link @Nav("/domains")" href="/domains">Domains</a></li>
                    <li class="nav-item"><a class="nav-link @Nav("/features")" href="/features">Features</a></li>
                    <li class="nav-item"><a class="nav-link @Nav("/blog")" href="/blog">Blog</a></li>
                    <li class="nav-item"><a class="nav-link @Nav("/kb")" href="/kb">Help</a></li>
                    <li class="nav-item"><a class="nav-link @Nav("/contact")" href="/contact">Contact</a></li>
                </ul>
                <div class="d-flex gap-2 mt-3 mt-lg-0">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Dashboard/Index" class="btn btn-sm btn-cta">My Dashboard</a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-sm btn-outline-cta">Login</a>
                        <a href="/register" class="btn btn-sm btn-cta">@fs.HeroCtaPrimaryText</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="pubmain">
        @RenderBody()
    </main>

    <footer class="pubfooter">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <a href="/" class="footer-brand">
                        @if (!string.IsNullOrEmpty(fs.LogoPath))
                        {
                            <img src="@fs.LogoPath" alt="@companyName" style="max-height:34px;max-width:200px;" />
                        }
                        else
                        {
                            @companyName
                        }
                    </a>
                    <p class="text-secondary mt-2" style="max-width:280px;">@fs.Tagline</p>
                    <div class="d-flex gap-2 mt-3">
                        @if (!string.IsNullOrEmpty(fs.SocialFacebook)) { <a class="social-ico" href="@fs.SocialFacebook"><i class="bi bi-facebook"></i></a> }
                        @if (!string.IsNullOrEmpty(fs.SocialTwitter)) { <a class="social-ico" href="@fs.SocialTwitter"><i class="bi bi-twitter-x"></i></a> }
                        @if (!string.IsNullOrEmpty(fs.SocialInstagram)) { <a class="social-ico" href="@fs.SocialInstagram"><i class="bi bi-instagram"></i></a> }
                        @if (!string.IsNullOrEmpty(fs.SocialLinkedin)) { <a class="social-ico" href="@fs.SocialLinkedin"><i class="bi bi-linkedin"></i></a> }
                        @if (!string.IsNullOrEmpty(fs.SocialGithub)) { <a class="social-ico" href="@fs.SocialGithub"><i class="bi bi-github"></i></a> }
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <h6>Products</h6>
                    <a href="/pricing">Shared Hosting</a>
                    <a href="/vps">VPS Hosting</a>
                    <a href="/domains">Domains</a>
                    <a href="/features">Features</a>
                </div>
                <div class="col-6 col-lg-2">
                    <h6>Company</h6>
                    <a href="/about">About</a>
                    <a href="/blog">Blog</a>
                    <a href="/contact">Contact</a>
                </div>
                <div class="col-6 col-lg-2">
                    <h6>Support</h6>
                    <a href="/kb">Knowledge Base</a>
                    <a href="/contact">Contact Us</a>
                    <a href="/Account/Login">Client Login</a>
                </div>
                <div class="col-6 col-lg-2">
                    <h6>Legal</h6>
                    <a href="/kb">Terms</a>
                    <a href="/kb">Privacy</a>
                    @if (site.DeveloperDocsPublic || isAdmin)
                    {
                        <a href="/docs">Docs</a>
                    }
                    @if (site.ShowGithubLink)
                    {
                        <a href="@site.ProjectUrl" target="_blank" rel="noopener">GitHub</a>
                    }
                </div>
            </div>
            <hr class="border-secondary mt-4" />
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <span class="text-secondary small">
                    © @year @companyName. All rights reserved.
                    @if (fs.ShowPoweredBy || site.ShowPoweredBy)
                    {
                        <span class="ms-1">· Powered by <a href="@site.ProjectUrl" target="_blank" rel="noopener" class="text-secondary">@site.ProjectName</a></span>
                    }
                </span>
                <form method="post" action="/lang" class="d-flex align-items-center gap-2">
                    <i class="bi bi-translate text-secondary"></i>
                    <select name="lang" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()">
                        <option value="en" selected="@(lang == "en")">English</option>
                        <option value="az" selected="@(lang == "az")">Azərbaycan</option>
                        <option value="tr" selected="@(lang == "tr")">Türkçe</option>
                        <option value="ar" selected="@(lang == "ar")">العربية</option>
                    </select>
                </form>
            </div>
        </div>
    </footer>

    <div class="cookie-bar d-none" id="cookieBar">
        <div class="container d-flex flex-column flex-md-row align-items-center gap-3">
            <span class="small text-secondary flex-grow-1">@fs.CookieConsentText</span>
            <button class="btn btn-sm btn-cta" onclick="document.getElementById('cookieBar').remove(); localStorage.setItem('srx_cookie_ok','1');">Accept</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(fs.LiveChatCode))
    {
        @Html.Raw(fs.LiveChatCode)
    }
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function () {
        var nav = document.getElementById('pubnav');
        function onScroll() { if (window.scrollY > 30) nav.classList.add('solid'); else nav.classList.remove('solid'); }
        if (nav) { window.addEventListener('scroll', onScroll); onScroll(); }
        if (!localStorage.getItem('srx_cookie_ok')) { var cb = document.getElementById('cookieBar'); if (cb) cb.classList.remove('d-none'); }
    })();
</script>
@if (!string.IsNullOrWhiteSpace(fs.CustomJs))
{
    @Html.Raw($"<script>{fs.CustomJs}</script>")
}
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
