@page
@model SRXPanel.Pages.Ssl.IndexModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "SSL Certificates";
}

@functions {
    (string cls, string label) ExpiryBadge(SslCertificate c)
    {
        if (c.Status == SslCertStatus.Expired || c.DaysUntilExpiry < 0)
            return ("srx-badge-suspended", "Expired");
        if (c.DaysUntilExpiry <= 30)
            return ("text-bg-warning", $"{c.DaysUntilExpiry} days left");
        return ("srx-badge-active", $"{c.DaysUntilExpiry} days left");
    }
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">SSL Certificates</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">SSL Certificates</h4>
    <div class="d-flex gap-2">
        <a asp-page="/Ssl/Upload" class="btn btn-outline-secondary"><i class="bi bi-upload"></i> Upload Custom</a>
        <a asp-page="/Ssl/Issue" class="btn btn-primary"><i class="bi bi-shield-plus"></i> Issue Certificate</a>
    </div>
</div>

<div class="card srx-card">
    <div class="card-body">
        @if (Model.Certificates.Any())
        {
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Domain</th>
                        @if (Model.ShowOwner)
                        {
                            <th>Owner</th>
                        }
                        <th>Type</th>
                        <th>Issued</th>
                        <th>Expires</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Certificates)
                    {
                        var badge = ExpiryBadge(c);
                        <tr>
                            <td><i class="bi bi-shield-lock text-success me-1"></i>@(c.Domain?.DomainName ?? "-")</td>
                            @if (Model.ShowOwner)
                            {
                                <td>@(c.User?.UserName ?? "-")</td>
                            }
                            <td><span class="badge text-bg-secondary">@c.Type</span></td>
                            <td>@c.IssuedAt.ToString("yyyy-MM-dd")</td>
                            <td>@c.ExpiresAt.ToString("yyyy-MM-dd")</td>
                            <td><span class="badge @badge.cls">@badge.label</span></td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <form method="post" asp-page-handler="Renew" asp-route-id="@c.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-primary" title="Renew"><i class="bi bi-arrow-clockwise"></i></button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id" class="d-inline srx-confirm-form" data-confirm-message="Remove SSL certificate for '@c.Domain?.DomainName'?">
                                        <button type="submit" class="btn btn-outline-danger" title="Remove"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No SSL certificates yet.</p>
        }
    </div>
</div>
