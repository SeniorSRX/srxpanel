@page
@model SRXPanel.Pages.Ssl.UploadModel
@{
    ViewData["Title"] = "Upload SSL Certificate";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-page="/Ssl/Index">SSL Certificates</a></li>
            <li class="breadcrumb-item active" aria-current="page">Upload</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">Upload Custom Certificate</h4>

<div class="card srx-card" style="max-width: 720px;">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <form method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.DomainId" class="form-label"></label>
                    <select asp-for="Input.DomainId" asp-items="Model.DomainOptions" class="form-select">
                        <option value="">-- Select domain --</option>
                    </select>
                    <span asp-validation-for="Input.DomainId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.ExpiresAt" class="form-label"></label>
                    <input asp-for="Input.ExpiresAt" type="date" class="form-control" />
                </div>
                <div class="col-md-12">
                    <label asp-for="Input.CertificatePem" class="form-label"></label>
                    <textarea asp-for="Input.CertificatePem" class="form-control font-monospace" rows="6" placeholder="-----BEGIN CERTIFICATE-----"></textarea>
                    <span asp-validation-for="Input.CertificatePem" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="Input.PrivateKeyPem" class="form-label"></label>
                    <textarea asp-for="Input.PrivateKeyPem" class="form-control font-monospace" rows="6" placeholder="-----BEGIN PRIVATE KEY-----"></textarea>
                    <span asp-validation-for="Input.PrivateKeyPem" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-upload"></i> Upload Certificate</button>
                <a asp-page="/Ssl/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
