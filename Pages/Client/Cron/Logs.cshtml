@page "/Client/Cron/Logs/{id:int}"
@model SRXPanel.Pages.Client.Cron.LogsModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Cron Execution Log";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Client/Cron/Index">Cron Jobs</a></li>
        <li class="breadcrumb-item active" aria-current="page">Execution Log</li>
    </ol></nav>
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h4 class="text-light mb-1">Execution log</h4>
        <code class="text-light">@Model.Job.Command</code>
        <div class="text-secondary small">
            <code>@Model.Job.Schedule</code> — @Model.ScheduleDescription
        </div>
    </div>
    <div class="d-flex gap-2">
        <form method="post" asp-page-handler="RunNow">
            <button class="btn btn-primary btn-sm" @(Model.Job.IsRunning ? "disabled" : "")>
                <i class="bi bi-play-fill"></i> Run now
            </button>
        </form>
        <a asp-page="/Client/Cron/Index" asp-route-editId="@Model.Job.Id" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil"></i> Edit
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card srx-card h-100"><div class="card-body">
        <div class="text-secondary small">Status</div>
        <div class="fs-5">
            @switch (Model.Job.State)
            {
                case CronJobState.Running: <span class="badge text-bg-info">Running</span> break;
                case CronJobState.Disabled: <span class="badge text-bg-secondary">Disabled</span> break;
                case CronJobState.Error: <span class="badge text-bg-danger">Error</span> break;
                default: <span class="badge text-bg-success">Active</span> break;
            }
        </div>
    </div></div></div>
    <div class="col-md-3"><div class="card srx-card h-100"><div class="card-body">
        <div class="text-secondary small">Last run</div>
        <div class="text-light">@(Model.Job.LastRunAt?.ToString("MMM dd, HH:mm") ?? "Never")</div>
    </div></div></div>
    <div class="col-md-3"><div class="card srx-card h-100"><div class="card-body">
        <div class="text-secondary small">Next run</div>
        <div class="text-light">@(Model.Job.IsActive ? Model.Job.NextRunAt?.ToString("MMM dd, HH:mm") ?? "—" : "Disabled")</div>
    </div></div></div>
    <div class="col-md-3"><div class="card srx-card h-100"><div class="card-body">
        <div class="text-secondary small">Last exit code</div>
        <div class="fs-5 @(Model.Job.LastExitCode == 0 ? "text-success" : Model.Job.LastExitCode == null ? "text-secondary" : "text-danger")">
            @(Model.Job.LastExitCode?.ToString() ?? "—")
        </div>
    </div></div></div>
</div>

@if (!Model.Logs.Any())
{
    <div class="card srx-card"><div class="card-body text-center py-5">
        <i class="bi bi-list-ul text-secondary" style="font-size:40px;"></i>
        <h6 class="text-light mt-3">This job has not run yet</h6>
        <p class="text-secondary mb-0">The scheduler checks for due jobs every minute. Use “Run now” to trigger it immediately.</p>
    </div></div>
}
else
{
    <div class="card srx-card"><div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Started</th>
                    <th>Trigger</th>
                    <th>Duration</th>
                    <th>Exit code</th>
                    <th>Output</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs)
                {
                    var truncated = log.Output.Length > 90 ? log.Output[..90].Replace("\n", " ") + "…" : log.Output.Replace("\n", " ");
                    <tr>
                        <td class="text-light small">@log.StartedAt.ToString("MMM dd, HH:mm:ss")</td>
                        <td>
                            <span class="badge @(log.Manual ? "text-bg-primary" : "text-bg-secondary")">
                                @(log.Manual ? "Manual" : "Scheduled")
                            </span>
                        </td>
                        <td class="text-secondary small">
                            @(log.CompletedAt == null ? "running…" : $"{log.DurationMs} ms")
                        </td>
                        <td>
                            @if (log.CompletedAt == null)
                            {
                                <span class="spinner-border spinner-border-sm text-info"></span>
                            }
                            else
                            {
                                <span class="badge @(log.ExitCode == 0 ? "text-bg-success" : "text-bg-danger")">@log.ExitCode</span>
                            }
                        </td>
                        <td class="text-secondary small font-monospace">@truncated</td>
                        <td class="text-end">
                            @if (!string.IsNullOrEmpty(log.Output))
                            {
                                <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal"
                                        data-bs-target="#outputModal" data-log-id="@log.Id">
                                    <i class="bi bi-arrows-fullscreen"></i> Full output
                                </button>
                                <template id="output-@log.Id">@log.Output</template>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div></div>

    @if (Model.Logs.Any(l => l.CompletedAt == null))
    {
        <div class="text-secondary small mt-2">
            <span class="spinner-border spinner-border-sm"></span> A run is in progress — this page refreshes in 5 seconds.
        </div>
    }
}

<div class="modal fade" id="outputModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title text-light"><i class="bi bi-terminal"></i> Command output</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre class="bg-black p-3 rounded small mb-0" style="max-height:60vh;overflow:auto;"><code id="modalOutput"></code></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var modal = document.getElementById('outputModal');
            modal.addEventListener('show.bs.modal', function (event) {
                var id = event.relatedTarget.dataset.logId;
                var source = document.getElementById('output-' + id);
                // Read the parsed fragment's text so HTML-encoded output comes back verbatim.
                document.getElementById('modalOutput').textContent = source ? source.content.textContent : '';
            });

            @if (Model.Logs.Any(l => l.CompletedAt == null))
            {
                <text>setTimeout(function () { window.location.reload(); }, 5000);</text>
            }
        })();
    </script>
}
