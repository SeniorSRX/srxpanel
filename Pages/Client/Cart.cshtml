@page
@model SRXPanel.Pages.Client.CartModel
@{
    ViewData["Title"] = "Cart";
    string Money(decimal d) => $"${d:0.00}";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item">Store</li>
        <li class="breadcrumb-item active" aria-current="page">Cart</li>
    </ol></nav>
}

<h4 class="text-light mb-4">Shopping Cart</h4>

@if (!Model.Items.Any())
{
    <div class="card srx-card"><div class="card-body text-center py-5">
        <i class="bi bi-cart3 text-secondary" style="font-size:48px;"></i>
        <h5 class="text-light mt-3">Your cart is empty</h5>
        <a href="/Client/Store" class="btn btn-primary mt-2"><i class="bi bi-cart-plus"></i> Browse Hosting</a>
    </div></div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card srx-card"><div class="card-body">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Item</th><th>Qty</th><th class="text-end">Price</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="text-light">@item.Label
                                <span class="badge text-bg-secondary ms-1">@item.Type</span>
                            </td>
                            <td>@item.Quantity</td>
                            <td class="text-end text-light">@Money(item.LineTotal)</td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="Remove"><input type="hidden" name="cartItemId" value="@item.Id" />
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div></div>
        </div>

        <div class="col-lg-4">
            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3">Order Summary</h6>
                <form method="post" asp-page-handler="ApplyCoupon" class="mb-3">
                    <div class="input-group input-group-sm">
                        <input name="CouponCode" value="@Model.CouponCode" class="form-control" placeholder="Promo code" />
                        <button class="btn btn-outline-secondary">Apply</button>
                    </div>
                </form>
                <div class="d-flex justify-content-between text-secondary"><span>Subtotal</span><span>@Money(Model.Subtotal)</span></div>
                @if (Model.AppliedCoupon != null)
                {
                    <div class="d-flex justify-content-between text-success"><span>Discount (@Model.AppliedCoupon.DiscountPercent%)</span><span>-@Money(Model.Subtotal - (Model.Total - Model.Tax))</span></div>
                }
                <div class="d-flex justify-content-between text-secondary"><span>Tax</span><span>@Money(Model.Tax)</span></div>
                <hr class="border-secondary" />
                <div class="d-flex justify-content-between text-light fw-bold fs-5"><span>Total</span><span>@Money(Model.Total)</span></div>

                @if (!Model.HasCard)
                {
                    <div class="alert alert-warning small mt-3 mb-2 py-2"><i class="bi bi-info-circle"></i> No saved card. In production you'd add one at checkout; in this environment the payment is simulated.</div>
                }
                <form method="post" asp-page-handler="Checkout" class="mt-3">
                    <input type="hidden" name="CouponCode" value="@Model.CouponCode" />
                    <button class="btn btn-primary w-100"><i class="bi bi-credit-card"></i> Checkout &amp; Pay</button>
                </form>
                <a href="/Client/Store" class="btn btn-link btn-sm w-100 mt-1 text-secondary">Continue shopping</a>
            </div></div>
        </div>
    </div>
}
