@page
@model SRXPanel.Pages.Client.InvoicesModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Invoices";
    string Money(decimal d, string c) => SRXPanel.Services.Billing.BillingService.FormatMoney(d, c);
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item">Store</li>
        <li class="breadcrumb-item active" aria-current="page">Invoices</li>
    </ol></nav>
}

<h4 class="text-light mb-4">Invoices</h4>

<div class="card srx-card"><div class="card-body">
    @if (!Model.Invoices.Any())
    {
        <p class="text-secondary text-center py-4 mb-0">No invoices yet.</p>
    }
    else
    {
        <table class="table align-middle mb-0">
            <thead><tr><th>Invoice</th><th>Date</th><th>Due</th><th class="text-end">Amount</th><th>Status</th><th></th></tr></thead>
            <tbody>
            @foreach (var inv in Model.Invoices)
            {
                <tr>
                    <td class="text-light">@inv.Number</td>
                    <td class="text-secondary small">@inv.CreatedAt.ToString("MMM d, yyyy")</td>
                    <td class="text-secondary small">@inv.DueDate.ToString("MMM d, yyyy")</td>
                    <td class="text-end text-light">@Money(inv.Amount, inv.Currency)</td>
                    <td>
                        @if (inv.Status == InvoiceStatus.Paid)
                        {
                            <span class="badge text-bg-success">Paid</span>
                        }
                        else if (Model.IsOverdue(inv))
                        {
                            <span class="badge text-bg-danger">Overdue</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">Unpaid</span>
                        }
                    </td>
                    <td class="text-end text-nowrap">
                        <a href="/Client/Invoices/Pdf/@inv.Id" target="_blank" class="btn btn-sm btn-outline-secondary"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
                        @if (inv.Status == InvoiceStatus.Unpaid)
                        {
                            <form method="post" asp-page-handler="Pay" class="d-inline" onsubmit="return confirm('Pay this invoice now?');">
                                <input type="hidden" name="invoiceId" value="@inv.Id" />
                                <button class="btn btn-sm btn-primary"><i class="bi bi-credit-card"></i> Pay</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div></div>
