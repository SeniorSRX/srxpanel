@page
@model SRXPanel.Pages.Client.Developer.SshModel
@{
    ViewData["Title"] = "SSH Access";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item">Developer</li>
        <li class="breadcrumb-item active" aria-current="page">SSH</li>
    </ol></nav>
}

<h4 class="text-light mb-3">SSH Access</h4>

@if (Model.GeneratedPrivateKey != null)
{
    <div class="card srx-card border-warning mb-4"><div class="card-body">
        <h6 class="text-warning mb-2"><i class="bi bi-key-fill"></i> Your private key — shown once</h6>
        <p class="text-secondary small mb-2">
            SRXPanel does not store this key. Download it now and keep it safe; anyone holding it can sign in as you.
            The matching public key (<code>@Model.GeneratedFingerprint</code>) has already been added below.
        </p>
        <pre class="bg-black p-3 rounded small mb-3" style="max-height:220px;overflow:auto;"><code id="privateKey">@Model.GeneratedPrivateKey</code></pre>
        <button class="btn btn-warning btn-sm" onclick="downloadKey()">
            <i class="bi bi-download"></i> Download id_rsa
        </button>
        <button class="btn btn-outline-secondary btn-sm" onclick="copyText(document.getElementById('privateKey').textContent, this)">
            <i class="bi bi-clipboard"></i> Copy
        </button>
    </div></div>
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card srx-card mb-4"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-hdd-network"></i> Connection details</h6>

            <table class="table table-sm align-middle mb-3">
                <tbody>
                    <tr>
                        <td class="text-secondary" style="width:90px;">Host</td>
                        <td class="text-light font-monospace">@Model.Host</td>
                        <td class="text-end"><button class="btn btn-sm btn-outline-secondary" onclick="copyText('@Model.Host', this)"><i class="bi bi-clipboard"></i></button></td>
                    </tr>
                    <tr>
                        <td class="text-secondary">Port</td>
                        <td class="text-light font-monospace">@Model.Access.Port</td>
                        <td class="text-end"><button class="btn btn-sm btn-outline-secondary" onclick="copyText('@Model.Access.Port', this)"><i class="bi bi-clipboard"></i></button></td>
                    </tr>
                    <tr>
                        <td class="text-secondary">Username</td>
                        <td class="text-light font-monospace">@Model.Username</td>
                        <td class="text-end"><button class="btn btn-sm btn-outline-secondary" onclick="copyText('@Model.Username', this)"><i class="bi bi-clipboard"></i></button></td>
                    </tr>
                </tbody>
            </table>

            @{ var sshCommand = $"ssh {Model.Username}@{Model.Host} -p {Model.Access.Port}"; }
            <div class="input-group input-group-sm mb-3">
                <span class="input-group-text">Command</span>
                <input class="form-control font-monospace" readonly value="@sshCommand" id="sshCmd" />
                <button class="btn btn-outline-secondary" onclick="copyText(document.getElementById('sshCmd').value, this)">
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>

            <hr class="border-secondary" />

            <form method="post" asp-page-handler="ToggleAccess">
                <input type="hidden" name="enable" value="@((!Model.Access.IsEnabled).ToString().ToLowerInvariant())" />
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-light">SSH access</div>
                        <div class="text-secondary small">
                            @(Model.Access.IsEnabled ? "Enabled — your keys can sign in." : "Disabled — no shell access.")
                        </div>
                    </div>
                    <button class="btn btn-sm @(Model.Access.IsEnabled ? "btn-outline-danger" : "btn-success")">
                        @(Model.Access.IsEnabled ? "Disable" : "Enable")
                    </button>
                </div>
            </form>

            @if (Model.Access.IsEnabled)
            {
                <form method="post" asp-page-handler="PasswordAuth" class="mt-3">
                    <input type="hidden" name="allow" value="@((!Model.Access.AllowPasswordAuth).ToString().ToLowerInvariant())" />
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-light">Password authentication</div>
                            <div class="text-secondary small">
                                @(Model.Access.AllowPasswordAuth ? "Allowed — less secure." : "Keys only (recommended).")
                            </div>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary">
                            @(Model.Access.AllowPasswordAuth ? "Require keys" : "Allow passwords")
                        </button>
                    </div>
                </form>
            }
        </div></div>

        <div class="card srx-card"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-clock-history"></i> Recent connections</h6>
            @if (!Model.AccessLog.Any())
            {
                <p class="text-secondary small mb-0">No SSH connections recorded yet.</p>
            }
            else
            {
                <table class="table table-sm mb-0">
                    <tbody>
                        @foreach (var entry in Model.AccessLog)
                        {
                            <tr>
                                <td>
                                    <i class="bi @(entry.Success ? "bi-check-circle text-success" : "bi-x-circle text-danger")"></i>
                                </td>
                                <td class="font-monospace small text-light">@entry.IpAddress</td>
                                <td class="text-secondary small">@entry.ConnectedAt.ToString("MMM dd, HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div></div>
    </div>

    <div class="col-lg-7">
        <div class="card srx-card mb-4"><div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="text-light mb-0"><i class="bi bi-key"></i> SSH keys (@Model.Keys.Count)</h6>
                <div>
                    <button class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#addKeyForm">
                        <i class="bi bi-plus-lg"></i> Add key
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#genKeyForm">
                        <i class="bi bi-magic"></i> Generate
                    </button>
                </div>
            </div>

            <div class="collapse mb-3" id="addKeyForm">
                <form method="post" asp-page-handler="AddKey" class="border border-secondary rounded p-3">
                    <div class="mb-2">
                        <label class="form-label small">Public key</label>
                        <textarea name="publicKey" rows="3" class="form-control font-monospace small" required
                                  placeholder="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... you@laptop"></textarea>
                        <div class="form-text">Paste the contents of your <code>.pub</code> file. Never paste a private key.</div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Label</label>
                        <input name="label" class="form-control form-control-sm" placeholder="My MacBook" required />
                    </div>
                    <button class="btn btn-primary btn-sm"><i class="bi bi-check-lg"></i> Add key</button>
                </form>
            </div>

            <div class="collapse mb-3" id="genKeyForm">
                <form method="post" asp-page-handler="Generate" class="border border-secondary rounded p-3">
                    <p class="text-secondary small">
                        SRXPanel generates the pair on the server, adds the public half to your account and hands you the
                        private key once. For ED25519, generate locally instead:
                        <code>ssh-keygen -t ed25519 -C "you@@example.com"</code> and paste the <code>.pub</code> above.
                    </p>
                    <div class="row g-2">
                        <div class="col-md-7">
                            <label class="form-label small">Label</label>
                            <input name="label" class="form-control form-control-sm" placeholder="Generated key" required />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label small">Key size</label>
                            <select name="bits" class="form-select form-select-sm">
                                <option value="4096" selected>RSA 4096 (recommended)</option>
                                <option value="3072">RSA 3072</option>
                                <option value="2048">RSA 2048</option>
                            </select>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary btn-sm mt-3"><i class="bi bi-magic"></i> Generate key pair</button>
                </form>
            </div>

            @if (!Model.Keys.Any())
            {
                <div class="text-center py-4">
                    <i class="bi bi-key text-secondary" style="font-size:36px;"></i>
                    <p class="text-secondary mt-2 mb-0">No keys yet. Add one to sign in without a password.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead><tr><th>Label</th><th>Type</th><th>Fingerprint</th><th>Last used</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var key in Model.Keys)
                            {
                                <tr>
                                    <td class="text-light">@key.Label</td>
                                    <td><span class="badge text-bg-secondary">@key.KeyType</span></td>
                                    <td class="font-monospace small text-secondary" style="word-break:break-all;">@key.Fingerprint</td>
                                    <td class="text-secondary small">@(key.LastUsedAt?.ToString("MMM dd") ?? "never")</td>
                                    <td class="text-end">
                                        <form method="post" asp-page-handler="RemoveKey"
                                              onsubmit="return confirm('Remove @key.Label? Any machine using this key loses access.');">
                                            <input type="hidden" name="keyId" value="@key.Id" />
                                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div></div>
    </div>
</div>

@section Scripts {
    <script>
        function copyText(text, btn) {
            navigator.clipboard.writeText(text).then(function () {
                var original = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-check-lg"></i>';
                setTimeout(function () { btn.innerHTML = original; }, 1200);
            });
        }

        function downloadKey() {
            var key = document.getElementById('privateKey').textContent;
            var blob = new Blob([key], { type: 'application/x-pem-file' });
            var link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = 'id_rsa';
            link.click();
            URL.revokeObjectURL(link.href);
        }
    </script>
}
