@page "/Client/Developer/GitRepo/{id:int}"
@model SRXPanel.Pages.Client.Developer.GitRepoModel
@using SRXPanel.Models
@{
    ViewData["Title"] = Model.Repo.ShortName;
    var live = Model.Live;
    var streaming = live != null && live.Status is GitDeployStatus.Pending or GitDeployStatus.Running;
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Client/Developer/Git">Git Deployment</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Repo.ShortName</li>
    </ol></nav>
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h4 class="text-light mb-1"><i class="bi bi-git accent"></i> @Model.Repo.ShortName</h4>
        <div class="text-secondary small font-monospace">@Model.Repo.RepoUrl</div>
    </div>
    <form method="post" asp-page-handler="Deploy">
        <button class="btn btn-primary btn-sm" @(Model.Repo.Status == GitRepoStatus.Deploying ? "disabled" : "")>
            <i class="bi bi-rocket-takeoff"></i> Deploy now
        </button>
    </form>
</div>

@if (live != null)
{
    <div class="card srx-card mb-4"><div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="text-light mb-0">
                <i class="bi bi-terminal"></i> Deployment #@live.Id
                <span class="badge text-bg-secondary">@live.TriggerType</span>
            </h6>
            <span id="liveStatus" class="badge @(live.Status switch {
                GitDeployStatus.Success => "text-bg-success",
                GitDeployStatus.Failed => "text-bg-danger",
                _ => "text-bg-info" })">@live.Status</span>
        </div>
        <pre class="ansi-log bg-black p-3 rounded small mb-0" style="max-height:340px;overflow:auto;" id="liveLog"></pre>
        <template id="liveSeed">@live.Output</template>
    </div></div>
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card srx-card mb-4"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-link-45deg"></i> Webhook</h6>

            <p class="text-secondary small">
                Add this URL to your repository so every push to
                <span class="badge text-bg-secondary">@Model.Repo.Branch</span> deploys automatically.
            </p>

            <div class="input-group input-group-sm mb-3">
                <input class="form-control font-monospace" readonly value="@Model.WebhookUrl" id="hookUrl" />
                <button class="btn btn-outline-secondary" onclick="copyText(document.getElementById('hookUrl').value, this)">
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>

            <div class="text-center mb-3">
                <div id="qrcode" class="d-inline-block bg-white p-2 rounded"></div>
            </div>

            <ul class="nav nav-tabs nav-fill mb-2" role="tablist">
                <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#gh" type="button">GitHub</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#gl" type="button">GitLab</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#bb" type="button">Bitbucket</button></li>
            </ul>
            <div class="tab-content small text-secondary">
                <div class="tab-pane fade show active" id="gh">
                    <ol class="ps-3 mb-0">
                        <li>Repository → <strong>Settings</strong> → <strong>Webhooks</strong> → Add webhook</li>
                        <li>Paste the URL above into <strong>Payload URL</strong></li>
                        <li>Content type: <code>application/json</code></li>
                        <li>Trigger: <strong>Just the push event</strong></li>
                    </ol>
                </div>
                <div class="tab-pane fade" id="gl">
                    <ol class="ps-3 mb-0">
                        <li>Project → <strong>Settings</strong> → <strong>Webhooks</strong></li>
                        <li>Paste the URL above into <strong>URL</strong></li>
                        <li>Trigger: <strong>Push events</strong>, branch <code>@Model.Repo.Branch</code></li>
                        <li>Save changes, then use <strong>Test → Push events</strong></li>
                    </ol>
                </div>
                <div class="tab-pane fade" id="bb">
                    <ol class="ps-3 mb-0">
                        <li>Repository → <strong>Settings</strong> → <strong>Webhooks</strong> → Add webhook</li>
                        <li>Paste the URL above into <strong>URL</strong></li>
                        <li>Trigger: <strong>Repository push</strong></li>
                    </ol>
                </div>
            </div>

            <form method="post" asp-page-handler="RegenerateSecret" class="mt-3"
                  onsubmit="return confirm('Regenerate the secret? The old webhook URL stops working immediately.');">
                <button class="btn btn-sm btn-outline-warning w-100">
                    <i class="bi bi-arrow-clockwise"></i> Regenerate webhook secret
                </button>
            </form>
        </div></div>
    </div>

    <div class="col-lg-7">
        <div class="card srx-card mb-4"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-sliders"></i> Settings</h6>
            <form method="post" asp-page-handler="Update">
                <div class="mb-3">
                    <label class="form-label">Branch</label>
                    <input name="branch" value="@Model.Repo.Branch" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Post-deploy commands</label>
                    <textarea name="postDeployCommands" rows="4" class="form-control font-monospace small">@Model.Repo.PostDeployCommands</textarea>
                    <div class="form-text">One per line, run in the deploy path after each pull.</div>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" name="autoDeploy" value="true" id="autoDeploy" checked="@Model.Repo.AutoDeploy" />
                    <input type="hidden" name="autoDeploy" value="false" />
                    <label class="form-check-label" for="autoDeploy">Auto-deploy when the webhook fires</label>
                </div>
                <button class="btn btn-primary btn-sm"><i class="bi bi-check-lg"></i> Save settings</button>
            </form>
        </div></div>

        <div class="card srx-card"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-clock-history"></i> Deployment history</h6>

            @if (!Model.Deployments.Any())
            {
                <p class="text-secondary small mb-0">Nothing deployed yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                        <thead><tr><th>When</th><th>Commit</th><th>Trigger</th><th>Duration</th><th>Status</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var deployment in Model.Deployments)
                            {
                                <tr>
                                    <td class="text-secondary small">@deployment.StartedAt.ToString("MMM dd, HH:mm")</td>
                                    <td>
                                        @if (deployment.CommitHash != null)
                                        {
                                            <code class="text-light">@deployment.CommitHash[..Math.Min(7, deployment.CommitHash.Length)]</code>
                                            <div class="text-secondary small text-truncate" style="max-width:220px;">@deployment.CommitMessage</div>
                                        }
                                        else
                                        {
                                            <span class="text-secondary">—</span>
                                        }
                                    </td>
                                    <td><span class="badge text-bg-secondary">@deployment.TriggerType</span></td>
                                    <td class="text-secondary small">
                                        @(deployment.Duration is TimeSpan d ? $"{d.TotalSeconds:0.0}s" : "—")
                                    </td>
                                    <td>
                                        <span class="badge @(deployment.Status switch {
                                            GitDeployStatus.Success => "text-bg-success",
                                            GitDeployStatus.Failed => "text-bg-danger",
                                            _ => "text-bg-info" })">@deployment.Status</span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal"
                                                data-bs-target="#logModal" data-deployment="@deployment.Id">
                                            <i class="bi bi-terminal"></i>
                                        </button>
                                        <template id="log-@deployment.Id">@deployment.Output</template>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div></div>
    </div>
</div>

<div class="modal fade" id="logModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title text-light"><i class="bi bi-terminal"></i> Deployment log</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre class="ansi-log bg-black p-3 rounded small mb-0" style="max-height:60vh;overflow:auto;" id="modalLog"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@@1.0.0/qrcode.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        function copyText(text, btn) {
            navigator.clipboard.writeText(text).then(function () {
                var original = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-check-lg"></i>';
                setTimeout(function () { btn.innerHTML = original; }, 1200);
            });
        }

        // Minimal ANSI SGR renderer: colours + bold, everything else stripped.
        var ANSI_COLORS = {
            30: '#6e7681', 31: '#ff7b72', 32: '#3fb950', 33: '#d29922', 34: '#58a6ff',
            35: '#bc8cff', 36: '#39c5cf', 37: '#c9d1d9', 90: '#6e7681', 91: '#ffa198',
            92: '#56d364', 93: '#e3b341', 94: '#79c0ff', 95: '#d2a8ff', 96: '#56d4dd', 97: '#f0f6fc'
        };

        function escapeHtml(s) {
            return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        function ansiToHtml(text) {
            var out = '', open = 0;
            var pattern = /\x1b\[([0-9;]*)m/g;
            var index = 0, match;

            while ((match = pattern.exec(text)) !== null) {
                out += escapeHtml(text.slice(index, match.index));
                index = pattern.lastIndex;

                match[1].split(';').forEach(function (raw) {
                    var code = parseInt(raw || '0', 10);
                    if (code === 0) { while (open > 0) { out += '</span>'; open--; } }
                    else if (code === 1) { out += '<span style="font-weight:600">'; open++; }
                    else if (ANSI_COLORS[code]) { out += '<span style="color:' + ANSI_COLORS[code] + '">'; open++; }
                });
            }
            out += escapeHtml(text.slice(index));
            while (open > 0) { out += '</span>'; open--; }
            return out;
        }

        // Deployment history modal.
        var logModal = document.getElementById('logModal');
        logModal.addEventListener('show.bs.modal', function (event) {
            var id = event.relatedTarget.dataset.deployment;
            var source = document.getElementById('log-' + id);
            document.getElementById('modalLog').innerHTML = source ? ansiToHtml(source.content.textContent) : '';
        });

        // Webhook QR code.
        new QRCode(document.getElementById('qrcode'), {
            text: document.getElementById('hookUrl').value,
            width: 148, height: 148, correctLevel: QRCode.CorrectLevel.M
        });

        @if (live != null)
        {
            <text>
            (function () {
                var deploymentId = @live.Id;
                var logEl = document.getElementById('liveLog');
                var statusEl = document.getElementById('liveStatus');
                var buffer = document.getElementById('liveSeed').content.textContent;

                function render() {
                    logEl.innerHTML = ansiToHtml(buffer);
                    logEl.scrollTop = logEl.scrollHeight;
                }
                render();

                var streaming = @(streaming ? "true" : "false");
                if (!streaming) return;

                function finish(success) {
                    statusEl.className = 'badge ' + (success ? 'text-bg-success' : 'text-bg-danger');
                    statusEl.textContent = success ? 'Success' : 'Failed';
                }

                if (window.signalR) {
                    var conn = new signalR.HubConnectionBuilder().withUrl('/hubs/devtools').build();
                    conn.on('deployOutput', function (line) { buffer += line + '\n'; render(); });
                    conn.on('deployCompleted', function (success) { finish(success); });
                    conn.start()
                        .then(function () { return conn.invoke('JoinDeployment', deploymentId); })
                        .catch(poll);
                } else {
                    poll();
                }

                // Fallback when WebSockets are unavailable.
                function poll() {
                    var timer = setInterval(function () {
                        fetch('?handler=Status&deploymentId=' + deploymentId)
                            .then(function (r) { return r.json(); })
                            .then(function (d) {
                                buffer = d.output || '';
                                render();
                                if (d.status === 'Success' || d.status === 'Failed') {
                                    clearInterval(timer);
                                    finish(d.status === 'Success');
                                }
                            })
                            .catch(function () { clearInterval(timer); });
                    }, 1200);
                }
            })();
            </text>
        }
    </script>
}
