@page "/Client/Apps/Progress/{jobId:int}"
@model SRXPanel.Pages.Client.Apps.ProgressModel
@using SRXPanel.Models
@{
    var j = Model.Job;
    ViewData["Title"] = $"{j.Type} {j.AppName}";
    var done = j.Status is AppJobStatus.Success or AppJobStatus.Failed;
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Client/Apps/Index">Applications</a></li>
        <li class="breadcrumb-item active" aria-current="page">@j.Type</li>
    </ol></nav>
}

<h4 class="text-light mb-4">@j.Type — @j.AppName</h4>

<div class="card srx-card mb-4" style="max-width:820px;"><div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="text-light" id="stepLabel">@j.CurrentStep</span>
        <span class="text-secondary" id="pctLabel">@j.Progress%</span>
    </div>
    <div class="progress" style="height:22px;">
        <div class="progress-bar @(j.Status == AppJobStatus.Failed ? "bg-danger" : "progress-bar-striped progress-bar-animated")"
             id="bar" style="width:@(j.Progress)%">@j.Progress%</div>
    </div>

    <div class="d-flex justify-content-between mt-3 flex-wrap gap-2" id="stepDots">
        @{ var stages = new[] { "Download", "Extract", "Configure", "Database Setup", "Finalize" }; }
        @foreach (var s in stages)
        {
            <span class="badge text-bg-secondary stage" data-stage="@s">@s</span>
        }
    </div>
</div></div>

<div class="card srx-card mb-4" style="max-width:820px;"><div class="card-body">
    <h6 class="text-light mb-2"><i class="bi bi-terminal"></i> Live log</h6>
    <pre class="bg-black p-3 rounded small mb-0" style="max-height:260px;overflow:auto;" id="log"><code>@j.Log</code></pre>
</div></div>

<div id="successBox" class="@(j.Status == AppJobStatus.Success && Model.Installation != null ? "" : "d-none")" style="max-width:820px;">
    <div class="card srx-card border-success"><div class="card-body">
        <h5 class="text-light"><i class="bi bi-check-circle-fill text-success"></i> All done!</h5>
        @if (Model.Installation is AppInstallation inst)
        {
            <table class="table table-sm align-middle mt-3 mb-3">
                <tbody>
                    <tr><td class="text-secondary">Site URL</td><td><a href="@inst.SiteUrl" target="_blank" class="accent">@inst.SiteUrl</a></td></tr>
                    <tr><td class="text-secondary">Admin URL</td><td><a href="@inst.AdminUrl" target="_blank" class="accent">@inst.AdminUrl</a></td></tr>
                    <tr><td class="text-secondary">Admin username</td><td class="text-light">@inst.AdminUser</td></tr>
                    <tr><td class="text-secondary">Password</td><td class="text-secondary">the password you chose during setup</td></tr>
                </tbody>
            </table>
            <div class="d-flex gap-2">
                <a href="@inst.SiteUrl" target="_blank" class="btn btn-primary btn-sm"><i class="bi bi-box-arrow-up-right"></i> Visit Site</a>
                <a href="@inst.AdminUrl" target="_blank" class="btn btn-outline-secondary btn-sm"><i class="bi bi-speedometer2"></i> Admin Panel</a>
                <a href="/Client/Apps/Manage/@inst.Id" class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear"></i> Manage</a>
            </div>
        }
        else
        {
            <p class="text-secondary mb-2">The operation completed successfully.</p>
            <a href="/Client/Apps" class="btn btn-primary btn-sm">Back to My Applications</a>
        }
    </div></div>
</div>

<div id="failBox" class="@(j.Status == AppJobStatus.Failed ? "" : "d-none")" style="max-width:820px;">
    <div class="alert alert-danger"><i class="bi bi-x-octagon"></i> The operation failed. Review the log above, then try again or contact support.
        <a href="/Client/Apps" class="alert-link">Back to My Applications</a>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        (function () {
            var jobId = @j.Id;
            var finished = @(done ? "true" : "false");
            var bar = document.getElementById('bar'),
                pct = document.getElementById('pctLabel'),
                stepLabel = document.getElementById('stepLabel'),
                log = document.getElementById('log');

            function render(p, step, logText) {
                bar.style.width = p + '%'; bar.textContent = p + '%';
                pct.textContent = p + '%';
                if (step) {
                    stepLabel.textContent = step;
                    document.querySelectorAll('.stage').forEach(function (el) {
                        if (el.dataset.stage === step) el.className = 'badge text-bg-primary stage';
                    });
                }
                if (logText != null) { log.innerHTML = '<code></code>'; log.firstChild.textContent = logText; log.scrollTop = log.scrollHeight; }
            }
            function complete(success, installationId) {
                finished = true;
                bar.classList.remove('progress-bar-striped', 'progress-bar-animated');
                if (success) {
                    bar.classList.add('bg-success');
                    // Reload so the success panel renders with the installation details.
                    setTimeout(function () { window.location.reload(); }, 700);
                } else {
                    bar.classList.add('bg-danger');
                    document.getElementById('failBox').classList.remove('d-none');
                }
            }

            // Preferred: SignalR live updates.
            if (window.signalR && !finished) {
                var conn = new signalR.HubConnectionBuilder().withUrl("/hubs/install").build();
                conn.on("progress", function (p, step, line) {
                    render(p, step, (log.textContent ? log.textContent + "\n" : "") + line);
                });
                conn.on("completed", function (success) { complete(success); });
                conn.start().then(function () { conn.invoke("JoinJob", jobId); }).catch(function () { poll(); });
            } else if (!finished) {
                poll();
            }

            // Fallback: poll the job status endpoint.
            function poll() {
                var timer = setInterval(function () {
                    fetch('?handler=Status&jobId=' + jobId)
                        .then(function (r) { return r.json(); })
                        .then(function (d) {
                            render(d.progress, d.step, d.log);
                            if (d.status === 'Success' || d.status === 'Failed') {
                                clearInterval(timer);
                                complete(d.status === 'Success', d.installationId);
                            }
                        }).catch(function () { clearInterval(timer); });
                }, 1200);
            }
        })();
    </script>
}
