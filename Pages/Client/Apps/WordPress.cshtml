@page "/Client/Apps/WordPress/{id:int}"
@model SRXPanel.Pages.Client.Apps.WordPressModel
@using SRXPanel.Models
@using SRXPanel.Services.Apps
@{
    var i = Model.Installation;
    var h = Model.Health;
    ViewData["Title"] = "WordPress Manager";
    string TabCls(string t) => Model.Tab == t ? "nav-link active" : "nav-link";
    string ScoreColor(int s) => s >= 80 ? "#3fb950" : s >= 55 ? "#d29922" : "#f85149";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Client/Apps/Index">Applications</a></li>
        <li class="breadcrumb-item"><a href="/Client/Apps/Manage/@i.Id">@i.SiteTitle</a></li>
        <li class="breadcrumb-item active" aria-current="page">WordPress Manager</li>
    </ol></nav>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="text-light mb-0"><i class="bi bi-wordpress accent"></i> WordPress Manager</h4>
    <a href="@i.AdminUrl" target="_blank" class="btn btn-outline-secondary btn-sm"><i class="bi bi-speedometer2"></i> wp-admin</a>
</div>

<ul class="nav nav-pills mb-4">
    <li class="nav-item"><a class="@TabCls("dashboard")" href="/Client/Apps/WordPress/@i.Id?tab=dashboard">Dashboard</a></li>
    <li class="nav-item"><a class="@TabCls("plugins")" href="/Client/Apps/WordPress/@i.Id?tab=plugins">Plugins</a></li>
    <li class="nav-item"><a class="@TabCls("themes")" href="/Client/Apps/WordPress/@i.Id?tab=themes">Themes</a></li>
    <li class="nav-item"><a class="@TabCls("settings")" href="/Client/Apps/WordPress/@i.Id?tab=settings">Settings</a></li>
</ul>

@if (Model.Tab == "dashboard")
{
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card srx-card text-center"><div class="card-body">
                <h6 class="text-secondary text-uppercase small">Site health</h6>
                <div style="font-size:46px;font-weight:800;color:@ScoreColor(h.Score);">@h.Score</div>
                <div class="text-secondary">out of 100</div>
            </div></div>
        </div>
        <div class="col-lg-8">
            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3">Overview</h6>
                <div class="row g-3">
                    <div class="col-6 col-md-3"><div class="text-secondary small">WordPress</div><div class="text-light">@h.WpVersion @(h.CoreUpToDate ? Html.Raw("<span class='badge text-bg-success'>latest</span>") : Html.Raw("<span class='badge text-bg-warning'>update</span>"))</div></div>
                    <div class="col-6 col-md-3"><div class="text-secondary small">PHP</div><div class="text-light">@h.PhpVersion @(h.PhpOk ? Html.Raw("<span class='badge text-bg-success'>ok</span>") : Html.Raw("<span class='badge text-bg-warning'>old</span>"))</div></div>
                    <div class="col-6 col-md-3"><div class="text-secondary small">Active theme</div><div class="text-light">@h.ActiveTheme</div></div>
                    <div class="col-6 col-md-3"><div class="text-secondary small">Plugins</div><div class="text-light">@h.PluginsActive active / @h.PluginsInactive inactive</div></div>
                </div>
                <hr class="border-secondary" />
                <h6 class="text-light mb-2">Recommendations</h6>
                @foreach (var r in h.Recommendations)
                {
                    <div class="text-secondary small py-1"><i class="bi bi-arrow-right-short accent"></i> @r</div>
                }
            </div></div>
        </div>
    </div>
}
else if (Model.Tab is "plugins" or "themes")
{
    var isPlugin = Model.Tab == "plugins";
    var assets = isPlugin ? Model.Plugins : Model.Themes;
    var type = isPlugin ? WpAssetType.Plugin : WpAssetType.Theme;

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card srx-card"><div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-light mb-0">Installed @(isPlugin ? "plugins" : "themes")</h6>
                    @if (isPlugin)
                    {
                        <form method="post" asp-page-handler="UpdateAll"><input type="hidden" name="id" value="@i.Id" />
                            <button class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-repeat"></i> Update all</button></form>
                    }
                </div>
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>Name</th><th>Version</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                    @if (!assets.Any())
                    {
                        <tr><td colspan="4" class="text-secondary text-center py-3">None installed.</td></tr>
                    }
                    @foreach (var a in assets)
                    {
                        <tr>
                            <td class="text-light small">@a.Name<div class="text-secondary font-monospace" style="font-size:11px;">@a.Slug</div></td>
                            <td class="small">@a.Version @if (a.UpdateAvailable) { <span class="badge text-bg-warning">@a.LatestVersion</span> }</td>
                            <td>@(a.IsActive ? Html.Raw("<span class='badge text-bg-success'>Active</span>") : Html.Raw("<span class='badge text-bg-secondary'>Inactive</span>"))</td>
                            <td class="text-end text-nowrap">
                                @if (a.UpdateAvailable)
                                {
                                    <form method="post" asp-page-handler="UpdateAsset" class="d-inline"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="assetId" value="@a.Id" /><input type="hidden" name="tab" value="@Model.Tab" />
                                        <button class="btn btn-sm btn-outline-warning py-0" title="Update"><i class="bi bi-arrow-up-circle"></i></button></form>
                                }
                                @if (isPlugin)
                                {
                                    <form method="post" asp-page-handler="Toggle" class="d-inline"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="assetId" value="@a.Id" /><input type="hidden" name="active" value="@((!a.IsActive).ToString().ToLower())" />
                                        <button class="btn btn-sm btn-outline-secondary py-0">@(a.IsActive ? "Deactivate" : "Activate")</button></form>
                                }
                                else if (!a.IsActive)
                                {
                                    <form method="post" asp-page-handler="ActivateTheme" class="d-inline"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="assetId" value="@a.Id" />
                                        <button class="btn btn-sm btn-outline-secondary py-0">Activate</button></form>
                                }
                                @if (!a.IsActive)
                                {
                                    <form method="post" asp-page-handler="DeleteAsset" class="d-inline" onsubmit="return confirm('Delete @a.Name?');"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="assetId" value="@a.Id" /><input type="hidden" name="tab" value="@Model.Tab" />
                                        <button class="btn btn-sm btn-outline-danger py-0"><i class="bi bi-trash"></i></button></form>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div></div>
        </div>

        <div class="col-lg-5">
            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3"><i class="bi bi-search"></i> Install from WordPress.org</h6>
                <form method="get" class="input-group input-group-sm mb-3">
                    <input type="hidden" name="tab" value="@Model.Tab" />
                    <input name="q" value="@Model.Q" class="form-control" placeholder="Search @Model.Tab…" />
                    <button class="btn btn-outline-secondary">Search</button>
                </form>
                @foreach (var r in Model.RepoResults)
                {
                    <div class="d-flex justify-content-between align-items-start py-2 border-bottom border-secondary">
                        <div class="small">
                            <div class="text-light">@r.Name <span class="text-secondary">v@r.Version</span></div>
                            <div class="text-secondary">@r.Description</div>
                            <div class="text-secondary" style="font-size:11px;"><i class="bi bi-download"></i> @r.Downloads.ToString("N0")</div>
                        </div>
                        <form method="post" asp-page-handler="Install" class="text-nowrap">
                            <input type="hidden" name="id" value="@i.Id" />
                            <input type="hidden" name="type" value="@type" />
                            <input type="hidden" name="slug" value="@r.Slug" />
                            <input type="hidden" name="activate" value="@(isPlugin ? "true" : "false")" />
                            <button class="btn btn-sm btn-primary py-0"><i class="bi bi-plus-lg"></i> Install</button>
                        </form>
                    </div>
                }
            </div></div>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card srx-card mb-4"><div class="card-body">
                <h6 class="text-light mb-3"><i class="bi bi-terminal"></i> WP-CLI commands</h6>
                <div class="d-grid gap-2">
                    <form method="post" asp-page-handler="Cli"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="command" value="@WpCliCommand.FlushCache" />
                        <button class="btn btn-outline-secondary btn-sm w-100 text-start"><i class="bi bi-arrow-clockwise"></i> Flush cache</button></form>
                    <form method="post" asp-page-handler="Cli"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="command" value="@WpCliCommand.RegenerateThumbnails" />
                        <button class="btn btn-outline-secondary btn-sm w-100 text-start"><i class="bi bi-images"></i> Regenerate thumbnails</button></form>
                    <form method="post" asp-page-handler="Cli"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="command" value="@WpCliCommand.ExportDatabase" />
                        <button class="btn btn-outline-secondary btn-sm w-100 text-start"><i class="bi bi-box-arrow-down"></i> Export database</button></form>
                    <form method="post" asp-page-handler="Cli"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="command" value="@WpCliCommand.ImportDatabase" />
                        <button class="btn btn-outline-secondary btn-sm w-100 text-start"><i class="bi bi-box-arrow-in-up"></i> Import database</button></form>
                </div>
                <form method="post" asp-page-handler="Cli" class="mt-3">
                    <input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="command" value="@WpCliCommand.SearchReplaceUrl" />
                    <label class="form-label small">Search-replace site URL</label>
                    <div class="input-group input-group-sm">
                        <input name="argument" class="form-control" placeholder="https://new-url.com" />
                        <button class="btn btn-outline-secondary">Replace</button>
                    </div>
                    <div class="form-text">Rewrites every occurrence of <code>@i.SiteUrl</code> in the database.</div>
                </form>
            </div></div>
        </div>

        <div class="col-lg-6">
            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3"><i class="bi bi-toggles"></i> Configuration flags</h6>
                @{
                    var flags = new (string Key, string Label, string Help)[]
                    {
                        ("https", "Force HTTPS in wp-config", "Sets FORCE_SSL_ADMIN so the admin area always uses HTTPS."),
                        ("debug", "Debug mode", "Enables WP_DEBUG. Leave off on production sites."),
                        ("multisite", "Multisite", "Sets WP_ALLOW_MULTISITE to enable the network setup screen.")
                    };
                }
                @foreach (var f in flags)
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
                        <div>
                            <div class="text-light small">@f.Label</div>
                            <div class="text-secondary" style="font-size:12px;">@f.Help</div>
                        </div>
                        <div class="d-flex gap-1">
                            <form method="post" asp-page-handler="Flag"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="flag" value="@f.Key" /><input type="hidden" name="value" value="true" />
                                <button class="btn btn-sm btn-outline-success py-0">On</button></form>
                            <form method="post" asp-page-handler="Flag"><input type="hidden" name="id" value="@i.Id" /><input type="hidden" name="flag" value="@f.Key" /><input type="hidden" name="value" value="false" />
                                <button class="btn btn-sm btn-outline-secondary py-0">Off</button></form>
                        </div>
                    </div>
                }
                <p class="text-secondary small mt-3 mb-0">Changing the WordPress admin URL is available via the security plugin of your choice; the panel exposes only the safe WP-CLI subset above.</p>
            </div></div>
        </div>
    </div>
}
