@page "/Client/Apps/Install/{appId:int}"
@model SRXPanel.Pages.Client.Apps.InstallModel
@{
    var a = Model.App;
    ViewData["Title"] = $"Install {a.Name}";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Client/Apps/Index">Applications</a></li>
        <li class="breadcrumb-item"><a asp-page="/Client/Apps/Catalog">Catalog</a></li>
        <li class="breadcrumb-item active" aria-current="page">Install @a.Name</li>
    </ol></nav>
}

<div class="d-flex align-items-center gap-3 mb-4">
    <i class="bi @a.IconPath accent" style="font-size:40px;"></i>
    <div>
        <h4 class="text-light mb-0">Install @a.Name</h4>
        <span class="text-secondary small">v@a.Version · needs @a.MinDiskMB MB · PHP @a.MinPhpVersion+</span>
    </div>
</div>

@if (!Model.Domains.Any())
{
    <div class="alert alert-info">You need at least one domain before installing an application. <a href="/Client/Domains" class="alert-link">Add a domain</a>.</div>
}
else
{
    <!-- Step indicator -->
    <div class="d-flex justify-content-between align-items-center mb-4" style="max-width:640px;">
        @{ var steps = new[] { "Domain & Path", "Configure", "Review & Install" }; }
        @for (var i = 0; i < steps.Length; i++)
        {
            <div class="text-center flex-fill step-ind" data-step="@(i + 1)">
                <div class="mx-auto d-flex align-items-center justify-content-center step-dot" style="width:36px;height:36px;border-radius:50%;background:#161b22;border:1px solid #30363d;color:#8b949e;font-weight:700;">@(i + 1)</div>
                <div class="small mt-1 text-secondary step-lbl">@steps[i]</div>
            </div>
            @if (i < steps.Length - 1)
            {
                <div class="flex-fill" style="height:2px;background:#30363d;margin-top:-18px;"></div>
            }
        }
    </div>

    <form method="post" id="installForm" style="max-width:820px;">
        <input type="hidden" asp-for="Input.AppId" />
        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

        <!-- Step 1 -->
        <div class="wiz-step" data-step="1">
            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3"><i class="bi bi-globe2"></i> Choose domain and path</h6>
                <div class="mb-3">
                    <label class="form-label">Domain</label>
                    <select asp-for="Input.DomainId" class="form-select" id="domainSel">
                        @foreach (var d in Model.Domains)
                        {
                            <option value="@d.Id" data-name="@d.DomainName">@d.DomainName</option>
                        }
                    </select>
                </div>
                <div class="mb-2">
                    <label class="form-label">Installation path</label>
                    <div class="input-group">
                        <span class="input-group-text" id="urlPrefix">https://</span>
                        <input asp-for="Input.Path" class="form-control" placeholder="/" id="pathInput" />
                    </div>
                    <div class="form-text">Use <code>/</code> for the domain root, or e.g. <code>/blog</code>, <code>/shop</code>.</div>
                </div>

                <div class="alert @(Model.EnoughDisk ? "alert-secondary" : "alert-danger") small mt-3 mb-0">
                    <i class="bi bi-hdd"></i>
                    @if (Model.EnoughDisk)
                    {
                        <text>Disk check passed — @a.MinDiskMB MB required, @(Model.FreeDiskMB > 1_000_000 ? "unlimited" : Model.FreeDiskMB + " MB") available.</text>
                    }
                    else
                    {
                        <text>Not enough disk space: @a.MinDiskMB MB required, only @Model.FreeDiskMB MB free.</text>
                    }
                </div>
                <div class="alert alert-warning small mt-2 mb-0 d-none" id="pathWarn">
                    <i class="bi bi-exclamation-triangle"></i> The target directory may not be empty. Existing files could be overwritten.
                </div>
            </div></div>
            <div class="d-flex justify-content-end mt-3">
                <button type="button" class="btn btn-primary" data-next="2" @(Model.EnoughDisk ? "" : "disabled")>Continue <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <!-- Step 2 -->
        <div class="wiz-step d-none" data-step="2">
            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3"><i class="bi bi-sliders"></i> Configure your site</h6>
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">Site title</label><input asp-for="Input.SiteTitle" class="form-control" /></div>
                    <div class="col-md-6"><label class="form-label">Language</label>
                        <select asp-for="Input.Language" class="form-select">
                            @foreach (var l in SRXPanel.Pages.Client.Apps.InstallModel.Languages)
                            {
                                <option value="@l.Code">@l.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4"><label class="form-label">Admin username</label><input asp-for="Input.AdminUser" class="form-control" /></div>
                    <div class="col-md-4">
                        <label class="form-label">Admin password</label>
                        <input asp-for="Input.AdminPass" type="password" class="form-control" id="pwInput" />
                        <div class="progress mt-1" style="height:5px;"><div class="progress-bar bg-danger" id="pwBar" style="width:0%"></div></div>
                        <div class="form-text" id="pwText">At least 8 characters.</div>
                    </div>
                    <div class="col-md-4"><label class="form-label">Admin email</label><input asp-for="Input.AdminEmail" class="form-control" /></div>

                    @if (a.RequiresDatabase)
                    {
                        <div class="col-md-6"><label class="form-label">Database name</label><input asp-for="Input.DbName" class="form-control font-monospace" /></div>
                    }
                </div>

                <div class="mt-3">
                    <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#adv">
                        <i class="bi bi-chevron-down"></i> Advanced options
                    </button>
                    <div class="collapse mt-3" id="adv">
                        <div class="row g-3">
                            <div class="col-md-4"><label class="form-label">Table prefix</label><input asp-for="Input.TablePrefix" class="form-control font-monospace" /></div>
                            <div class="col-md-4"><label class="form-label">PHP version</label>
                                <select asp-for="Input.PhpVersion" class="form-select">
                                    @foreach (var v in SRXPanel.Pages.Client.Apps.InstallModel.PhpVersions)
                                    {
                                        <option value="@v">PHP @v</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check form-switch"><input class="form-check-input" asp-for="Input.DebugMode" /><label class="form-check-label">Debug mode</label></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div></div>
            <div class="d-flex justify-content-between mt-3">
                <button type="button" class="btn btn-outline-secondary" data-prev="1"><i class="bi bi-arrow-left"></i> Back</button>
                <button type="button" class="btn btn-primary" data-next="3">Continue <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <!-- Step 3 -->
        <div class="wiz-step d-none" data-step="3">
            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3"><i class="bi bi-check2-circle"></i> Review and install</h6>
                <table class="table table-sm align-middle mb-0">
                    <tbody>
                        <tr><td class="text-secondary">Application</td><td class="text-light">@a.Name v@a.Version</td></tr>
                        <tr><td class="text-secondary">Site URL</td><td class="text-light" id="revUrl">—</td></tr>
                        <tr><td class="text-secondary">Site title</td><td class="text-light" id="revTitle">—</td></tr>
                        <tr><td class="text-secondary">Admin user</td><td class="text-light" id="revAdmin">—</td></tr>
                        @if (a.RequiresDatabase)
                        {
                            <tr><td class="text-secondary">Database</td><td class="text-light" id="revDb">—</td></tr>
                        }
                        <tr><td class="text-secondary">PHP</td><td class="text-light" id="revPhp">—</td></tr>
                        <tr><td class="text-secondary">Estimated time</td><td class="text-light">~30 seconds</td></tr>
                    </tbody>
                </table>
            </div></div>
            <div class="d-flex justify-content-between mt-3">
                <button type="button" class="btn btn-outline-secondary" data-prev="2"><i class="bi bi-arrow-left"></i> Back</button>
                <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-lightning-charge"></i> Install @a.Name</button>
            </div>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var cur = 1;
            function show(n) {
                cur = n;
                document.querySelectorAll('.wiz-step').forEach(function (s) { s.classList.toggle('d-none', +s.dataset.step !== n); });
                document.querySelectorAll('.step-ind').forEach(function (ind) {
                    var i = +ind.dataset.step, dot = ind.querySelector('.step-dot'), lbl = ind.querySelector('.step-lbl');
                    if (i <= n) { dot.style.background = 'var(--srx-sidebar-active, #3b82f6)'; dot.style.color = '#fff'; lbl.classList.replace('text-secondary','text-light'); }
                    else { dot.style.background = '#161b22'; dot.style.color = '#8b949e'; lbl.classList.replace('text-light','text-secondary'); }
                });
                if (n === 3) review();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
            function siteUrl() {
                var sel = document.getElementById('domainSel');
                var name = sel.options[sel.selectedIndex].dataset.name;
                var p = (document.getElementById('pathInput').value || '/').trim();
                if (p === '/' || p === '') return 'https://' + name;
                return 'https://' + name + '/' + p.replace(/^\/+|\/+$/g, '');
            }
            function review() {
                document.getElementById('revUrl').textContent = siteUrl();
                document.getElementById('revTitle').textContent = document.getElementById('Input_SiteTitle').value;
                document.getElementById('revAdmin').textContent = document.getElementById('Input_AdminUser').value;
                var db = document.getElementById('Input_DbName'); if (db) document.getElementById('revDb').textContent = db.value;
                document.getElementById('revPhp').textContent = 'PHP ' + document.getElementById('Input_PhpVersion').value;
            }
            document.querySelectorAll('[data-next]').forEach(function (b) {
                b.addEventListener('click', function () {
                    if (cur === 2) {
                        var req = ['Input_SiteTitle','Input_AdminUser','Input_AdminPass','Input_AdminEmail'];
                        for (var i = 0; i < req.length; i++) { var el = document.getElementById(req[i]); if (el && !el.value) { el.reportValidity(); return; } }
                    }
                    show(+b.dataset.next);
                });
            });
            document.querySelectorAll('[data-prev]').forEach(function (b) { b.addEventListener('click', function () { show(+b.dataset.prev); }); });

            // Path warning + URL preview
            var pathInput = document.getElementById('pathInput');
            if (pathInput) pathInput.addEventListener('input', function () {
                var v = (this.value || '/').trim();
                document.getElementById('pathWarn').classList.toggle('d-none', v === '/' || v === '');
            });

            // Password strength meter
            var pw = document.getElementById('pwInput');
            if (pw) pw.addEventListener('input', function () {
                var v = this.value, s = 0;
                if (v.length >= 8) s++; if (v.length >= 12) s++;
                if (/[A-Z]/.test(v) && /[a-z]/.test(v)) s++;
                if (/[0-9]/.test(v)) s++; if (/[^A-Za-z0-9]/.test(v)) s++;
                var pct = Math.min(100, s * 20);
                var bar = document.getElementById('pwBar');
                bar.style.width = pct + '%';
                bar.className = 'progress-bar ' + (pct < 40 ? 'bg-danger' : pct < 80 ? 'bg-warning' : 'bg-success');
                document.getElementById('pwText').textContent = pct < 40 ? 'Weak password' : pct < 80 ? 'Reasonable password' : 'Strong password';
            });
            show(1);
        })();
    </script>
}
