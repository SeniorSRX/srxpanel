@page
@model SRXPanel.Pages.Client.Apps.CatalogModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "App Catalog";
    string CatLabel(AppCategory c) => c switch
    {
        AppCategory.ECommerce => "E-Commerce",
        AppCategory.ProjectManagement => "Project Management",
        _ => c.ToString()
    };
    string Stars(double r) => new string('★', (int)Math.Round(r)) + new string('☆', 5 - (int)Math.Round(r));
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Client/Apps/Index">Applications</a></li>
        <li class="breadcrumb-item active" aria-current="page">Catalog</li>
    </ol></nav>
}

<h4 class="text-light mb-1">App Catalog</h4>
<p class="text-secondary">Install popular web applications on your domains with a single click.</p>

<form method="get" class="mb-4">
    <div class="row g-2" style="max-width:560px;">
        <div class="col-md-8"><input name="search" value="@Model.Search" class="form-control" placeholder="Search apps…" /></div>
        <div class="col-md-4"><button class="btn btn-outline-secondary w-100"><i class="bi bi-search"></i> Search</button></div>
    </div>
    <div class="d-flex flex-wrap gap-1 mt-3">
        <a href="/Client/Apps/Catalog" class="btn btn-sm @(Model.Category == null ? "btn-primary" : "btn-outline-secondary")">All</a>
        @foreach (var c in Enum.GetValues<AppCategory>())
        {
            <a href="/Client/Apps/Catalog?category=@c" class="btn btn-sm @(Model.Category == c ? "btn-primary" : "btn-outline-secondary")">@CatLabel(c)</a>
        }
    </div>
</form>

@if (!Model.Apps.Any())
{
    <p class="text-secondary">No applications match your search.</p>
}
else
{
    <div class="row g-3">
        @foreach (var a in Model.Apps)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card srx-card h-100"><div class="card-body d-flex flex-column">
                    <div class="d-flex gap-3 mb-2">
                        <i class="bi @a.IconPath accent" style="font-size:34px;"></i>
                        <div>
                            <h6 class="text-light mb-0">@a.Name</h6>
                            <div class="text-secondary small">v@a.Version · @CatLabel(a.Category)</div>
                        </div>
                    </div>
                    <p class="text-secondary small flex-grow-1">@a.Description</p>
                    <div class="d-flex justify-content-between align-items-center text-secondary small mb-2">
                        <span title="Curated rating"><span class="text-warning">@Stars(a.Rating)</span> @a.Rating.ToString("0.0")</span>
                        <span><i class="bi bi-hdd"></i> @a.MinDiskMB MB</span>
                        <span><i class="bi bi-download"></i> @a.InstallCount</span>
                    </div>
                    <div class="d-flex gap-1">
                        <a href="/Client/Apps/Detail/@a.Slug" class="btn btn-outline-secondary btn-sm flex-fill">Details</a>
                        <a href="/Client/Apps/Install/@a.Id" class="btn btn-primary btn-sm flex-fill"><i class="bi bi-lightning-charge"></i> Install</a>
                    </div>
                </div></div>
            </div>
        }
    </div>
}
