@page "/Client/Invoices/Pdf/{id:int}"
@using SRXPanel.Services
@model SRXPanel.Pages.Client.InvoicePdfModel
@inject IFrontendService Frontend
@{
    Layout = null;
    var fs = await Frontend.GetSettingsAsync();
    var company = string.IsNullOrWhiteSpace(fs.SiteName) ? "Web Hosting" : fs.SiteName;
    var inv = Model.Invoice;
    string Money(decimal d) => SRXPanel.Services.Billing.BillingService.FormatMoney(d, inv.Currency);
    ViewData["Title"] = $"Invoice {inv.Number}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Invoice @inv.Number</title>
    <style>
        body { font-family: -apple-system, Segoe UI, Roboto, Arial, sans-serif; color:#111; margin:0; padding:40px; }
        .head { display:flex; justify-content:space-between; align-items:flex-start; border-bottom:2px solid #111; padding-bottom:16px; }
        .brand { font-size:24px; font-weight:800; }
        .muted { color:#666; font-size:13px; }
        table { width:100%; border-collapse:collapse; margin-top:24px; }
        th, td { text-align:left; padding:10px; border-bottom:1px solid #ddd; }
        th { background:#f5f5f5; }
        .right { text-align:right; }
        .total { font-size:18px; font-weight:800; }
        .status { display:inline-block; padding:4px 12px; border-radius:999px; font-size:12px; font-weight:700; }
        .paid { background:#d4edda; color:#155724; }
        .unpaid { background:#fff3cd; color:#856404; }
        .btn { display:inline-block; margin-top:24px; padding:8px 16px; background:#111; color:#fff; text-decoration:none; border-radius:6px; }
        @@media print { .btn { display:none; } body { padding:0; } }
    </style>
</head>
<body>
    <div class="head">
        <div>
            <div class="brand">@company</div>
            <div class="muted">Invoice</div>
        </div>
        <div class="right">
            <div><strong>@inv.Number</strong></div>
            <div class="muted">Date: @inv.CreatedAt.ToString("MMM d, yyyy")</div>
            <div class="muted">Due: @inv.DueDate.ToString("MMM d, yyyy")</div>
            <div style="margin-top:6px;">
                <span class="status @(inv.Status == SRXPanel.Models.InvoiceStatus.Paid ? "paid" : "unpaid")">@inv.Status</span>
            </div>
        </div>
    </div>

    <p style="margin-top:24px;"><strong>Billed to:</strong><br />
        @Model.Client.FullName<br />
        <span class="muted">@Model.Client.Email</span>
    </p>

    <table>
        <thead><tr><th>Description</th><th class="right">Amount</th></tr></thead>
        <tbody>
            <tr>
                <td>Invoice @inv.Number</td>
                <td class="right">@Money(inv.Amount)</td>
            </tr>
        </tbody>
        <tfoot>
            <tr><td class="right total">Total</td><td class="right total">@Money(inv.Amount)</td></tr>
        </tfoot>
    </table>

    @if (inv.PaidAt != null)
    {
        <p class="muted">Paid on @inv.PaidAt.Value.ToString("MMM d, yyyy")</p>
    }

    <a href="#" class="btn" onclick="window.print();return false;">Print / Save as PDF</a>
</body>
</html>
