@page
@model SRXPanel.Pages.Client.Security.AntivirusModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Antivirus";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Client/Security/Index">Security</a></li>
        <li class="breadcrumb-item active" aria-current="page">Antivirus</li>
    </ol></nav>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="text-light mb-0">Antivirus (ClamAV)</h4>
    <span class="text-secondary small"><i class="bi bi-shield-check"></i> Definitions updated @Model.DefinitionsDate.ToString("MMM d, yyyy")</span>
</div>

<div class="card srx-card mb-4"><div class="card-body">
    <form method="post" asp-page-handler="Scan" class="row g-2 align-items-end" id="scanForm">
        <div class="col-md-8">
            <label class="form-label text-secondary small">Path to scan (blank = your home directory)</label>
            <input name="path" class="form-control" placeholder="@Model.HomePath" />
        </div>
        <div class="col-md-4">
            <button class="btn btn-primary w-100" id="scanBtn"><i class="bi bi-search"></i> Scan Now</button>
        </div>
    </form>
    <div class="mt-3 d-none" id="progressWrap">
        <div class="progress" style="height:20px;"><div class="progress-bar progress-bar-striped progress-bar-animated" id="scanBar" style="width:0%">0%</div></div>
        <div class="text-secondary small mt-1" id="scanFile"></div>
    </div>
</div></div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card srx-card"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-list-check"></i> Recent scan results</h6>
            <div class="table-responsive" style="max-height:360px;overflow:auto;">
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>File</th><th>Status</th><th>Threat</th><th></th></tr></thead>
                    <tbody>
                    @if (!Model.Recent.Any())
                    {
                        <tr><td colspan="4" class="text-secondary text-center py-3">No scans yet — run one above.</td></tr>
                    }
                    @foreach (var r in Model.Recent)
                    {
                        <tr>
                            <td class="small" style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@r.Path">@r.Path</td>
                            <td>@(r.Status == ScanStatus.Infected ? Html.Raw("<span class='badge text-bg-danger'>Infected</span>") : r.Status == ScanStatus.Clean ? Html.Raw("<span class='badge text-bg-success'>Clean</span>") : Html.Raw("<span class='badge text-bg-secondary'>Error</span>"))</td>
                            <td class="small text-danger">@r.ThreatName</td>
                            <td class="text-end">
                                @if (r.Status == ScanStatus.Infected && r.Action == ScanAction.None)
                                {
                                    <form method="post" asp-page-handler="Quarantine"><input type="hidden" name="path" value="@r.Path" /><input type="hidden" name="threat" value="@r.ThreatName" />
                                        <button class="btn btn-sm btn-outline-warning py-0"><i class="bi bi-shield-lock"></i> Quarantine</button></form>
                                }
                                else if (r.Action == ScanAction.Quarantined)
                                {
                                    <span class="badge text-bg-warning">Quarantined</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div></div>
    </div>

    <div class="col-lg-5">
        <div class="card srx-card"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-shield-lock"></i> Quarantine manager</h6>
            @if (!Model.Quarantine.Any())
            {
                <p class="text-secondary mb-0">Quarantine is empty.</p>
            }
            else
            {
                foreach (var q in Model.Quarantine)
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
                        <div class="small">
                            <div class="text-light" style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@q.OriginalPath">@q.OriginalPath</div>
                            <span class="text-danger">@q.ThreatName</span>
                        </div>
                        <div class="d-flex gap-1">
                            <form method="post" asp-page-handler="Restore"><input type="hidden" name="id" value="@q.Id" /><button class="btn btn-sm btn-outline-secondary py-0" title="Restore"><i class="bi bi-arrow-counterclockwise"></i></button></form>
                            <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Permanently delete this file?');"><input type="hidden" name="id" value="@q.Id" /><button class="btn btn-sm btn-outline-danger py-0" title="Delete"><i class="bi bi-trash"></i></button></form>
                        </div>
                    </div>
                }
            }
        </div></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        (function () {
            var uid = "@Model.UserId";
            if (!window.signalR || !uid) return;
            var conn = new signalR.HubConnectionBuilder().withUrl("/hubs/security").build();
            conn.on("scanProgress", function (pct, file) {
                document.getElementById('progressWrap').classList.remove('d-none');
                var bar = document.getElementById('scanBar');
                bar.style.width = pct + '%'; bar.textContent = pct + '%';
                document.getElementById('scanFile').textContent = 'Scanning: ' + file;
            });
            conn.start().then(function () { conn.invoke("JoinUser", uid); }).catch(function(){});
            document.getElementById('scanForm').addEventListener('submit', function () {
                document.getElementById('progressWrap').classList.remove('d-none');
                document.getElementById('scanBtn').disabled = true;
            });
        })();
    </script>
}
