@page
@model SRXPanel.Pages.Client.StoreModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Order Hosting";
    string Money(decimal d) => $"${d:0.00}";
    string Disk(long mb) => mb >= 1024 ? $"{mb / 1024} GB" : $"{mb} MB";
    string Limit(int n) => n == 0 ? "Unlimited" : n.ToString();
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item">Store</li>
        <li class="breadcrumb-item active" aria-current="page">Order Hosting</li>
    </ol></nav>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="text-light mb-0">Order a New Service</h4>
    <a href="/Client/Store/Addons" class="btn btn-outline-secondary btn-sm"><i class="bi bi-plus-square"></i> Add-ons</a>
</div>

<ul class="nav nav-pills mb-4" role="tablist">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#tab-shared">Shared Hosting</button></li>
    @if (Model.VpsPlans.Any())
    {
        <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-vps">VPS</button></li>
    }
    @if (Model.ResellerPackages.Any())
    {
        <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-reseller">Reseller</button></li>
    }
</ul>

<div class="tab-content">
    <!-- Shared -->
    <div class="tab-pane fade show active" id="tab-shared">
        <div class="row g-4">
            @{ int i = 0; }
            @foreach (var plan in Model.Plans)
            {
                var featured = i == 1; i++;
                <div class="col-lg-4 col-md-6">
                    <div class="card srx-card h-100 @(featured ? "border-primary" : "")"><div class="card-body">
                        @if (featured) { <span class="badge text-bg-primary mb-2">Most Popular</span> }
                        <h5 class="text-light">@plan.Name</h5>
                        <div class="my-2"><span class="fs-3 fw-bold text-light">@Money(plan.Price)</span><span class="text-secondary">/mo</span></div>
                        <div class="text-secondary small py-1"><i class="bi bi-hdd accent"></i> @Disk(plan.DiskQuotaMB) SSD</div>
                        <div class="text-secondary small py-1"><i class="bi bi-arrow-left-right accent"></i> @Disk(plan.BandwidthQuotaMB) bandwidth</div>
                        <div class="text-secondary small py-1"><i class="bi bi-globe2 accent"></i> @Limit(plan.MaxDomains) domain(s)</div>
                        <div class="text-secondary small py-1"><i class="bi bi-envelope accent"></i> @Limit(plan.MaxEmails) email(s)</div>
                        <div class="text-secondary small py-1"><i class="bi bi-database accent"></i> @Limit(plan.MaxDatabases) database(s)</div>
                        <div class="d-grid gap-2 mt-3">
                            <form method="post" asp-page-handler="Order" onsubmit="return @(Model.HasCard ? "confirm('Order this plan now? Your saved card will be charged and the account provisioned immediately.')" : "true");">
                                <input type="hidden" name="planId" value="@plan.Id" />
                                <button class="btn btn-primary w-100"><i class="bi bi-lightning-charge"></i> Order Now</button>
                            </form>
                            <form method="post" asp-page-handler="AddToCart">
                                <input type="hidden" name="type" value="@CartItemType.Plan" />
                                <input type="hidden" name="referenceId" value="@plan.Id" />
                                <input type="hidden" name="label" value="@plan.Name (hosting)" />
                                <input type="hidden" name="price" value="@plan.Price" />
                                <button class="btn btn-outline-secondary btn-sm w-100"><i class="bi bi-cart-plus"></i> Add to Cart</button>
                            </form>
                        </div>
                    </div></div>
                </div>
            }
        </div>
        @if (!Model.HasCard)
        {
            <p class="text-secondary small mt-3"><i class="bi bi-info-circle"></i> You have no saved payment method — "Order Now" takes you to secure checkout.</p>
        }
    </div>

    <!-- VPS -->
    @if (Model.VpsPlans.Any())
    {
        <div class="tab-pane fade" id="tab-vps">
            <div class="row g-4">
                @foreach (var v in Model.VpsPlans)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card srx-card h-100 @(v.IsPopular ? "border-primary" : "")"><div class="card-body">
                            @if (v.IsPopular) { <span class="badge text-bg-primary mb-2">Popular</span> }
                            <h5 class="text-light">@v.Name</h5>
                            <div class="text-secondary small mb-1"><i class="bi bi-geo-alt accent"></i> @v.Location</div>
                            <div class="my-2"><span class="fs-3 fw-bold text-light">@Money(v.Price)</span><span class="text-secondary">/mo</span></div>
                            <div class="text-secondary small py-1"><i class="bi bi-cpu accent"></i> @v.CpuCores vCPU</div>
                            <div class="text-secondary small py-1"><i class="bi bi-memory accent"></i> @(v.RamMB / 1024) GB RAM</div>
                            <div class="text-secondary small py-1"><i class="bi bi-hdd accent"></i> @v.DiskGB GB SSD</div>
                            <form method="post" asp-page-handler="AddToCart" class="mt-3">
                                <input type="hidden" name="type" value="@CartItemType.Vps" />
                                <input type="hidden" name="referenceId" value="@v.Id" />
                                <input type="hidden" name="label" value="@v.Name (VPS)" />
                                <input type="hidden" name="price" value="@v.Price" />
                                <button class="btn btn-primary w-100"><i class="bi bi-cart-plus"></i> Add to Cart</button>
                            </form>
                        </div></div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Reseller -->
    @if (Model.ResellerPackages.Any())
    {
        <div class="tab-pane fade" id="tab-reseller">
            <div class="row g-4">
                @foreach (var r in Model.ResellerPackages)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card srx-card h-100"><div class="card-body">
                            <h5 class="text-light">@r.Name</h5>
                            <p class="text-secondary small">@r.Description</p>
                            <div class="my-2"><span class="fs-3 fw-bold text-light">@Money(r.Price)</span><span class="text-secondary">/mo</span></div>
                            <div class="text-secondary small py-1"><i class="bi bi-hdd accent"></i> @Disk(r.DiskQuotaMB) storage</div>
                            <div class="text-secondary small py-1"><i class="bi bi-globe2 accent"></i> @Limit(r.MaxDomains) domains</div>
                            <form method="post" asp-page-handler="AddToCart" class="mt-3">
                                <input type="hidden" name="type" value="@CartItemType.Reseller" />
                                <input type="hidden" name="referenceId" value="@r.Id" />
                                <input type="hidden" name="label" value="@r.Name (reseller)" />
                                <input type="hidden" name="price" value="@r.Price" />
                                <button class="btn btn-primary w-100"><i class="bi bi-cart-plus"></i> Add to Cart</button>
                            </form>
                        </div></div>
                    </div>
                }
            </div>
        </div>
    }
</div>
