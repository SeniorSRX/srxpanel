@page
@using SRXPanel.Services
@model SRXPanel.Pages.Account.RegisterModel
@inject IFrontendService Frontend
@{
    Layout = null;
    ViewData["Title"] = "Create Account";
    var regFs = await Frontend.GetSettingsAsync();
    var regBrand = string.IsNullOrWhiteSpace(regFs.SiteName) ? "Professional Web Hosting" : regFs.SiteName;
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account - @regBrand</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="background:#0d1117;">
    <div class="d-flex align-items-center justify-content-center" style="min-height:100vh;">
        <div class="card srx-card" style="width:440px;">
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(regFs.LogoPath))
                {
                    <div class="text-center mb-1"><img src="@regFs.LogoPath" alt="@regBrand" style="max-height:40px;max-width:200px;" /></div>
                }
                else
                {
                    <h3 class="text-center mb-1">@regBrand</h3>
                }
                <p class="text-center text-secondary mb-4">Create your hosting account</p>

                <div asp-validation-summary="All" class="alert alert-danger" role="alert" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <form method="post">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div class="mb-3">
                        <label asp-for="Input.FullName" class="form-label"></label>
                        <input asp-for="Input.FullName" class="form-control" />
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>
                    <div class="row g-2">
                        <div class="col-6 mb-3">
                            <label asp-for="Input.UserName" class="form-label">Username</label>
                            <input asp-for="Input.UserName" class="form-control" />
                            <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="Input.Email" class="form-label">Email</label>
                            <input asp-for="Input.Email" class="form-control" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <input asp-for="Input.Password" class="form-control" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Create Account</button>
                </form>
                <p class="text-center text-secondary mt-3 mb-0 small">
                    Already have an account? <a asp-page="/Account/Login">Sign in</a>
                </p>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
