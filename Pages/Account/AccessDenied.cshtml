@page
@{
    ViewData["Title"] = "Access Denied";
    Layout = "_LoginLayout";
}

<div class="srx-login-wrapper">
    <div class="srx-login-card text-center">
        <i class="bi bi-shield-exclamation text-danger" style="font-size: 3rem;"></i>
        <h4 class="mt-3 text-light">Access Denied</h4>
        <p class="text-secondary">You do not have permission to access this resource.</p>
        <a asp-page="/Dashboard/Index" class="btn btn-primary">
            <i class="bi bi-house"></i> Back to Dashboard
        </a>
    </div>
</div>
