@page
@using SRXPanel.Services
@model SRXPanel.Pages.Account.LoginModel
@inject IFrontendService Frontend
@{
    ViewData["Title"] = "Login";
    Layout = "_LoginLayout";
    var loginFs = await Frontend.GetSettingsAsync();
    var loginBrand = string.IsNullOrWhiteSpace(loginFs.SiteName) ? "Professional Web Hosting" : loginFs.SiteName;
}

<div class="srx-login-wrapper">
    <div class="srx-login-card">
        <div class="text-center mb-4">
            @if (!string.IsNullOrEmpty(loginFs.LogoPath))
            {
                <img src="@loginFs.LogoPath" alt="@loginBrand" style="max-height:44px;max-width:220px;" />
            }
            else
            {
                <div class="srx-login-brand">@loginBrand</div>
            }
            <div class="text-secondary small mt-1">Sign in to manage your hosting</div>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="mb-3">
                <label asp-for="Input.UserNameOrEmail" class="form-label">Username or Email</label>
                <input asp-for="Input.UserNameOrEmail" class="form-control" autocomplete="username" autofocus />
                <span asp-validation-for="Input.UserNameOrEmail" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-box-arrow-in-right"></i> Sign In
            </button>
        </form>

        @if (Model.ExternalLogins.Any())
        {
            <div class="d-flex align-items-center my-3 text-secondary small">
                <hr class="flex-grow-1" /><span class="px-2">or</span><hr class="flex-grow-1" />
            </div>
            <form method="post" asp-page-handler="ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl">
                @foreach (var provider in Model.ExternalLogins)
                {
                    <button type="submit" name="provider" value="@provider.Name" class="btn btn-outline-light w-100 d-flex align-items-center justify-content-center gap-2">
                        @if (provider.Name == "Google")
                        {
                            <i class="bi bi-google"></i>
                        }
                        <span>Sign in with @provider.DisplayName</span>
                    </button>
                }
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
