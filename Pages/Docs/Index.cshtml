    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background:#0d1117; color:#c9d1d9; }
        .docs-nav { border-bottom:1px solid #30363d; position:sticky; top:0; background:rgba(13,17,23,.92); backdrop-filter:blur(8px); z-index:100; }
        .docs-wrap { display:grid; grid-template-columns:240px 1fr; gap:40px; max-width:1200px; margin:0 auto; padding:32px 20px 80px; }
        .docs-side { position:sticky; top:80px; align-self:start; height:max-content; }
        .docs-side a { display:block; padding:6px 10px; border-radius:6px; color:#8b949e; text-decoration:none; font-size:14px; }
        .docs-side a:hover { background:#161b22; color:#fff; }
        .docs-side .grp { color:#6e7681; text-transform:uppercase; font-size:11px; letter-spacing:.5px; margin:16px 0 4px 10px; }
        .docs-body h2 { color:#fff; font-weight:700; margin-top:8px; padding-top:12px; scroll-margin-top:80px; }
        .docs-body h3 { color:#e6edf3; font-size:18px; margin-top:24px; }
        .docs-body p, .docs-body li { color:#c9d1d9; }
        .docs-body section { padding:24px 0; border-bottom:1px solid #21262d; }
        .docs-body pre { background:#161b22; border:1px solid #30363d; border-radius:10px; padding:16px; overflow:auto; }
        .docs-body pre code { color:#e6edf3; font-size:13px; }
        .docs-body code { color:#79c0ff; }
        .docs-body table { width:100%; border-collapse:collapse; margin:12px 0; }
        .docs-body th, .docs-body td { border:1px solid #30363d; padding:8px 12px; font-size:14px; text-align:left; }
        .docs-body th { background:#161b22; color:#fff; }
        .callout { background:#161b22; border-left:3px solid #3b82f6; border-radius:6px; padding:12px 16px; margin:14px 0; font-size:14px; }
        @@media (max-width: 800px) { .docs-wrap { grid-template-columns:1fr; } .docs-side { position:static; } }
    </style>
</head>
<body>
    <nav class="docs-nav">
        <div class="container d-flex justify-content-between align-items-center py-3">
            <a href="/" class="text-decoration-none" style="font-size:22px;font-weight:700;color:#fff;">@brand <span class="text-secondary fs-6 fw-normal">Docs</span></a>
            <div class="d-flex gap-2">
                <a href="/" class="btn btn-outline-secondary btn-sm">Home</a>
                <a href="/Account/Login" class="btn btn-primary btn-sm">Sign In</a>
            </div>
        </div>
