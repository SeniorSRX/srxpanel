@page
@using SRXPanel.Services
@model SRXPanel.Pages.Docs.IndexModel
@inject IFrontendService Frontend
@{
    Layout = null;
    ViewData["Title"] = "Documentation";
    var fs = await Frontend.GetSettingsAsync();
    var brand = string.IsNullOrWhiteSpace(fs.SiteName) ? "Documentation" : fs.SiteName;
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
