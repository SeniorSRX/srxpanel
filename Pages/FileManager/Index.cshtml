@page
@model SRXPanel.Pages.FileManager.IndexModel
@{
    ViewData["Title"] = "File Manager";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">File Manager</li>
        </ol>
    </nav>
}

@if (Model.Editing)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="text-light mb-0"><i class="bi bi-pencil-square"></i> Editing <code>@Model.EditFilePath</code></h4>
        <a asp-page="/FileManager/Index" asp-route-path="@Model.Path" class="btn btn-outline-secondary btn-sm">Back to files</a>
    </div>
    <div class="card srx-card">
        <div class="card-body">
            <form method="post" asp-page-handler="SaveFile">
                <input type="hidden" name="file" value="@Model.EditFilePath" />
                <textarea name="content" class="form-control font-monospace" rows="22" spellcheck="false">@Model.EditFileContent</textarea>
                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save</button>
                    <a asp-page="/FileManager/Index" asp-route-path="@Model.Path" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
    return;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="text-light mb-0"><i class="bi bi-folder2-open"></i> File Manager</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#newFolderModal"><i class="bi bi-folder-plus"></i> New Folder</button>
        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#newFileModal"><i class="bi bi-file-earmark-plus"></i> New File</button>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal"><i class="bi bi-upload"></i> Upload</button>
    </div>
</div>

<div class="card srx-card mb-3">
    <div class="card-body py-2">
        <nav aria-label="file breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-page="/FileManager/Index" asp-route-path=""><i class="bi bi-house"></i> home</a>
                </li>
                @{
                    var acc = "";
                }
                @foreach (var seg in Model.Crumbs)
                {
                    acc = string.IsNullOrEmpty(acc) ? seg : $"{acc}/{seg}";
                    <li class="breadcrumb-item"><a asp-page="/FileManager/Index" asp-route-path="@acc">@seg</a></li>
                }
            </ol>
        </nav>
    </div>
</div>

<div class="card srx-card">
    <div class="card-body">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Size</th>
                    <th>Modified</th>
                    <th>Permissions</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!string.IsNullOrEmpty(Model.Path))
                {
                    var parent = Model.Path.Contains('/') ? Model.Path[..Model.Path.LastIndexOf('/')] : "";
                    <tr>
                        <td colspan="5"><a asp-page="/FileManager/Index" asp-route-path="@parent" class="text-secondary"><i class="bi bi-arrow-90deg-up"></i> ..</a></td>
                    </tr>
                }
                @foreach (var e in Model.Entries)
                {
                    <tr>
                        <td>
                            @if (e.IsDirectory)
                            {
                                <a asp-page="/FileManager/Index" asp-route-path="@e.RelativePath" class="text-decoration-none">
                                    <i class="bi bi-folder-fill text-warning me-1"></i>@e.Name
                                </a>
                            }
                            else
                            {
                                <i class="bi bi-file-earmark text-secondary me-1"></i>@e.Name
                            }
                        </td>
                        <td>@(e.IsDirectory ? "—" : FormatSize(e.Size))</td>
                        <td>@e.Modified.ToString("yyyy-MM-dd HH:mm")</td>
                        <td><code class="small">@e.Permissions</code></td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                @if (!e.IsDirectory && Model.HasEditableExtension(e.Name))
                                {
                                    <a asp-page-handler="Edit" asp-route-file="@e.RelativePath" asp-route-path="@Model.Path" class="btn btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                                }
                                @if (!e.IsDirectory)
                                {
                                    <a asp-page-handler="Download" asp-route-file="@e.RelativePath" class="btn btn-outline-secondary" title="Download"><i class="bi bi-download"></i></a>
                                }
                                <button type="button" class="btn btn-outline-secondary" title="Rename"
                                        data-bs-toggle="modal" data-bs-target="#renameModal"
                                        data-target-path="@e.RelativePath" data-current-name="@e.Name"><i class="bi bi-input-cursor-text"></i></button>
                                <form method="post" asp-page-handler="Delete" asp-route-path="@Model.Path" class="d-inline srx-confirm-form" data-confirm-message="Delete '@e.Name'?">
                                    <input type="hidden" name="target" value="@e.RelativePath" />
                                    <button type="submit" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Entries.Any())
                {
                    <tr><td colspan="5" class="text-secondary">This folder is empty.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    static string FormatSize(long bytes)
    {
        string[] units = { "B", "KB", "MB", "GB" };
        double size = bytes;
        int u = 0;
        while (size >= 1024 && u < units.Length - 1) { size /= 1024; u++; }
        return $"{size:0.#} {units[u]}";
    }
}

<!-- New Folder Modal -->
<div class="modal fade" id="newFolderModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="NewFolder" asp-route-path="@Model.Path" class="modal-content">
            <div class="modal-header"><h5 class="modal-title">New Folder</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input name="name" class="form-control" placeholder="Folder name" required />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Create</button>
            </div>
        </form>
    </div>
</div>

<!-- New File Modal -->
<div class="modal fade" id="newFileModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="NewFile" asp-route-path="@Model.Path" class="modal-content">
            <div class="modal-header"><h5 class="modal-title">New File</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input name="name" class="form-control" placeholder="filename.txt" required />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Create</button>
            </div>
        </form>
    </div>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Upload" asp-route-path="@Model.Path" enctype="multipart/form-data" class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Upload File</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input type="file" name="upload" class="form-control" required />
                <div class="form-text">Max 100 MB. Allowed extensions only.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Upload</button>
            </div>
        </form>
    </div>
</div>

<!-- Rename Modal -->
<div class="modal fade" id="renameModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Rename" asp-route-path="@Model.Path" class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Rename</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input type="hidden" name="target" id="renameTarget" />
                <input name="newName" id="renameNewName" class="form-control" required />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Rename</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const renameModal = document.getElementById('renameModal');
        if (renameModal) {
            renameModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                document.getElementById('renameTarget').value = btn.getAttribute('data-target-path');
                document.getElementById('renameNewName').value = btn.getAttribute('data-current-name');
            });
        }
    </script>
}
