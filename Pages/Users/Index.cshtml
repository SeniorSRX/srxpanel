@page
@model SRXPanel.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Users</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">Users</h4>
    <a asp-page="/Users/Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> New User</a>
</div>

<div class="card srx-card">
    <div class="card-body">
        @if (Model.Users.Any())
        {
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Package</th>
                        <th>Domains</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>@u.UserName</td>
                            <td>@u.FullName</td>
                            <td>@u.Email</td>
                            <td><span class="badge text-bg-secondary">@u.Role</span></td>
                            <td>@(u.PackageName ?? "-")</td>
                            <td>@u.DomainCount</td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge srx-badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge srx-badge-suspended">Suspended</span>
                                }
                            </td>
                            <td>@u.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-page="/Users/Edit" asp-route-id="@u.Id" class="btn btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (User.IsInRole(Roles.SuperAdmin))
                                    {
                                        <form method="post" asp-page-handler="Impersonate" asp-route-id="@u.Id" class="d-inline">
                                            <button type="submit" class="btn btn-outline-info" title="Impersonate">
                                                <i class="bi bi-person-bounding-box"></i>
                                            </button>
                                        </form>
                                    }
                                    <form method="post" asp-page-handler="ToggleActive" asp-route-id="@u.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-warning" title="@(u.IsActive ? "Suspend" : "Unsuspend")">
                                            <i class="bi @(u.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@u.Id" class="d-inline srx-confirm-form" data-confirm-message="Delete user '@u.UserName'? This cannot be undone.">
                                        <button type="submit" class="btn btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No users found.</p>
        }
    </div>
</div>
