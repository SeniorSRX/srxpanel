@page
@model SRXPanel.Pages.PricingModel
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Hosting Plans & Pricing";
    ViewData["MetaDescription"] = "Compare our shared hosting, VPS and reseller plans. Start with a 14-day free trial — no credit card required.";
    string Money(decimal d) => $"${d:0.00}";
    string Limit(int n) => n == 0 ? "Unlimited" : n.ToString();
    string Disk(long mb) => mb >= 1024 ? $"{mb / 1024} GB" : $"{mb} MB";
}

<section class="text-center" style="padding:56px 0 24px;">
    <div class="container">
        <h1 class="text-light fw-bold">Simple, transparent pricing</h1>
        <p class="text-secondary fs-5">Choose the plan that fits. Cancel anytime. 14-day free trial, no card required.</p>

        <div class="d-inline-flex gap-2 p-1 mt-2" style="background:#161b22;border:1px solid #30363d;border-radius:999px;">
            <button type="button" class="btn btn-sm btn-cta tabbtn active" data-tab="shared">Shared Hosting</button>
            <button type="button" class="btn btn-sm btn-outline-cta tabbtn" data-tab="vps">VPS</button>
            <button type="button" class="btn btn-sm btn-outline-cta tabbtn" data-tab="reseller">Reseller</button>
        </div>

        <div class="mt-3">
            <div class="d-inline-flex align-items-center gap-2">
                <span class="text-secondary" id="lblMonthly">Monthly</span>
                <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" id="cycleToggle" style="cursor:pointer;"></div>
                <span class="text-secondary" id="lblAnnual">Annual <span class="badge text-bg-success">Save 20%</span></span>
            </div>
        </div>
    </div>
</section>

<div class="container pb-4">
    <!-- Shared hosting -->
    <div class="tabpane" data-pane="shared">
        <div class="row g-4 justify-content-center">
            @{ int i = 0; }
            @foreach (var plan in Model.Plans)
            {
                var featured = i == 1; i++;
                <div class="col-lg-4 col-md-6">
                    <div style="background:#161b22;border:1px solid @(featured ? "var(--srx-primary)" : "#30363d");border-radius:16px;padding:30px;height:100%;@(featured ? "box-shadow:0 0 0 1px var(--srx-primary);" : "")">
                        @if (featured) { <span class="badge text-bg-primary mb-2">Most Popular</span> }
                        <h3 class="text-light">@plan.Name</h3>
                        <p class="text-secondary" style="min-height:44px;">@plan.Description</p>
                        <div class="my-3">
                            <span class="price-m" style="font-size:42px;font-weight:800;color:#fff;">@Money(plan.Price)</span>
                            <span class="price-a d-none" style="font-size:42px;font-weight:800;color:#fff;">@Money(Math.Round(plan.AnnualPrice / 12, 2))</span>
                            <span class="text-secondary">/mo</span>
                            <div class="text-secondary small price-a d-none">Billed @Money(plan.AnnualPrice)/yr</div>
                        </div>
                        <a href="/register?plan=@plan.Id" class="btn @(featured ? "btn-cta" : "btn-outline-cta") w-100 mb-3">Get Started</a>
                        <div class="text-secondary py-1"><i class="bi bi-check-lg accent"></i> @Disk(plan.DiskQuotaMB) SSD storage</div>
                        <div class="text-secondary py-1"><i class="bi bi-check-lg accent"></i> @Disk(plan.BandwidthQuotaMB) bandwidth</div>
                        <div class="text-secondary py-1"><i class="bi bi-check-lg accent"></i> @Limit(plan.MaxDomains) domain(s)</div>
                        <div class="text-secondary py-1"><i class="bi bi-check-lg accent"></i> @Limit(plan.MaxEmails) email account(s)</div>
                        <div class="text-secondary py-1"><i class="bi bi-check-lg accent"></i> @Limit(plan.MaxDatabases) database(s)</div>
                        <div class="text-secondary py-1"><i class="bi bi-check-lg accent"></i> Free SSL certificates</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- VPS -->
    <div class="tabpane d-none" data-pane="vps">
        <div class="row g-4 justify-content-center">
            @foreach (var v in Model.VpsPlans)
            {
                <div class="col-lg-4 col-md-6">
                    <div style="background:#161b22;border:1px solid @(v.IsPopular ? "var(--srx-primary)" : "#30363d");border-radius:16px;padding:30px;height:100%;@(v.IsPopular ? "box-shadow:0 0 0 1px var(--srx-primary);" : "")">
                        @if (v.IsPopular) { <span class="badge text-bg-primary mb-2">Most Popular</span> }
                        <h3 class="text-light">@v.Name</h3>
                        <div class="text-secondary small mb-2"><i class="bi bi-geo-alt"></i> @v.Location</div>
                        <div class="my-3">
                            <span class="price-m" style="font-size:42px;font-weight:800;color:#fff;">@Money(v.Price)</span>
                            <span class="price-a d-none" style="font-size:42px;font-weight:800;color:#fff;">@Money(Math.Round(v.AnnualPrice / 12, 2))</span>
                            <span class="text-secondary">/mo</span>
                        </div>
                        <a href="/vps" class="btn @(v.IsPopular ? "btn-cta" : "btn-outline-cta") w-100 mb-3">Deploy Now</a>
                        <div class="text-secondary py-1"><i class="bi bi-cpu accent"></i> @v.CpuCores vCPU core(s)</div>
                        <div class="text-secondary py-1"><i class="bi bi-memory accent"></i> @(v.RamMB / 1024) GB RAM</div>
                        <div class="text-secondary py-1"><i class="bi bi-hdd accent"></i> @v.DiskGB GB NVMe SSD</div>
                        <div class="text-secondary py-1"><i class="bi bi-arrow-left-right accent"></i> @(v.BandwidthGB / 1000) TB bandwidth</div>
                        <div class="text-secondary py-1"><i class="bi bi-terminal accent"></i> Full root access</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Reseller -->
    <div class="tabpane d-none" data-pane="reseller">
        @if (Model.ResellerPackages.Any())
        {
            <div class="row g-4 justify-content-center">
                @foreach (var r in Model.ResellerPackages)
                {
                    <div class="col-lg-4 col-md-6">
                        <div style="background:#161b22;border:1px solid #30363d;border-radius:16px;padding:30px;height:100%;">
                            <h3 class="text-light">@r.Name</h3>
                            <p class="text-secondary" style="min-height:44px;">@r.Description</p>
                            <div class="my-3"><span style="font-size:42px;font-weight:800;color:#fff;">@Money(r.Price)</span> <span class="text-secondary">/mo</span></div>
                            <a href="/register" class="btn btn-outline-cta w-100 mb-3">Start Reselling</a>
                            <div class="text-secondary py-1"><i class="bi bi-check-lg accent"></i> @Disk(r.DiskQuotaMB) storage</div>
                            <div class="text-secondary py-1"><i class="bi bi-check-lg accent"></i> @Limit(r.MaxDomains) domains</div>
                            <div class="text-secondary py-1"><i class="bi bi-check-lg accent"></i> White-label branding</div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-secondary py-5">
                <i class="bi bi-shop" style="font-size:48px;"></i>
                <h4 class="text-light mt-3">Become a reseller</h4>
                <p>Launch your own hosting brand with white-label control panels and your own pricing.</p>
                <a href="/contact" class="btn btn-cta">Contact Sales</a>
            </div>
        }
    </div>

    <div class="text-center mt-4">
        <span class="badge rounded-pill" style="background:#161b22;border:1px solid #30363d;padding:10px 18px;color:#c9d1d9;">
            <i class="bi bi-shield-check accent"></i> 30-day money-back guarantee
        </span>
    </div>
</div>

<!-- FAQ -->
<section class="py-5" style="background:#0b0f14;">
    <div class="container" style="max-width:800px;">
        <h2 class="text-center text-light fw-bold mb-4">Frequently asked questions</h2>
        <div class="accordion" id="faq">
            @{
                var faqs = new (string Q, string A)[]
                {
                    ("Do I need a credit card to start?", "No. Every plan comes with a 14-day free trial and no credit card is required to begin."),
                    ("Can I upgrade or downgrade later?", "Absolutely. You can change your plan any time from your dashboard and we prorate the difference."),
                    ("Is there a money-back guarantee?", "Yes — if you're not happy within 30 days, we'll refund your payment in full."),
                    ("Do you offer free SSL?", "Every domain gets a free Let's Encrypt certificate that renews automatically."),
                    ("Can I host multiple websites?", "Yes, depending on your plan. Business and Enterprise plans support multiple or unlimited domains.")
                };
                var fi = 0;
            }
            @foreach (var f in faqs)
            {
                var id = $"faq{fi++}";
                <div class="accordion-item" style="background:#161b22;border-color:#30363d;">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@id" style="background:#161b22;color:#e6edf3;">@f.Q</button>
                    </h2>
                    <div id="@id" class="accordion-collapse collapse" data-bs-parent="#faq">
                        <div class="accordion-body text-secondary">@f.A</div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('.tabbtn').forEach(function (b) {
            b.addEventListener('click', function () {
                document.querySelectorAll('.tabbtn').forEach(function (x) { x.classList.remove('active','btn-cta'); x.classList.add('btn-outline-cta'); });
                b.classList.add('active','btn-cta'); b.classList.remove('btn-outline-cta');
                var t = b.dataset.tab;
                document.querySelectorAll('.tabpane').forEach(function (p) { p.classList.toggle('d-none', p.dataset.pane !== t); });
            });
        });
        document.getElementById('cycleToggle').addEventListener('change', function () {
            var annual = this.checked;
            document.querySelectorAll('.price-m').forEach(function (e) { e.classList.toggle('d-none', annual); });
            document.querySelectorAll('.price-a').forEach(function (e) { e.classList.toggle('d-none', !annual); });
        });
    </script>
}
