@page
@model SRXPanel.Pages.Domains.IndexModel
@{
    ViewData["Title"] = "Domains";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Domains</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">Domains</h4>
    <a asp-page="/Domains/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Domain</a>
</div>

<div class="card srx-card">
    <div class="card-body">
        @if (Model.Domains.Any())
        {
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Domain</th>
                        @if (Model.ShowOwner)
                        {
                            <th>Owner</th>
                        }
                        <th>Document Root</th>
                        <th>PHP</th>
                        <th>SSL</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Domains)
                    {
                        <tr>
                            <td>@d.DomainName</td>
                            @if (Model.ShowOwner)
                            {
                                <td>@(d.User?.UserName ?? "-")</td>
                            }
                            <td><code>@d.DocumentRoot</code></td>
                            <td>@d.PhpVersion</td>
                            <td>
                                @if (d.SslEnabled)
                                {
                                    <i class="bi bi-shield-lock-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-shield-slash text-secondary"></i>
                                }
                            </td>
                            <td>
                                @if (d.IsActive)
                                {
                                    <span class="badge srx-badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge srx-badge-suspended">Disabled</span>
                                }
                            </td>
                            <td>@d.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <form method="post" asp-page-handler="ToggleActive" asp-route-id="@d.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-warning" title="@(d.IsActive ? "Disable" : "Enable")">
                                            <i class="bi @(d.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@d.Id" class="d-inline srx-confirm-form" data-confirm-message="Remove domain '@d.DomainName'?">
                                        <button type="submit" class="btn btn-outline-danger" title="Remove">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No domains found.</p>
        }
    </div>
</div>
