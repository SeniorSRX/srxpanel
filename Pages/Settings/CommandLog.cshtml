@page
@model SRXPanel.Pages.Settings.CommandLogModel
@{
    ViewData["Title"] = "Command Log";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
            <li class="breadcrumb-item active" aria-current="page">Command Log</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">Command Log</h4>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex gap-2">
            <select name="ServiceFilter" class="form-select form-select-sm" onchange="this.form.submit()" style="min-width: 160px;">
                <option value="">All services</option>
                @foreach (var s in Model.Services)
                {
                    if (s == Model.ServiceFilter)
                    {
                        <option value="@s" selected>@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            </select>
        </form>
        <form method="post" asp-page-handler="Clear" class="srx-confirm-form" data-confirm-message="Clear the entire command log?">
            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Clear</button>
        </form>
    </div>
</div>

<div class="card srx-card">
    <div class="card-body">
        @if (Model.Logs.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Service</th>
                            <th>Mode</th>
                            <th>Exit</th>
                            <th>Command / Output</th>
                            <th>By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.Logs)
                        {
                            <tr>
                                <td class="text-nowrap small">@log.ExecutedAt.ToString("MM-dd HH:mm:ss")</td>
                                <td>@(string.IsNullOrEmpty(log.Service) ? "-" : log.Service)</td>
                                <td>
                                    @if (log.Simulated)
                                    {
                                        <span class="badge text-bg-warning">SIM</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-info">LIVE</span>
                                    }
                                </td>
                                <td>
                                    @if (log.ExitCode == 0)
                                    {
                                        <span class="badge srx-badge-active">0</span>
                                    }
                                    else
                                    {
                                        <span class="badge srx-badge-suspended">@log.ExitCode</span>
                                    }
                                </td>
                                <td>
                                    <code class="d-block text-info small">@log.Command</code>
                                    @if (!string.IsNullOrWhiteSpace(log.Output))
                                    {
                                        <pre class="small text-secondary mb-0 mt-1" style="white-space: pre-wrap; max-height: 160px; overflow-y: auto;">@log.Output</pre>
                                    }
                                </td>
                                <td class="small">@log.TriggeredBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination pagination-sm mb-0">
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : "")">
                                <a class="page-link" asp-route-Page="@p" asp-route-ServiceFilter="@Model.ServiceFilter">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <p class="text-secondary mb-0">No commands logged yet. Perform an action (create a domain, database, etc.) to see entries here.</p>
        }
    </div>
</div>
