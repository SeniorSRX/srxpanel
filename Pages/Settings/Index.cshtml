@page
@model SRXPanel.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Settings</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">Panel Settings</h4>
    <a asp-page="/Settings/CommandLog" class="btn btn-outline-secondary"><i class="bi bi-terminal"></i> Command Log</a>
</div>

<div class="alert @(Model.EffectiveSimulationMode ? "alert-warning" : "alert-success") d-flex align-items-center gap-2">
    <i class="bi @(Model.EffectiveSimulationMode ? "bi-cpu" : "bi-hdd-network")"></i>
    <div>
        <strong>Execution mode: @(Model.EffectiveSimulationMode ? "SIMULATION" : "LIVE (Linux)")</strong> —
        @if (Model.EffectiveSimulationMode)
        {
            <span>system commands are logged to the Command Log but not executed. Ideal for Windows/dev.</span>
        }
        else
        {
            <span>system commands are executed on the host (nginx, mysql, bind9, vsftpd, postfix, certbot).</span>
        }
    </div>
</div>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card srx-card h-100">
                <div class="card-body">
                    <h6 class="text-light mb-3"><i class="bi bi-sliders"></i> General</h6>
                    <div class="mb-3">
                        <label asp-for="Input.Hostname" class="form-label">Panel Hostname</label>
                        <input asp-for="Input.Hostname" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.DefaultPhpVersion" class="form-label">Default PHP Version</label>
                        <select asp-for="Input.DefaultPhpVersion" class="form-select">
                            @foreach (var v in Model.PhpVersions)
                            {
                                <option value="@v">PHP @v</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.MaxUploadSizeMB" class="form-label">Max Upload Size (MB)</label>
                        <input asp-for="Input.MaxUploadSizeMB" type="number" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.LetsEncryptEmail" class="form-label">Let's Encrypt Default Email</label>
                        <input asp-for="Input.LetsEncryptEmail" class="form-control" />
                    </div>
                    <div class="mb-0">
                        <label asp-for="Input.SshKeyPath" class="form-label">SSH Key Path (remote execution)</label>
                        <input asp-for="Input.SshKeyPath" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card srx-card h-100">
                <div class="card-body">
                    <h6 class="text-light mb-3"><i class="bi bi-toggle-on"></i> Execution</h6>
                    <div class="form-check form-switch mb-3">
                        <input asp-for="SimulationMode" class="form-check-input" role="switch" />
                        <label asp-for="SimulationMode" class="form-check-label">Simulation Mode (log commands, don't execute)</label>
                    </div>
                    <p class="text-secondary small">
                        Leave ON for Windows/dev. Turn OFF only on a real Ubuntu 22.04 host where nginx,
                        mysql, bind9, vsftpd, postfix and certbot are installed and the panel runs as root.
                    </p>

                    <h6 class="text-light mb-3 mt-4"><i class="bi bi-database"></i> MySQL Root Connection</h6>
                    <div class="row g-2">
                        <div class="col-8">
                            <label asp-for="Input.MySql.Host" class="form-label">Host</label>
                            <input asp-for="Input.MySql.Host" class="form-control" />
                        </div>
                        <div class="col-4">
                            <label asp-for="Input.MySql.Port" class="form-label">Port</label>
                            <input asp-for="Input.MySql.Port" type="number" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Input.MySql.RootUser" class="form-label">Root User</label>
                            <input asp-for="Input.MySql.RootUser" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Input.MySql.RootPassword" class="form-label">Root Password</label>
                            <input asp-for="Input.MySql.RootPassword" type="password" class="form-control" autocomplete="new-password" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-12">
            <div class="card srx-card">
                <div class="card-body">
                    <h6 class="text-light mb-3"><i class="bi bi-envelope-at"></i> SMTP (outgoing mail)</h6>
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label asp-for="Input.Smtp.Host" class="form-label">Host</label>
                            <input asp-for="Input.Smtp.Host" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.Smtp.Port" class="form-label">Port</label>
                            <input asp-for="Input.Smtp.Port" type="number" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Input.Smtp.User" class="form-label">User</label>
                            <input asp-for="Input.Smtp.User" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Input.Smtp.Password" class="form-label">Password</label>
                            <input asp-for="Input.Smtp.Password" type="password" class="form-control" autocomplete="new-password" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Smtp.From" class="form-label">From Address</label>
                            <input asp-for="Input.Smtp.From" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Settings</button>
        <a asp-page="/Dashboard/Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
