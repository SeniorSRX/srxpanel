@page
@model SRXPanel.Pages.Ftp.IndexModel
@{
    ViewData["Title"] = "FTP Accounts";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">FTP Accounts</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">FTP Accounts</h4>
    <a asp-page="/Ftp/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New FTP Account</a>
</div>

<div class="card srx-card">
    <div class="card-body">
        @if (Model.Accounts.Any())
        {
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Username</th>
                        @if (Model.ShowOwner)
                        {
                            <th>Owner</th>
                        }
                        <th>Home Directory</th>
                        <th>Quota</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Model.Accounts)
                    {
                        <tr>
                            <td>@f.Username</td>
                            @if (Model.ShowOwner)
                            {
                                <td>@(f.User?.UserName ?? "-")</td>
                            }
                            <td><code>@f.HomeDirectory</code></td>
                            <td>@(f.QuotaMB == 0 ? "Unlimited" : $"{f.QuotaMB} MB")</td>
                            <td>
                                @if (f.IsActive)
                                {
                                    <span class="badge srx-badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge srx-badge-suspended">Disabled</span>
                                }
                            </td>
                            <td>@f.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-page="/Ftp/Edit" asp-route-id="@f.Id" class="btn btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <form method="post" asp-page-handler="ToggleActive" asp-route-id="@f.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-warning" title="@(f.IsActive ? "Disable" : "Enable")">
                                            <i class="bi @(f.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@f.Id" class="d-inline srx-confirm-form" data-confirm-message="Delete FTP account '@f.Username'?">
                                        <button type="submit" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No FTP accounts found.</p>
        }
    </div>
</div>
