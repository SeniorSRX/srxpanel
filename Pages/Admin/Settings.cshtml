@page
@model SRXPanel.Pages.Admin.SettingsModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Platform Settings";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item">Admin</li>
            <li class="breadcrumb-item active" aria-current="page">Platform Settings</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">Platform Settings</h4>

@if (Model.SmtpTestResult != null)
{
    <div class="alert alert-info"><i class="bi bi-envelope-check"></i> @Model.SmtpTestResult</div>
}

<form method="post">
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card srx-card mb-4">
                <div class="card-body">
                    <h6 class="text-light mb-3"><i class="bi bi-globe"></i> Identity</h6>
                    <div class="mb-2"><label class="form-label">Platform Name</label><input asp-for="Settings.PlatformName" class="form-control" /></div>
                    <div class="mb-2"><label class="form-label">Logo Path</label><input asp-for="Settings.LogoPath" class="form-control" placeholder="/img/logo.png" /></div>
                    <div class="mb-2"><label class="form-label">Default Currency</label><input asp-for="Settings.DefaultCurrency" class="form-control" /></div>
                    <div class="row g-2">
                        <div class="col-6"><label class="form-label">Terms URL</label><input asp-for="Settings.TermsUrl" class="form-control" /></div>
                        <div class="col-6"><label class="form-label">Privacy URL</label><input asp-for="Settings.PrivacyUrl" class="form-control" /></div>
                    </div>
                </div>
            </div>

            <div class="card srx-card">
                <div class="card-body">
                    <h6 class="text-light mb-3"><i class="bi bi-cash-coin"></i> Fees &amp; Trial</h6>
                    <div class="row g-2">
                        <div class="col-6 mb-2"><label class="form-label">Platform Fee %</label><input asp-for="Settings.PlatformFeePercent" type="number" step="0.01" class="form-control" /></div>
                        <div class="col-6 mb-2"><label class="form-label">Trial Period (days)</label><input asp-for="Settings.TrialPeriodDays" type="number" class="form-control" /></div>
                        <div class="col-6 mb-2"><label class="form-label">Min Payout Amount</label><input asp-for="Settings.MinPayoutAmount" type="number" step="0.01" class="form-control" /></div>
                        <div class="col-6 mb-2"><label class="form-label">Affiliate Commission %</label><input asp-for="Settings.DefaultAffiliateCommission" type="number" step="0.01" class="form-control" /></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card srx-card mb-4">
                <div class="card-body">
                    <h6 class="text-light mb-3"><i class="bi bi-toggles"></i> Access &amp; Modes</h6>
                    <div class="mb-2"><label class="form-label">Registration</label>
                        <select asp-for="Settings.Registration" asp-items="Html.GetEnumSelectList<RegistrationMode>()" class="form-select"></select>
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" asp-for="Settings.RequireEmailVerification" />
                        <label class="form-check-label">Require email verification</label>
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" asp-for="Settings.MaintenanceMode" />
                        <label class="form-check-label">Maintenance mode</label>
                    </div>
                </div>
            </div>

            <div class="card srx-card">
                <div class="card-body">
                    <h6 class="text-light mb-3"><i class="bi bi-envelope-gear"></i> SMTP</h6>
                    <p class="text-secondary small">SMTP host/credentials are configured in <code>appsettings</code> under <code>Panel:Smtp</code>. Use the button to verify connectivity.</p>
                    <button type="submit" class="btn btn-outline-secondary btn-sm" asp-page-handler="TestSmtp"><i class="bi bi-plug"></i> Test SMTP Connection</button>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Platform Settings</button>
    </div>
</form>

<hr class="my-4 border-secondary" />

<form method="post" asp-page-handler="Backup">
    <div class="card srx-card">
        <div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-cloud-arrow-up"></i> Off-site Backup (S3 / Backblaze B2)</h6>
            <p class="text-secondary small">
                Configure the S3-compatible bucket used to store customer backups off-site. For Backblaze B2, set
                the endpoint (e.g. <code>s3.us-west-002.backblazeb2.com</code>). Leave blank to keep backups local only.
            </p>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Provider</label>
                    <select asp-for="Backup.Provider" class="form-select">
                        <option value="S3">Amazon S3</option>
                        <option value="Backblaze">Backblaze B2</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Bucket Name</label>
                    <input asp-for="Backup.BucketName" class="form-control" placeholder="my-backups" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Region</label>
                    <input asp-for="Backup.Region" class="form-control" placeholder="us-east-1" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Access Key</label>
                    <input asp-for="Backup.AccessKey" class="form-control" autocomplete="off" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Secret Key</label>
                    <input asp-for="Backup.SecretKey" type="password" class="form-control" autocomplete="off" />
                </div>
                <div class="col-md-12">
                    <label class="form-label">Endpoint (Backblaze / custom S3 only)</label>
                    <input asp-for="Backup.Endpoint" class="form-control" placeholder="s3.us-west-002.backblazeb2.com" />
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Backup Settings</button>
            </div>
        </div>
    </div>
</form>
