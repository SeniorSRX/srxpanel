@page
@model SRXPanel.Pages.Admin.AddonsModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Add-ons";
    string Money(decimal d) => $"${d:0.00}";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item">Store Admin</li>
        <li class="breadcrumb-item active" aria-current="page">Add-ons</li>
    </ol></nav>
}

<h4 class="text-light mb-4">Add-on Services</h4>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card srx-card"><div class="card-body">
            <table class="table align-middle mb-0">
                <thead><tr><th>Name</th><th>Type</th><th>Value</th><th class="text-end">Price</th><th>Active</th><th></th></tr></thead>
                <tbody>
                @if (!Model.Addons.Any())
                {
                    <tr><td colspan="6" class="text-secondary text-center py-3">No add-ons yet.</td></tr>
                }
                @foreach (var a in Model.Addons)
                {
                    <tr>
                        <td class="text-light">@a.Name<div class="text-secondary small">@a.Description</div></td>
                        <td class="text-secondary small">@a.Type</td>
                        <td class="text-secondary small">@a.Value</td>
                        <td class="text-end text-light">@Money(a.Price)</td>
                        <td>
                            <form method="post" asp-page-handler="Toggle"><input type="hidden" name="id" value="@a.Id" />
                                <button class="btn btn-sm @(a.IsActive ? "btn-success" : "btn-outline-secondary")">@(a.IsActive ? "On" : "Off")</button></form>
                        </td>
                        <td class="text-end text-nowrap">
                            <a href="?editId=@a.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Delete this add-on?');"><input type="hidden" name="id" value="@a.Id" />
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div></div>
    </div>

    <div class="col-lg-4">
        <div class="card srx-card"><div class="card-body">
            <h6 class="text-light mb-3">@(Model.Editing ? "Edit add-on" : "New add-on")</h6>
            <form method="post" asp-page-handler="Save">
                <input type="hidden" asp-for="Input.Id" />
                <div class="mb-2"><label class="form-label">Name</label><input asp-for="Input.Name" class="form-control form-control-sm" /></div>
                <div class="mb-2"><label class="form-label">Description</label><textarea asp-for="Input.Description" class="form-control form-control-sm" rows="2"></textarea></div>
                <div class="mb-2"><label class="form-label">Type</label>
                    <select asp-for="Input.Type" asp-items="Html.GetEnumSelectList<AddonType>()" class="form-select form-select-sm"></select>
                </div>
                <div class="row g-2">
                    <div class="col-6 mb-2"><label class="form-label">Value</label><input asp-for="Input.Value" type="number" class="form-control form-control-sm" /></div>
                    <div class="col-6 mb-2"><label class="form-label">Price</label><input asp-for="Input.Price" type="number" step="0.01" class="form-control form-control-sm" /></div>
                    <div class="col-6 mb-2"><label class="form-label">Cycle</label><select asp-for="Input.BillingCycle" asp-items="Html.GetEnumSelectList<BillingCycle>()" class="form-select form-select-sm"></select></div>
                    <div class="col-6 mb-2"><label class="form-label">Sort</label><input asp-for="Input.SortOrder" type="number" class="form-control form-control-sm" /></div>
                </div>
                <div class="form-check form-switch mb-3"><input class="form-check-input" asp-for="Input.IsActive" /><label class="form-check-label">Active</label></div>
                <button class="btn btn-primary btn-sm"><i class="bi bi-save"></i> Save</button>
                @if (Model.Editing)
                {
                    <a href="/Admin/Addons" class="btn btn-outline-secondary btn-sm">Cancel</a>
                }
            </form>
        </div></div>
    </div>
</div>
