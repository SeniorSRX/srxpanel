@page
@model SRXPanel.Pages.Admin.Security.WafModel
@{
    ViewData["Title"] = "WAF";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Admin/Security/Index">Security</a></li>
        <li class="breadcrumb-item active" aria-current="page">WAF</li>
    </ol></nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">WAF — Global</h4>
    <div class="d-flex align-items-center gap-2">
        <span class="text-secondary small">OWASP CRS v@Model.CrsVersion</span>
        <form method="post" asp-page-handler="UpdateCrs"><button class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-repeat"></i> Update CRS</button></form>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card srx-card"><div class="card-body text-center">
            <i class="bi bi-shield-exclamation" style="font-size:26px;color:#f85149;"></i>
            <div style="font-size:30px;font-weight:800;color:#fff;">@Model.TotalAlerts</div>
            <div class="text-secondary small">Total WAF alerts</div>
        </div></div>
        <div class="card srx-card mt-4"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-hdd-network"></i> Top attacking IPs</h6>
            @foreach (var ip in Model.TopIps)
            {
                <div class="d-flex justify-content-between py-1"><span class="text-light small">@ip.IP</span><span class="badge text-bg-danger">@ip.Count</span></div>
            }
        </div></div>
    </div>

    <div class="col-lg-8">
        <div class="card srx-card mb-4"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-fire"></i> Top triggered rules</h6>
            @foreach (var r in Model.TopRules)
            {
                <div class="d-flex justify-content-between py-1"><span class="text-light small"><code>@r.Rule</code> @r.Message</span><span class="badge text-bg-secondary">@r.Count</span></div>
            }
        </div></div>

        <div class="card srx-card"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-list-check"></i> Per-domain WAF status</h6>
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>Domain</th><th>WAF</th><th>Mode</th><th>Alerts</th></tr></thead>
                <tbody>
                @if (!Model.DomainStatus.Any())
                {
                    <tr><td colspan="4" class="text-secondary text-center py-3">No WAF configurations yet.</td></tr>
                }
                @foreach (var d in Model.DomainStatus)
                {
                    <tr>
                        <td class="text-light">@d.Domain</td>
                        <td>@(d.Enabled ? Html.Raw("<span class='badge text-bg-success'>On</span>") : Html.Raw("<span class='badge text-bg-secondary'>Off</span>"))</td>
                        <td class="small">@d.Mode</td>
                        <td>@d.Alerts</td>
                    </tr>
                }
                </tbody>
            </table>
        </div></div>
    </div>
</div>
