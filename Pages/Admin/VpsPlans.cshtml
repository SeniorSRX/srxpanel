@page
@model SRXPanel.Pages.Admin.VpsPlansModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Manage VPS Plans";
    var formOpen = Model.EditMode || !ViewData.ModelState.IsValid;
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">VPS Plans</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">VPS Plans</h4>
    <button class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#planForm"><i class="bi bi-plus-lg"></i> New VPS Plan</button>
</div>

<div class="collapse mb-4 @(formOpen ? "show" : "")" id="planForm">
    <div class="card srx-card">
        <div class="card-body">
            <h6 class="text-light mb-3">@(Model.EditMode ? "Edit VPS Plan" : "New VPS Plan")</h6>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <form method="post" asp-page-handler="Save">
                <input type="hidden" asp-for="Input.Id" />
                <div class="row g-2">
                    <div class="col-md-4"><label class="form-label">Name</label><input asp-for="Input.Name" class="form-control" /></div>
                    <div class="col-md-6"><label class="form-label">Description</label><input asp-for="Input.Description" class="form-control" /></div>
                    <div class="col-md-2"><label class="form-label">Sort Order</label><input asp-for="Input.SortOrder" class="form-control" /></div>

                    <div class="col-md-2"><label class="form-label">vCPU Cores</label><input asp-for="Input.CpuCores" class="form-control" /></div>
                    <div class="col-md-2"><label class="form-label">RAM (MB)</label><input asp-for="Input.RamMB" class="form-control" /></div>
                    <div class="col-md-2"><label class="form-label">Disk (GB)</label><input asp-for="Input.DiskGB" class="form-control" /></div>
                    <div class="col-md-2"><label class="form-label">Bandwidth (GB)</label><input asp-for="Input.BandwidthGB" class="form-control" /></div>
                    <div class="col-md-2"><label class="form-label">Price</label><input asp-for="Input.Price" class="form-control" /></div>
                    <div class="col-md-2"><label class="form-label">Cycle</label>
                        <select asp-for="Input.BillingCycle" class="form-select">
                            <option value="@BillingCycle.Monthly">Monthly</option>
                            <option value="@BillingCycle.Annual">Annual</option>
                        </select>
                    </div>

                    <div class="col-md-4"><label class="form-label">Location</label>
                        <input asp-for="Input.Location" class="form-control" list="knownLocations" />
                        <datalist id="knownLocations">
                            @foreach (var loc in Model.KnownLocations)
                            {
                                <option value="@loc"></option>
                            }
                        </datalist>
                    </div>
                    <div class="col-md-4"><label class="form-label">Proxmox Node</label>
                        <select asp-for="Input.NodeId" class="form-select">
                            <option value="">Auto (least loaded)</option>
                            @foreach (var n in Model.Nodes)
                            {
                                <option value="@n.Id">@n.Name — @n.Location</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end gap-4">
                        <div class="form-check">
                            <input asp-for="Input.IsPopular" class="form-check-input" />
                            <label asp-for="Input.IsPopular" class="form-check-label">Popular</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Input.IsActive" class="form-check-input" />
                            <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Operating Systems <span class="text-secondary small">(stored as CSV)</span></label>
                        @if (Model.AvailableOs.Any())
                        {
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (var os in Model.AvailableOs)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="SelectedOs" value="@os"
                                               id="os_@os" @(Model.SelectedOs.Contains(os) ? "checked" : "") />
                                        <label class="form-check-label text-capitalize" for="os_@os">@os</label>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-warning small">No OS templates configured yet — add VPS templates first.</div>
                        }
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Offered Templates <span class="text-secondary small">(Ctrl/Cmd-click for multiple)</span></label>
                        <select name="SelectedTemplateIds" class="form-select" multiple size="5">
                            @foreach (var t in Model.Templates)
                            {
                                <option value="@t.Id" selected="@Model.SelectedTemplateIds.Contains(t.Id)">
                                    @t.Name (@t.OsType@(t.Node != null ? " · " + t.Node.Name : ""))
                                </option>
                            }
                        </select>
                        <div class="form-text">Leave empty to offer all templates on the selected node.</div>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-lg"></i> Save VPS Plan</button>
                    @if (Model.EditMode)
                    {
                        <a asp-page="/Admin/VpsPlans" class="btn btn-outline-secondary btn-sm">Cancel</a>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

<div class="card srx-card">
    <div class="card-body">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th><th>vCPU</th><th>RAM</th><th>Disk</th><th>Bandwidth</th>
                    <th>Price</th><th>Cycle</th><th>Location</th><th>Status</th><th>Popular</th><th>Sort</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Plans.Any())
                {
                    <tr><td colspan="12" class="text-center text-secondary py-4">No VPS plans yet. Create one above.</td></tr>
                }
                @foreach (var p in Model.Plans)
                {
                    var refCount = Model.InstanceCounts.TryGetValue(p.Id, out var c) ? c : 0;
                    <tr>
                        <td>@p.Name</td>
                        <td>@p.CpuCores</td>
                        <td>@p.RamMB MB</td>
                        <td>@p.DiskGB GB</td>
                        <td>@p.BandwidthGB GB</td>
                        <td>$@p.Price.ToString("0.00")</td>
                        <td>@p.BillingCycle</td>
                        <td class="small">@p.Location</td>
                        <td>@(p.IsActive ? Html.Raw("<span class='badge srx-badge-active'>Active</span>") : Html.Raw("<span class='badge srx-badge-suspended'>Inactive</span>"))</td>
                        <td>@(p.IsPopular ? Html.Raw("<i class='bi bi-star-fill text-warning'></i>") : Html.Raw("<span class='text-secondary'>—</span>"))</td>
                        <td>@p.SortOrder</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-page="/Admin/VpsPlans" asp-route-editId="@p.Id" class="btn btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                                <form method="post" asp-page-handler="Toggle" asp-route-id="@p.Id" class="d-inline">
                                    <button class="btn btn-outline-warning" title="Toggle active"><i class="bi @(p.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i></button>
                                </form>
                                @if (refCount == 0)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@p.Id" class="d-inline srx-confirm-form" data-confirm-message="Delete VPS plan '@p.Name'?">
                                        <button class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-outline-danger" title="@refCount instance(s) use this plan — deactivate instead" disabled><i class="bi bi-trash"></i></button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
