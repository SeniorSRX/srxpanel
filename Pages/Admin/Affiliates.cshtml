@page
@model SRXPanel.Pages.Admin.AffiliatesModel
@{
    ViewData["Title"] = "Affiliates";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item">Admin</li>
            <li class="breadcrumb-item active" aria-current="page">Affiliates</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">Affiliate Management</h4>

@if (Model.PendingPayouts.Any())
{
    <div class="card srx-card mb-4 border-warning">
        <div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-hourglass-split"></i> Pending Payout Requests</h6>
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>Affiliate</th><th class="text-end">Amount</th><th>Method</th><th>Details</th><th></th></tr></thead>
                <tbody>
                    @foreach (var p in Model.PendingPayouts)
                    {
                        <tr>
                            <td class="text-light">@Model.PayoutAffiliateNames[p.Id]</td>
                            <td class="text-end">@p.Amount.ToString("0.00")</td>
                            <td>@p.PaymentMethod</td>
                            <td class="small text-secondary">@p.PaymentDetails</td>
                            <td class="text-end text-nowrap">
                                <form method="post" asp-page-handler="PayoutDecision" class="d-inline">
                                    <input type="hidden" name="payoutId" value="@p.Id" />
                                    <input type="hidden" name="approve" value="true" />
                                    <button class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Approve</button>
                                </form>
                                <form method="post" asp-page-handler="PayoutDecision" class="d-inline">
                                    <input type="hidden" name="payoutId" value="@p.Id" />
                                    <input type="hidden" name="approve" value="false" />
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="card srx-card">
    <div class="card-body">
        <h6 class="text-light mb-3"><i class="bi bi-people"></i> All Affiliates</h6>
        @if (Model.Rows.Any())
        {
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>User</th><th>Code</th><th>Rate</th><th>Signups</th><th class="text-end">Pending</th><th>Rate / Adjust</th></tr></thead>
                <tbody>
                    @foreach (var r in Model.Rows)
                    {
                        <tr>
                            <td>
                                <strong class="text-light">@r.UserName</strong>
                                @if (r.FraudFlags.Any())
                                {
                                    <span class="badge text-bg-danger ms-1" title="@string.Join(", ", r.FraudFlags)"><i class="bi bi-exclamation-triangle"></i> fraud?</span>
                                }
                            </td>
                            <td><code>@r.Affiliate.Code</code></td>
                            <td>@r.Affiliate.CommissionPercent%</td>
                            <td>@r.Signups</td>
                            <td class="text-end">@r.Affiliate.PendingBalance.ToString("0.00")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <form method="post" asp-page-handler="SetRate" class="d-flex gap-1">
                                        <input type="hidden" name="affiliateId" value="@r.Affiliate.Id" />
                                        <input name="rate" type="number" step="0.1" value="@r.Affiliate.CommissionPercent" class="form-control form-control-sm" style="width:70px;" />
                                        <button class="btn btn-sm btn-outline-primary">Rate</button>
                                    </form>
                                    <form method="post" asp-page-handler="Adjust" class="d-flex gap-1">
                                        <input type="hidden" name="affiliateId" value="@r.Affiliate.Id" />
                                        <input name="amount" type="number" step="0.01" class="form-control form-control-sm" style="width:80px;" placeholder="±0.00" />
                                        <button class="btn btn-sm btn-outline-secondary">Adjust</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No affiliates yet.</p>
        }
    </div>
</div>
