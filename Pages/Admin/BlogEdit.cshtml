@page
@model SRXPanel.Pages.Admin.BlogEditModel
@{
    ViewData["Title"] = Model.IsNew ? "New Post" : "Edit Post";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item">Website</li>
            <li class="breadcrumb-item"><a asp-page="/Admin/Blog">Blog</a></li>
            <li class="breadcrumb-item active" aria-current="page">@(Model.IsNew ? "New" : "Edit")</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">@(Model.IsNew ? "New Post" : "Edit Post")</h4>

<form method="post" id="postForm">
    <input type="hidden" asp-for="Input.Id" />
    <input type="hidden" asp-for="Input.Content" id="Content" />
    <div asp-validation-summary="All" class="text-danger small mb-2"></div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card srx-card mb-4"><div class="card-body">
                <div class="mb-3"><label class="form-label">Title</label><input asp-for="Input.Title" class="form-control form-control-lg" required /></div>
                <div class="mb-3"><label class="form-label">Slug <span class="text-secondary small">(leave blank to auto-generate)</span></label><input asp-for="Input.Slug" class="form-control" /></div>
                <div class="mb-3"><label class="form-label">Excerpt</label><textarea asp-for="Input.Excerpt" class="form-control" rows="2"></textarea></div>
                <div class="mb-1"><label class="form-label">Content</label></div>
                <div id="editor" style="height:360px;background:#fff;border-radius:6px;"></div>
            </div></div>
        </div>

        <div class="col-lg-4">
            <div class="card srx-card mb-4"><div class="card-body">
                <h6 class="text-light mb-3">Publish</h6>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" asp-for="Input.Publish" />
                    <label class="form-check-label">Published</label>
                </div>
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-save"></i> Save post</button>
            </div></div>

            <div class="card srx-card mb-4"><div class="card-body">
                <h6 class="text-light mb-3">Organization</h6>
                <div class="mb-3"><label class="form-label">Category</label><select asp-for="Input.CategoryId" asp-items="Model.CategoryOptions" class="form-select"><option value="">— none —</option></select></div>
                <div class="mb-0"><label class="form-label">Tags <span class="text-secondary small">(comma separated)</span></label><input asp-for="Input.Tags" class="form-control" placeholder="hosting, security" /></div>
            </div></div>

            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3">Media &amp; SEO</h6>
                <div class="mb-3"><label class="form-label">Featured image URL</label><input asp-for="Input.FeaturedImage" class="form-control" placeholder="/img/post.jpg" /></div>
                <div class="mb-3"><label class="form-label">Meta title</label><input asp-for="Input.MetaTitle" class="form-control" /></div>
                <div class="mb-0"><label class="form-label">Meta description</label><textarea asp-for="Input.MetaDescription" class="form-control" rows="2"></textarea></div>
            </div></div>
        </div>
    </div>
</form>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
    <script>
        var quill = new Quill('#editor', {
            theme: 'snow',
            modules: { toolbar: [[{ header: [2, 3, false] }], ['bold', 'italic', 'underline'], [{ list: 'ordered' }, { list: 'bullet' }], ['blockquote', 'code-block'], ['link'], ['clean']] }
        });
        var initial = document.getElementById('Content').value;
        if (initial) quill.clipboard.dangerouslyPasteHTML(initial);
        document.getElementById('postForm').addEventListener('submit', function () {
            document.getElementById('Content').value = quill.root.innerHTML;
        });
    </script>
}
