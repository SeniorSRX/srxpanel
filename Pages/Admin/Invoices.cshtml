@page
@model SRXPanel.Pages.Admin.InvoicesModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Invoices";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Invoices</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">Invoices</h4>
    <a asp-page-handler="Export" asp-route-StatusFilter="@Model.StatusFilter" asp-route-FromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-ToDate="@Model.ToDate?.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary"><i class="bi bi-filetype-csv"></i> Export CSV</a>
</div>

<form method="get" class="card srx-card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Status</label>
                <select name="StatusFilter" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var s in Enum.GetNames<InvoiceStatus>())
                    {
                        if (s == Model.StatusFilter)
                        {
                            <option value="@s" selected>@s</option>
                        }
                        else
                        {
                            <option value="@s">@s</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3"><label class="form-label small">From</label><input type="date" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" /></div>
            <div class="col-md-3"><label class="form-label small">To</label><input type="date" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" /></div>
            <div class="col-md-3"><button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-funnel"></i> Filter</button></div>
        </div>
    </div>
</form>

<div class="card srx-card">
    <div class="card-body">
        <div class="mb-3 text-secondary">Total paid (filtered): <strong class="text-light">$@Model.TotalPaid.ToString("0.00")</strong></div>
        @if (Model.Invoices.Any())
        {
            <table class="table align-middle mb-0">
                <thead><tr><th>Number</th><th>Customer</th><th>Amount</th><th>Status</th><th>Created</th><th>Paid</th></tr></thead>
                <tbody>
                    @foreach (var i in Model.Invoices)
                    {
                        <tr>
                            <td><code>@i.Number</code></td>
                            <td>@(i.User?.UserName ?? "-")</td>
                            <td>@SRXPanel.Pages.Admin.InvoicesModel.Money(i.Amount, i.Currency)</td>
                            <td>
                                @if (i.Status == InvoiceStatus.Paid)
                                {
                                    <span class="badge srx-badge-active">Paid</span>
                                }
                                else if (i.Status == InvoiceStatus.Unpaid)
                                {
                                    <span class="badge text-bg-warning">Unpaid</span>
                                }
                                else
                                {
                                    <span class="badge srx-badge-suspended">Void</span>
                                }
                            </td>
                            <td>@i.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>@(i.PaidAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No invoices found.</p>
        }
    </div>
</div>
