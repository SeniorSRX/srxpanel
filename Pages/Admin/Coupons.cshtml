@page
@model SRXPanel.Pages.Admin.CouponsModel
@{
    ViewData["Title"] = "Coupons";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Coupons</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">Discount Coupons</h4>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card srx-card">
            <div class="card-body">
                <h6 class="text-light mb-3">Create Coupon</h6>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <form method="post" asp-page-handler="Create">
                    <div class="mb-2"><label class="form-label">Code</label><input asp-for="Input.Code" class="form-control" placeholder="SUMMER25" /></div>
                    <div class="mb-2"><label class="form-label">Discount %</label><input asp-for="Input.DiscountPercent" class="form-control" /></div>
                    <div class="mb-2"><label class="form-label">Max Uses (0 = unlimited)</label><input asp-for="Input.MaxUses" class="form-control" /></div>
                    <div class="mb-3"><label class="form-label">Expires (optional)</label><input asp-for="Input.ExpiresAt" type="date" class="form-control" /></div>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-lg"></i> Create &amp; Sync</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card srx-card">
            <div class="card-body">
                @if (Model.Coupons.Any())
                {
                    <table class="table align-middle mb-0">
                        <thead><tr><th>Code</th><th>Discount</th><th>Uses</th><th>Expires</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                        <tbody>
                            @foreach (var c in Model.Coupons)
                            {
                                <tr>
                                    <td><code>@c.Code</code></td>
                                    <td>@c.DiscountPercent%</td>
                                    <td>@c.UsedCount@(c.MaxUses > 0 ? $" / {c.MaxUses}" : "")</td>
                                    <td>@(c.ExpiresAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                                    <td>
                                        @if (c.IsValid)
                                        {
                                            <span class="badge srx-badge-active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge srx-badge-suspended">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <form method="post" asp-page-handler="Toggle" asp-route-id="@c.Id" class="d-inline">
                                                <button class="btn btn-outline-warning" title="Toggle"><i class="bi @(c.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i></button>
                                            </form>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id" class="d-inline srx-confirm-form" data-confirm-message="Delete coupon '@c.Code'?">
                                                <button class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-secondary mb-0">No coupons yet.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
