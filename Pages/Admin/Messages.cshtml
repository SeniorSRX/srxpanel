@page
@model SRXPanel.Pages.Admin.MessagesModel
@{
    ViewData["Title"] = "Messages";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item">Website</li>
            <li class="breadcrumb-item active" aria-current="page">Messages</li>
        </ol>
    </nav>
}

<h4 class="text-light mb-4">Contact Messages</h4>

<div class="card srx-card"><div class="card-body">
    @if (!Model.Messages.Any())
    {
        <p class="text-secondary mb-0 text-center py-3">No messages yet.</p>
    }
    else
    {
        <div class="accordion" id="msgs">
            @foreach (var m in Model.Messages)
            {
                <div class="accordion-item" style="background:#0d1117;border-color:#30363d;">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#m@(m.Id)" style="background:#0d1117;color:#e6edf3;">
                            @if (!m.IsRead) { <span class="badge text-bg-primary me-2">New</span> }
                            <span class="fw-semibold me-2">@m.Name</span>
                            <span class="text-secondary small me-2">@m.Email</span>
                            <span class="text-secondary small ms-auto me-3">@m.CreatedAt.ToString("MMM d, HH:mm")</span>
                        </button>
                    </h2>
                    <div id="m@(m.Id)" class="accordion-collapse collapse" data-bs-parent="#msgs">
                        <div class="accordion-body">
                            <div class="text-secondary small mb-1">Subject: <span class="text-light">@(m.Subject ?? "(none)")</span></div>
                            <p class="text-light" style="white-space:pre-wrap;">@m.Message</p>
                            <div class="d-flex gap-2">
                                <a href="mailto:@m.Email?subject=Re: @m.Subject" class="btn btn-sm btn-outline-primary"><i class="bi bi-reply"></i> Reply</a>
                                <form method="post" asp-page-handler="Toggle"><input type="hidden" name="id" value="@m.Id" /><button class="btn btn-sm btn-outline-secondary">Mark @(m.IsRead ? "unread" : "read")</button></form>
                                <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Delete this message?');"><input type="hidden" name="id" value="@m.Id" /><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div></div>
