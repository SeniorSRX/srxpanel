@page
@model SRXPanel.Pages.Admin.ResellerBillingModel
@using SRXPanel.Models
@{
    ViewData["Title"] = "Reseller Billing";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item">Admin</li>
            <li class="breadcrumb-item active" aria-current="page">Reseller Billing</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">Reseller Billing</h4>
    <div class="srx-stat-card" style="min-width:180px;">
        <div class="srx-stat-value">@Model.TotalFees.ToString("0.00")</div>
        <div class="srx-stat-label"><i class="bi bi-cash-stack"></i> Total Platform Fees</div>
    </div>
</div>

<div class="card srx-card mb-4">
    <div class="card-body">
        <h6 class="text-light mb-3"><i class="bi bi-people"></i> Reseller Balances</h6>
        @if (Model.Rows.Any())
        {
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>Reseller</th><th>Model</th><th class="text-end">Balance</th><th>Adjust / Invoice / Payout</th></tr></thead>
                <tbody>
                    @foreach (var r in Model.Rows)
                    {
                        <tr>
                            <td><strong class="text-light">@r.Profile.CompanyName</strong><div class="small text-secondary">@r.UserName</div></td>
                            <td><span class="badge text-bg-secondary">@r.Model</span></td>
                            <td class="text-end @(r.Balance < 0 ? "text-danger" : "text-light")">@r.Balance.ToString("0.00")</td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <form method="post" asp-page-handler="Adjust" class="d-flex gap-1">
                                        <input type="hidden" name="resellerId" value="@r.Profile.UserId" />
                                        <select name="type" class="form-select form-select-sm" style="width:auto;">
                                            <option value="@ResellerTransactionType.Credit">Credit</option>
                                            <option value="@ResellerTransactionType.Debit">Debit</option>
                                            <option value="@ResellerTransactionType.Fee">Fee</option>
                                        </select>
                                        <input name="amount" type="number" step="0.01" class="form-control form-control-sm" style="width:90px;" placeholder="0.00" />
                                        <input name="reason" class="form-control form-control-sm" style="width:120px;" placeholder="reason" />
                                        <button class="btn btn-sm btn-outline-primary">Apply</button>
                                    </form>
                                    <form method="post" asp-page-handler="GenerateInvoice" class="d-flex gap-1">
                                        <input type="hidden" name="resellerId" value="@r.Profile.UserId" />
                                        <input name="amount" type="number" step="0.01" class="form-control form-control-sm" style="width:90px;" placeholder="invoice" />
                                        <button class="btn btn-sm btn-outline-secondary" title="Generate monthly invoice"><i class="bi bi-receipt"></i></button>
                                    </form>
                                    <form method="post" asp-page-handler="Payout" class="d-flex gap-1">
                                        <input type="hidden" name="resellerId" value="@r.Profile.UserId" />
                                        <input name="amount" type="number" step="0.01" class="form-control form-control-sm" style="width:90px;" placeholder="payout" />
                                        <button class="btn btn-sm btn-outline-success" title="Record payout"><i class="bi bi-send"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No resellers yet.</p>
        }
    </div>
</div>

<div class="card srx-card">
    <div class="card-body">
        <h6 class="text-light mb-3"><i class="bi bi-send"></i> Recent Payouts</h6>
        @if (Model.RecentPayouts.Any())
        {
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>Date</th><th class="text-end">Amount</th><th>Note</th></tr></thead>
                <tbody>
                    @foreach (var p in Model.RecentPayouts)
                    {
                        <tr><td class="small text-secondary">@p.CreatedAt.ToString("yyyy-MM-dd")</td><td class="text-end">@p.Amount.ToString("0.00")</td><td class="small">@p.Description</td></tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-secondary mb-0">No payouts recorded.</p>
        }
    </div>
</div>
