@page "/Admin/Vps/Detail/{id:int}"
@model SRXPanel.Pages.Admin.Vps.DetailModel
@using SRXPanel.Models
@{
    ViewData["Title"] = $"VPS — {Model.Vps.Hostname}";
    var v = Model.Vps;
    (string cls, string text) Badge(VpsStatus s) => s switch
    {
        VpsStatus.Running => ("text-bg-success", "Running"),
        VpsStatus.Building => ("text-bg-info", "Building"),
        VpsStatus.Stopped => ("text-bg-secondary", "Stopped"),
        VpsStatus.Suspended => ("text-bg-warning", "Suspended"),
        VpsStatus.Error => ("text-bg-danger", "Error"),
        _ => ("text-bg-secondary", s.ToString())
    };
    var b = Badge(v.Status);
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Admin/Vps/Index">VPS</a></li>
        <li class="breadcrumb-item active" aria-current="page">@v.Hostname</li>
    </ol></nav>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="text-light mb-0"><i class="bi bi-hdd-rack accent"></i> @v.Hostname <span class="badge @b.cls">@b.text</span></h4>
        <div class="text-secondary small">
            VM @v.VmId · <span class="font-monospace">@(v.IpAddress ?? "—")</span> · @(v.Node?.Name) (@v.Node?.Location) · owner @(Model.Owner?.Email ?? v.UserId)
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card srx-card mb-3"><div class="card-body">
            <h6 class="text-light mb-3">Overview</h6>
            <div class="row g-3 mb-2">
                <div class="col-3 text-center"><div class="text-secondary small">CPU</div><div class="fs-4 text-light">@(Model.LiveStats?.CpuPercent.ToString("0") ?? "—")%</div></div>
                <div class="col-3 text-center"><div class="text-secondary small">RAM</div><div class="fs-4 text-light">@(Model.LiveStats?.RamPercent.ToString("0") ?? "—")%</div></div>
                <div class="col-3 text-center"><div class="text-secondary small">Disk</div><div class="fs-4 text-light">@(Model.LiveStats?.DiskPercent.ToString("0") ?? "—")%</div></div>
                <div class="col-3 text-center"><div class="text-secondary small">Bandwidth</div><div class="fs-4 text-light">@v.BandwidthPercent%</div></div>
            </div>
            <table class="table table-sm text-secondary mb-0">
                <tr><td>Resources</td><td class="text-end text-light">@v.CpuCores vCPU · @(v.RamMB / 1024) GB · @v.DiskGB GB · @(v.BandwidthGB / 1000) TB</td></tr>
                <tr><td>Plan</td><td class="text-end text-light">@(Model.Plan?.Name ?? "—")</td></tr>
                <tr><td>IPv6 / MAC</td><td class="text-end font-monospace small text-light">@(v.Ipv6Address ?? "—") · @(v.MacAddress ?? "—")</td></tr>
                <tr><td>Created / Renews</td><td class="text-end text-light">@v.CreatedAt.ToString("yyyy-MM-dd") / @(v.ExpiresAt?.ToString("yyyy-MM-dd") ?? "—")</td></tr>
                @if (v.SuspendedAt != null) { <tr><td>Suspended</td><td class="text-end text-warning">@v.SuspendedAt?.ToString("yyyy-MM-dd HH:mm") @(v.BandwidthSuspended ? "(bandwidth)" : "")</td></tr> }
            </table>
        </div></div>

        <div class="card srx-card mb-3"><div class="card-body">
            <h6 class="text-light mb-3">Power</h6>
            <form method="post" asp-page-handler="Power" class="d-flex flex-wrap gap-2">
                <button name="action" value="start" class="btn btn-sm btn-outline-success">Start</button>
                <button name="action" value="shutdown" class="btn btn-sm btn-outline-warning">Shutdown</button>
                <button name="action" value="stop" class="btn btn-sm btn-outline-danger">Force stop</button>
                <button name="action" value="restart" class="btn btn-sm btn-outline-secondary">Restart</button>
            </form>
        </div></div>

        <div class="card srx-card"><div class="card-body">
            <h6 class="text-light mb-3">Recent actions</h6>
            @if (!Model.Actions.Any()) { <p class="text-secondary mb-0">No actions yet.</p> }
            else
            {
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>Action</th><th>Status</th><th>When</th></tr></thead>
                    <tbody>
                    @foreach (var a in Model.Actions)
                    {
                        var sc = a.Status == VpsActionStatus.Success ? "text-bg-success" : a.Status == VpsActionStatus.Failed ? "text-bg-danger" : "text-bg-secondary";
                        <tr><td class="text-light">@a.Action</td><td><span class="badge @sc">@a.Status</span></td><td class="text-secondary small">@a.StartedAt.ToString("MM-dd HH:mm")</td></tr>
                    }
                    </tbody>
                </table>
            }
        </div></div>
    </div>

    <div class="col-lg-5">
        <div class="card srx-card border-warning mb-3"><div class="card-body">
            <h6 class="text-warning mb-3"><i class="bi bi-shield-lock"></i> Admin overrides</h6>

            <div class="d-flex gap-2 mb-3">
                @if (v.Status == VpsStatus.Suspended)
                {
                    <form method="post" asp-page-handler="Resume"><button class="btn btn-sm btn-outline-success"><i class="bi bi-play-circle"></i> Resume</button></form>
                }
                else
                {
                    <form method="post" asp-page-handler="Suspend" class="srx-confirm-form" data-confirm-message="Suspend this VPS?"><button class="btn btn-sm btn-outline-warning"><i class="bi bi-pause-circle"></i> Suspend</button></form>
                }
                <form method="post" asp-page-handler="ForceDelete" class="srx-confirm-form" data-confirm-message="Force-delete and destroy this VPS?"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Force delete</button></form>
            </div>

            <form method="post" asp-page-handler="Migrate" class="row g-2 align-items-end mb-3">
                <div class="col"><label class="form-label text-secondary small">Migrate to node</label>
                    <select name="targetNodeId" class="form-select form-select-sm">
                        @foreach (var n in Model.Nodes.Where(n => n.Id != v.NodeId))
                        {
                            <option value="@n.Id">@n.Name — @n.Location</option>
                        }
                    </select></div>
                <div class="col-auto"><button class="btn btn-sm btn-outline-primary">Migrate</button></div>
            </form>

            <form method="post" asp-page-handler="FreeDays" class="row g-2 align-items-end mb-3">
                <div class="col-auto"><label class="form-label text-secondary small">Add free days</label>
                    <input name="days" type="number" min="1" max="365" value="30" class="form-control form-control-sm" style="width:90px" /></div>
                <div class="col-auto"><button class="btn btn-sm btn-outline-primary">Add</button></div>
            </form>

            <form method="post" asp-page-handler="Override" class="mb-2">
                <label class="form-label text-secondary small">Override limits</label>
                <div class="row g-2">
                    <div class="col-6"><div class="input-group input-group-sm"><span class="input-group-text">vCPU</span><input name="cpuCores" type="number" value="@v.CpuCores" class="form-control" /></div></div>
                    <div class="col-6"><div class="input-group input-group-sm"><span class="input-group-text">RAM MB</span><input name="ramMB" type="number" value="@v.RamMB" class="form-control" /></div></div>
                    <div class="col-6"><div class="input-group input-group-sm"><span class="input-group-text">Disk GB</span><input name="diskGB" type="number" value="@v.DiskGB" class="form-control" /></div></div>
                    <div class="col-6"><div class="input-group input-group-sm"><span class="input-group-text">BW GB</span><input name="bandwidthGB" type="number" value="@v.BandwidthGB" class="form-control" /></div></div>
                </div>
                <button class="btn btn-sm btn-outline-primary mt-2">Apply override</button>
            </form>
        </div></div>

        <div class="card srx-card"><div class="card-body">
            <h6 class="text-light mb-3">Internal notes</h6>
            <form method="post" asp-page-handler="Notes">
                <textarea name="internalNotes" class="form-control mb-2" rows="4">@v.Notes</textarea>
                <button class="btn btn-sm btn-primary">Save notes</button>
            </form>
        </div></div>
    </div>
</div>
