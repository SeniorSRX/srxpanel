@page "/Admin/Nodes/Detail/{id:int}"
@model SRXPanel.Pages.Admin.Nodes.DetailModel
@using SRXPanel.Models
@{
    ViewData["Title"] = $"Node — {Model.Node.Name}";
    var node = Model.Node;
    var tab = Model.Tab;
    var m = Model.LiveMetrics;

    (string href, string icon, string label)[] tabs =
    {
        ("overview", "bi-speedometer2", "Overview"),
        ("services", "bi-hdd-stack", "Services"),
        ("domains", "bi-globe2", "Domains"),
        ("users", "bi-people", "Users"),
        ("alerts", "bi-bell", "Alerts"),
        ("maintenance", "bi-tools", "Maintenance")
    };
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Admin/Nodes/Index">Nodes</a></li>
        <li class="breadcrumb-item active" aria-current="page">@node.Name</li>
    </ol></nav>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="text-light mb-0">
            <i class="bi bi-server accent"></i> @node.Name
            @switch (node.Status)
            {
                case NodeStatus.Online: <span class="badge text-bg-success">Online</span> break;
                case NodeStatus.Offline: <span class="badge text-bg-danger">Offline</span> break;
                default: <span class="badge text-bg-warning">Maintenance</span> break;
            }
        </h4>
        <div class="text-secondary small">
            @node.Type · @node.IpAddress:@node.SshPort · @node.Location · @node.CpuCores vCPU / @node.RamGB GB / @node.DiskGB GB · @node.Os
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-4">
    @foreach (var (href, icon, label) in tabs)
    {
        <li class="nav-item">
            <a class="nav-link @(tab == href ? "active" : "")" asp-page="/Admin/Nodes/Detail" asp-route-id="@node.Id" asp-route-tab="@href">
                <i class="bi @icon"></i> @label
            </a>
        </li>
    }
</ul>

@if (tab == "overview")
{
    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card srx-card"><div class="card-body text-center">
            <div class="text-secondary small">CPU</div>
            <div class="fs-2 text-light" id="cpuVal">@(m?.CpuPercent.ToString("0") ?? "—")<span class="fs-6">%</span></div>
            <div class="progress" style="height:6px;"><div class="progress-bar bg-info" id="cpuBar" style="width:@(m?.CpuPercent ?? 0)%"></div></div>
        </div></div></div>
        <div class="col-md-3"><div class="card srx-card"><div class="card-body text-center">
            <div class="text-secondary small">RAM</div>
            <div class="fs-2 text-light" id="ramVal">@(m?.RamPercent.ToString("0") ?? "—")<span class="fs-6">%</span></div>
            <div class="progress" style="height:6px;"><div class="progress-bar bg-primary" id="ramBar" style="width:@(m?.RamPercent ?? 0)%"></div></div>
        </div></div></div>
        <div class="col-md-3"><div class="card srx-card"><div class="card-body text-center">
            <div class="text-secondary small">Disk</div>
            <div class="fs-2 text-light" id="diskVal">@(m?.DiskPercent.ToString("0") ?? "—")<span class="fs-6">%</span></div>
            <div class="progress" style="height:6px;"><div class="progress-bar bg-warning" id="diskBar" style="width:@(m?.DiskPercent ?? 0)%"></div></div>
        </div></div></div>
        <div class="col-md-3"><div class="card srx-card"><div class="card-body text-center">
            <div class="text-secondary small">Load / Uptime</div>
            <div class="fs-4 text-light" id="loadVal">@(m?.Load1.ToString("0.00") ?? "—")</div>
            <div class="text-secondary small">up @(m != null ? $"{(int)m.Uptime.TotalDays}d {m.Uptime.Hours}h" : "—")</div>
        </div></div></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card srx-card mb-4"><div class="card-body">
                <h6 class="text-light mb-3">Network throughput (last hour)</h6>
                <canvas id="netChart" height="110"></canvas>
            </div></div>

            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3">Top processes</h6>
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>PID</th><th>User</th><th>CPU%</th><th>MEM%</th><th>Command</th></tr></thead>
                    <tbody>
                        @foreach (var proc in Model.Processes)
                        {
                            <tr>
                                <td class="text-secondary small">@proc.Pid</td>
                                <td class="text-secondary small">@proc.User</td>
                                <td class="text-light small">@proc.CpuPercent</td>
                                <td class="text-secondary small">@proc.MemPercent</td>
                                <td class="text-secondary small font-monospace" style="word-break:break-all;">@proc.Command</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div></div>
        </div>

        <div class="col-lg-5">
            <div class="card srx-card mb-4"><div class="card-body">
                <h6 class="text-light mb-3">Disk usage</h6>
                @foreach (var disk in Model.Disks)
                {
                    <div class="d-flex justify-content-between small">
                        <span class="text-light font-monospace">@disk.Mount</span>
                        <span class="text-secondary">@disk.UsedGB / @disk.TotalGB GB</span>
                    </div>
                    <div class="progress mb-3" style="height:8px;">
                        <div class="progress-bar @(disk.UsedPercent >= 90 ? "bg-danger" : disk.UsedPercent >= 75 ? "bg-warning" : "bg-success")"
                             style="width:@disk.UsedPercent%"></div>
                    </div>
                }
            </div></div>

            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-2">Connection</h6>
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr><td class="text-secondary">Active connections</td><td class="text-light" id="connVal">@(m?.ActiveConnections.ToString() ?? "—")</td></tr>
                        <tr><td class="text-secondary">SSH latency</td><td class="text-light">@(node.LatencyMs?.ToString() ?? "—") ms</td></tr>
                        <tr><td class="text-secondary">Last ping</td><td class="text-light">@(node.LastPingAt?.ToString("HH:mm:ss") ?? "—")</td></tr>
                    </tbody>
                </table>
            </div></div>
        </div>
    </div>
}
else if (tab == "services")
{
    <div class="card srx-card"><div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>Service</th><th>Status</th><th>Version</th><th>Port</th><th>Last checked</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var service in node.Services.OrderBy(s => s.ServiceType))
                {
                    <tr>
                        <td class="text-light"><i class="bi bi-hdd"></i> @service.ServiceType</td>
                        <td>
                            @switch (service.Status)
                            {
                                case ServerServiceStatus.Running: <span class="badge text-bg-success">Running</span> break;
                                case ServerServiceStatus.Stopped: <span class="badge text-bg-secondary">Stopped</span> break;
                                case ServerServiceStatus.Error: <span class="badge text-bg-danger">Error</span> break;
                                default: <span class="badge text-bg-dark border border-secondary">Not installed</span> break;
                            }
                        </td>
                        <td class="text-secondary small">@service.Version</td>
                        <td class="text-secondary small">@service.Port</td>
                        <td class="text-secondary small">@service.LastCheckedAt.ToString("HH:mm:ss")</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-secondary" onclick="showLog('@service.ServiceType')" title="Logs"><i class="bi bi-file-text"></i></button>
                                @foreach (var action in new[] { "start", "stop", "restart" })
                                {
                                    <form method="post" asp-page-handler="ServiceAction" class="d-inline">
                                        <input type="hidden" name="service" value="@service.ServiceType" />
                                        <input type="hidden" name="action" value="@action" />
                                        <button class="btn btn-outline-secondary" title="@action">
                                            <i class="bi @(action == "start" ? "bi-play-fill" : action == "stop" ? "bi-stop-fill" : "bi-arrow-clockwise")"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div></div>

    <div class="mt-3">
        <h6 class="text-light mb-2">Install a service</h6>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var type in Enum.GetValues<ServerServiceType>())
            {
                if (node.Services.All(s => s.ServiceType != type))
                {
                    <form method="post" asp-page-handler="InstallService" class="d-inline">
                        <input type="hidden" name="service" value="@type" />
                        <button class="btn btn-sm btn-outline-primary"><i class="bi bi-download"></i> Install @type</button>
                    </form>
                }
            }
        </div>
    </div>

    <div class="modal fade" id="logModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title text-light"><i class="bi bi-file-text"></i> <span id="logTitle"></span></h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <pre class="bg-black p-3 rounded small mb-0" style="max-height:60vh;overflow:auto;"><code id="logBody"></code></pre>
                </div>
            </div>
        </div>
    </div>
}
else if (tab == "domains")
{
    <div class="card srx-card"><div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>Domain</th><th>Primary</th><th>Assigned</th><th class="text-end">Move to node</th></tr></thead>
            <tbody>
                @foreach (var dn in Model.Domains)
                {
                    <tr>
                        <td class="text-light">@dn.Domain?.DomainName</td>
                        <td>@if (dn.IsPrimary) { <span class="badge text-bg-primary">Primary</span> }</td>
                        <td class="text-secondary small">@dn.AssignedAt.ToString("MMM dd, yyyy")</td>
                        <td class="text-end">
                            <form method="post" asp-page-handler="MoveDomain" class="d-inline-flex gap-1">
                                <input type="hidden" name="domainId" value="@dn.DomainId" />
                                <select name="targetNodeId" class="form-select form-select-sm" style="width:auto;">
                                    @foreach (var other in Model.OtherNodes)
                                    {
                                        <option value="@other.Id">@other.Name</option>
                                    }
                                </select>
                                <button class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-right"></i> Migrate</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Domains.Any())
                {
                    <tr><td colspan="4" class="text-center text-secondary py-4">No domains on this node.</td></tr>
                }
            </tbody>
        </table>
    </div></div>
}
else if (tab == "users")
{
    <div class="card srx-card"><div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>User</th><th>Email</th><th>Assigned</th><th class="text-end">Move to node</th></tr></thead>
            <tbody>
                @foreach (var un in Model.Users)
                {
                    <tr>
                        <td class="text-light">@un.User?.UserName</td>
                        <td class="text-secondary small">@un.User?.Email</td>
                        <td class="text-secondary small">@un.AssignedAt.ToString("MMM dd, yyyy")</td>
                        <td class="text-end">
                            <form method="post" asp-page-handler="MoveUser" class="d-inline-flex gap-1">
                                <input type="hidden" name="userId" value="@un.UserId" />
                                <select name="targetNodeId" class="form-select form-select-sm" style="width:auto;">
                                    @foreach (var other in Model.OtherNodes)
                                    {
                                        <option value="@other.Id">@other.Name</option>
                                    }
                                </select>
                                <button class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-right"></i> Move</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Users.Any())
                {
                    <tr><td colspan="4" class="text-center text-secondary py-4">No users pinned to this node.</td></tr>
                }
            </tbody>
        </table>
    </div></div>
}
else if (tab == "alerts")
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card srx-card"><div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead><tr><th>Severity</th><th>Message</th><th>Raised</th><th class="text-end"></th></tr></thead>
                    <tbody>
                        @foreach (var alert in Model.Alerts)
                        {
                            <tr class="@(alert.IsAcknowledged ? "opacity-50" : "")">
                                <td>
                                    @switch (alert.Severity)
                                    {
                                        case AlertSeverity.Critical: <span class="badge text-bg-danger">Critical</span> break;
                                        case AlertSeverity.Warning: <span class="badge text-bg-warning">Warning</span> break;
                                        default: <span class="badge text-bg-info">Info</span> break;
                                    }
                                </td>
                                <td class="text-light small">@alert.Message</td>
                                <td class="text-secondary small">@alert.CreatedAt.ToString("MMM dd, HH:mm")</td>
                                <td class="text-end">
                                    @if (alert.IsAcknowledged)
                                    {
                                        <span class="text-secondary small"><i class="bi bi-check-all"></i> @alert.AcknowledgedBy</span>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Acknowledge" class="d-inline">
                                            <input type="hidden" name="alertId" value="@alert.Id" />
                                            <button class="btn btn-sm btn-outline-secondary">Acknowledge</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Alerts.Any())
                        {
                            <tr><td colspan="4" class="text-center text-secondary py-4">No alerts for this node.</td></tr>
                        }
                    </tbody>
                </table>
            </div></div>
        </div>
        <div class="col-lg-4">
            <div class="card srx-card"><div class="card-body">
                <h6 class="text-light mb-3">Alert thresholds</h6>
                <form method="post" asp-page-handler="Thresholds">
                    <div class="mb-2">
                        <label class="form-label small">CPU %</label>
                        <input name="cpu" type="number" min="50" max="100" value="@node.CpuThreshold" class="form-control form-control-sm" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">RAM %</label>
                        <input name="ram" type="number" min="50" max="100" value="@node.RamThreshold" class="form-control form-control-sm" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">Disk %</label>
                        <input name="disk" type="number" min="50" max="100" value="@node.DiskThreshold" class="form-control form-control-sm" />
                    </div>
                    <button class="btn btn-primary btn-sm w-100">Save thresholds</button>
                </form>
                <div class="text-secondary small mt-3">
                    CPU alerts fire only after the threshold is exceeded for 5 minutes. Unacknowledged critical
                    alerts escalate by email after 15 min and SMS after 30.
                </div>
            </div></div>
        </div>
    </div>
}
else if (tab == "maintenance")
{
    <div class="row g-4" style="max-width:820px;">
        <div class="col-md-6">
            <div class="card srx-card h-100"><div class="card-body">
                <h6 class="text-light mb-3">Maintenance mode</h6>
                <p class="text-secondary small">Serve a maintenance page for every site on this node.</p>
                <form method="post" asp-page-handler="Maintenance">
                    <input type="hidden" name="enable" value="@((node.Status != NodeStatus.Maintenance).ToString().ToLowerInvariant())" />
                    <button class="btn btn-sm @(node.Status == NodeStatus.Maintenance ? "btn-success" : "btn-outline-warning") w-100">
                        @(node.Status == NodeStatus.Maintenance ? "Disable maintenance mode" : "Enable maintenance mode")
                    </button>
                </form>
            </div></div>
        </div>
        <div class="col-md-6">
            <div class="card srx-card h-100"><div class="card-body">
                <h6 class="text-light mb-3">System updates</h6>
                <p class="text-secondary small">Run <code>apt update &amp;&amp; apt upgrade</code> on the node.</p>
                <form method="post" asp-page-handler="SystemUpdate">
                    <button class="btn btn-sm btn-outline-secondary w-100"><i class="bi bi-arrow-repeat"></i> Run system updates</button>
                </form>
            </div></div>
        </div>
        <div class="col-md-6">
            <div class="card srx-card h-100 border-warning"><div class="card-body">
                <h6 class="text-warning mb-3"><i class="bi bi-arrow-clockwise"></i> Reboot</h6>
                <p class="text-secondary small">Restart the server. Sites are briefly unavailable.</p>
                <form method="post" asp-page-handler="Reboot" onsubmit="return confirm('Reboot @node.Name now?');">
                    <button class="btn btn-sm btn-outline-warning w-100">Reboot server</button>
                </form>
            </div></div>
        </div>
        <div class="col-md-6">
            <div class="card srx-card h-100 border-danger"><div class="card-body">
                <h6 class="text-danger mb-3"><i class="bi bi-trash"></i> Remove node</h6>
                <p class="text-secondary small">Detach from the fleet. Move its domains first.</p>
                <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Remove @node.Name from the fleet?');">
                    <button class="btn btn-sm btn-outline-danger w-100">Remove node</button>
                </form>
            </div></div>
        </div>
    </div>

    <div class="card srx-card mt-4" style="max-width:820px;"><div class="card-body">
        <h6 class="text-light mb-2"><i class="bi bi-terminal"></i> Install the SRXPanel agent</h6>
        <p class="text-secondary small">Run this on the node to install the localhost-only monitoring agent:</p>
        <pre class="bg-black p-3 rounded small mb-0"><code>@Model.AgentInstallCommand</code></pre>
    </div></div>
}

@section Scripts {
    @if (tab == "overview")
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
        <script>
            var histLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.History.Select(h => h.Timestamp.ToString("HH:mm"))));
            var histIn = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.History.Select(h => h.NetworkInMbps)));
            var histOut = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.History.Select(h => h.NetworkOutMbps)));
            var grid = { color: '#21262d' }, ticks = { color: '#8b949e' };

            var netChart = new Chart(document.getElementById('netChart'), {
                type: 'line',
                data: { labels: histLabels, datasets: [
                    { label: 'In (Mbps)', data: histIn, borderColor: '#3fb950', backgroundColor: 'rgba(63,185,80,.1)', fill: true, tension: .3 },
                    { label: 'Out (Mbps)', data: histOut, borderColor: '#58a6ff', backgroundColor: 'rgba(88,166,255,.1)', fill: true, tension: .3 }
                ] },
                options: { plugins: { legend: { labels: { color: '#c9d1d9' } } }, scales: { x: { grid: grid, ticks: ticks }, y: { grid: grid, ticks: ticks } } }
            });

            function apply(d) {
                document.getElementById('cpuVal').innerHTML = Math.round(d.cpu) + '<span class="fs-6">%</span>';
                document.getElementById('ramVal').innerHTML = Math.round(d.ram) + '<span class="fs-6">%</span>';
                document.getElementById('diskVal').innerHTML = Math.round(d.disk) + '<span class="fs-6">%</span>';
                document.getElementById('cpuBar').style.width = d.cpu + '%';
                document.getElementById('ramBar').style.width = d.ram + '%';
                document.getElementById('diskBar').style.width = d.disk + '%';
                document.getElementById('loadVal').textContent = d.load1.toFixed(2);
                document.getElementById('connVal').textContent = d.conns;
                netChart.data.labels.push(new Date().toLocaleTimeString().slice(0,5));
                netChart.data.datasets[0].data.push(d.netIn);
                netChart.data.datasets[1].data.push(d.netOut);
                if (netChart.data.labels.length > 60) { netChart.data.labels.shift(); netChart.data.datasets.forEach(function(ds){ds.data.shift();}); }
                netChart.update('none');
            }

            var nodeId = @node.Id;
            var connected = false;
            if (window.signalR) {
                var conn = new signalR.HubConnectionBuilder().withUrl('/hubs/nodes').build();
                conn.on('metrics', function (d) { apply(d); });
                conn.start().then(function () { connected = true; conn.invoke('JoinNode', nodeId); }).catch(pollLoop);
            } else { pollLoop(); }

            // Fallback + supplement: poll every 30s (the monitor pushes each minute).
            function pollLoop() {
                setInterval(function () {
                    fetch('?handler=Metrics').then(function (r) { return r.json(); }).then(apply).catch(function(){});
                }, 30000);
            }
        </script>
    }
    else if (tab == "services")
    {
        <script>
            function showLog(service) {
                document.getElementById('logTitle').textContent = service + ' — last 50 lines';
                document.getElementById('logBody').textContent = 'Loading…';
                new bootstrap.Modal(document.getElementById('logModal')).show();
                fetch('?handler=ServiceLog&service=' + service)
                    .then(function (r) { return r.json(); })
                    .then(function (d) { document.getElementById('logBody').textContent = d.log; });
            }
        </script>
    }
}
