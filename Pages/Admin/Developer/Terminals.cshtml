@page
@model SRXPanel.Pages.Admin.Developer.TerminalsModel
@{
    ViewData["Title"] = "Terminal Sessions";

    string Duration(TimeSpan span) =>
        span.TotalHours >= 1 ? $"{(int)span.TotalHours}h {span.Minutes}m"
        : span.TotalMinutes >= 1 ? $"{(int)span.TotalMinutes}m {span.Seconds}s"
        : $"{span.Seconds}s";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb"><ol class="breadcrumb srx-breadcrumb mb-0">
        <li class="breadcrumb-item">Developer</li>
        <li class="breadcrumb-item active" aria-current="page">Terminal Sessions</li>
    </ol></nav>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="text-light mb-0">Terminal Sessions</h4>
        <div class="text-secondary small">
            Browser shell sessions. Each runs as its own user, never root, and closes after 30 minutes idle.
        </div>
    </div>
    <form method="post" asp-page-handler="Reap">
        <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-hourglass-split"></i> Close idle sessions</button>
    </form>
</div>

<div class="card srx-card mb-4"><div class="card-body">
    <h6 class="text-light mb-3">
        <i class="bi bi-broadcast text-success"></i> Active sessions
        <span class="badge text-bg-secondary">@Model.Active.Count</span>
    </h6>

    @if (!Model.Active.Any())
    {
        <p class="text-secondary small mb-0">No active terminal sessions.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr><th>User</th><th>IP address</th><th>Started</th><th>Duration</th><th>Idle</th><th>Commands</th><th class="text-end"></th></tr>
                </thead>
                <tbody>
                    @foreach (var session in Model.Active)
                    {
                        var idle = DateTime.UtcNow - session.LastActivityAt;
                        <tr>
                            <td>
                                <div class="text-light">@session.User?.UserName</div>
                                <div class="text-secondary" style="font-size:11px;">@session.User?.Email</div>
                            </td>
                            <td class="font-monospace small text-light">@session.IpAddress</td>
                            <td class="text-secondary small">@session.StartedAt.ToString("MMM dd, HH:mm:ss")</td>
                            <td class="text-secondary small">@Duration(session.Duration)</td>
                            <td>
                                <span class="badge @(idle.TotalMinutes > 20 ? "text-bg-warning" : "text-bg-secondary")">
                                    @Duration(idle)
                                </span>
                            </td>
                            <td class="text-secondary small">@session.CommandCount</td>
                            <td class="text-end">
                                @if (session.TerminationRequested)
                                {
                                    <span class="badge text-bg-warning">terminating…</span>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Terminate"
                                          onsubmit="return confirm('Terminate @session.User?.UserName\'s session? Their shell closes immediately.');">
                                        <input type="hidden" name="id" value="@session.Id" />
                                        <button class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-x-octagon"></i> Terminate
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div></div>

<div class="card srx-card"><div class="card-body">
    <h6 class="text-light mb-3"><i class="bi bi-clock-history"></i> Session history</h6>

    @if (!Model.History.Any())
    {
        <p class="text-secondary small mb-0">No closed sessions recorded.</p>
    }
    else
    {
        <div class="table-responsive" style="max-height:460px;overflow:auto;">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead>
                    <tr><th>User</th><th>IP address</th><th>Started</th><th>Ended</th><th>Duration</th><th>Commands</th><th>Client</th></tr>
                </thead>
                <tbody>
                    @foreach (var session in Model.History)
                    {
                        <tr>
                            <td class="text-light small">@session.User?.UserName</td>
                            <td class="font-monospace small text-secondary">@session.IpAddress</td>
                            <td class="text-secondary small">@session.StartedAt.ToString("MMM dd, HH:mm")</td>
                            <td class="text-secondary small">@(session.EndedAt?.ToString("HH:mm:ss") ?? "—")</td>
                            <td class="text-secondary small">@Duration(session.Duration)</td>
                            <td class="text-secondary small">@session.CommandCount</td>
                            <td class="text-secondary text-truncate" style="max-width:220px;font-size:11px;">@session.UserAgent</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div></div>
