@page
@model SRXPanel.Pages.Admin.BlogModel
@{
    ViewData["Title"] = "Blog";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb srx-breadcrumb mb-0">
            <li class="breadcrumb-item">Website</li>
            <li class="breadcrumb-item active" aria-current="page">Blog</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-light mb-0">Blog Posts</h4>
    <a href="/Admin/BlogEdit" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> New post</a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card srx-card"><div class="card-body">
            <table class="table align-middle mb-0">
                <thead><tr><th>Title</th><th>Category</th><th>Status</th><th>Views</th><th></th></tr></thead>
                <tbody>
                @if (!Model.Posts.Any())
                {
                    <tr><td colspan="5" class="text-secondary text-center py-3">No posts yet.</td></tr>
                }
                @foreach (var p in Model.Posts)
                {
                    <tr>
                        <td><a href="/Admin/BlogEdit?id=@p.Id" class="text-light text-decoration-none">@p.Title</a></td>
                        <td class="text-secondary small">@(p.Category?.Name ?? "—")</td>
                        <td>
                            @if (p.Status == BlogStatus.Published) { <span class="badge text-bg-success">Published</span> }
                            else { <span class="badge text-bg-secondary">Draft</span> }
                        </td>
                        <td class="text-secondary">@p.Views</td>
                        <td class="text-end text-nowrap">
                            <form method="post" asp-page-handler="Toggle" class="d-inline"><input type="hidden" name="id" value="@p.Id" /><button class="btn btn-sm btn-outline-secondary" title="Toggle publish"><i class="bi bi-arrow-repeat"></i></button></form>
                            <a href="/Admin/BlogEdit?id=@p.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Delete this post?');"><input type="hidden" name="id" value="@p.Id" /><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div></div>
    </div>

    <div class="col-lg-4">
        <div class="card srx-card"><div class="card-body">
            <h6 class="text-light mb-3"><i class="bi bi-tags"></i> Categories</h6>
            @foreach (var c in Model.Categories)
            {
                <div class="d-flex justify-content-between align-items-center py-1">
                    <span class="text-light">@c.Name <span class="text-secondary small">/@c.Slug</span></span>
                    <form method="post" asp-page-handler="DeleteCategory"><input type="hidden" name="id" value="@c.Id" /><button class="btn btn-sm btn-outline-danger py-0"><i class="bi bi-x"></i></button></form>
                </div>
            }
            <form method="post" asp-page-handler="AddCategory" class="border-top pt-3 mt-2">
                <input name="name" class="form-control form-control-sm mb-2" placeholder="Category name" required />
                <input name="description" class="form-control form-control-sm mb-2" placeholder="Description (optional)" />
                <button class="btn btn-sm btn-primary"><i class="bi bi-plus-lg"></i> Add category</button>
            </form>
        </div></div>
    </div>
</div>
