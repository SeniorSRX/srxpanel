# ─────────────────────────────────────────────────────────────
# SRXPanel Docker environment
# Copy to .env and fill in before running `docker compose up -d`
# ─────────────────────────────────────────────────────────────

# Public hostname for the panel (used for SSL and links)
PANEL_DOMAIN=panel.example.com

# Email for Let's Encrypt certificate registration
LETSENCRYPT_EMAIL=admin@example.com

# ── MySQL ──────────────────────────────────────────────────────
# Root password for the MySQL service (use a long random value)
MYSQL_ROOT_PASSWORD=change-me-root-password
# Application database + user
MYSQL_DATABASE=srxpanel
MYSQL_USER=srxpanel
MYSQL_PASSWORD=change-me-app-password

# ── Stripe (leave blank to run billing in simulation mode) ────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
