{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=srxpanel.db"
  },
  "Version": "1.0.0",
  "UpdateChannel": "stable",
  "SimulationMode": false,
  "PanelSettings": {
    "ShowPoweredBy": false,
    "ShowGithubLink": false,
    "DeveloperDocsPublic": false
  },
  "Stripe": {
    "PublishableKey": "",
    "SecretKey": "",
    "WebhookSecret": "",
    "Currency": "usd"
  },
  "Google": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "Twilio": {
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  },
  "Backup": {
    "Provider": "S3",
    "BucketName": "",
    "AccessKey": "",
    "SecretKey": "",
    "Region": "us-east-1",
    "Endpoint": ""
  },
  "Panel": {
    "Hostname": "panel.example.com",
    "DefaultPhpVersion": "8.3",
    "MaxUploadSizeMB": 100,
    "LetsEncryptEmail": "admin@example.com",
    "SshKeyPath": "/root/.ssh/id_rsa",
    "Smtp": {
      "Host": "localhost",
      "Port": 587,
      "User": "",
      "Password": "",
      "From": "no-reply@example.com"
    },
    "MySql": {
      "Host": "localhost",
      "Port": 3306,
      "RootUser": "root",
      "RootPassword": ""
    },
    "Nginx": {
      "SitesAvailable": "/etc/nginx/sites-available",
      "SitesEnabled": "/etc/nginx/sites-enabled",
      "LogDir": "/var/log/nginx",
      "PhpFpmSocketPattern": "/run/php/php{version}-fpm.sock"
    },
    "Bind": {
      "ZonesDir": "/etc/bind/zones",
      "NamedConfLocal": "/etc/bind/named.conf.local",
      "DefaultNs": "ns1.example.com.",
      "ServerIp": "203.0.113.10"
    },
    "Mail": {
      "VmailboxFile": "/etc/postfix/vmailbox",
      "VirtualFile": "/etc/postfix/virtual",
      "MaildirRoot": "/var/mail/vhosts"
    }
  }
}
